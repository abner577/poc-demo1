string getFilterForApprovalDetails(ApprovalDetailsRequest approvalDetailsRequest){
    
    string filter ="$filter=";
    string filterCondition = "";
    string andValue = "%20and%20";
    string quoteValue = "'";
    ApprovalDetailsRequestInfo approvalDetailsRequestInfo = approvalDetailsRequest.requestInfo;
    
    if(null != approvalDetailsRequestInfo){
    if(!isEmpty(approvalDetailsRequestInfo.billingAccountNumber))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "billingAccountNumber%20eq%20" + quoteValue + approvalDetailsRequestInfo.billingAccountNumber + quoteValue;
      
    if(!isEmpty(approvalDetailsRequestInfo.approverCUID))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "approverCUID%20eq%20" + quoteValue + approvalDetailsRequestInfo.approverCUID + quoteValue;
    
    if(!isEmpty(approvalDetailsRequestInfo.currentApproverCUID))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "currentApproverCUID%20eq%20" + quoteValue + approvalDetailsRequestInfo.currentApproverCUID + quoteValue;
      
    if(!isEmpty(approvalDetailsRequestInfo.createDateFrom))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "createDateFrom%20eq%20" + quoteValue + approvalDetailsRequestInfo.createDateFrom + quoteValue;
    
    if(!isEmpty(approvalDetailsRequestInfo.createDateTo))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "createDateTo%20eq%20" + quoteValue + approvalDetailsRequestInfo.createDateTo + quoteValue;
      
    if(!isEmpty(approvalDetailsRequestInfo.initiatorCUID))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "initiatorCUID%20eq%20" + quoteValue + approvalDetailsRequestInfo.initiatorCUID + quoteValue;
      
    if(!isEmpty(approvalDetailsRequestInfo.requestId))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "requestId%20eq%20" + quoteValue +approvalDetailsRequestInfo.requestId + quoteValue;
      
    if(!isEmpty(approvalDetailsRequestInfo.requestStatus))
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "requestStatus%20eq%20" + quoteValue + approvalDetailsRequestInfo.requestStatus + quoteValue;
    
    if(!isEmpty(approvalDetailsRequestInfo.requestType)){
        
        string requestTypeId = "";
        if(strEqualsIgnoreCase("Invoice level Adjustment", approvalDetailsRequestInfo.requestType))
           requestTypeId = "WS90300019";
        else if(strEqualsIgnoreCase("Account level Adjustment", approvalDetailsRequestInfo.requestType))
           requestTypeId = "WS90300012";
        else if(strEqualsIgnoreCase("Refund", approvalDetailsRequestInfo.requestType))
          requestTypeId = "WS90300008";
        else if(strEqualsIgnoreCase("Write-Off", approvalDetailsRequestInfo.requestType))
           requestTypeId = "WS90300003";
        else if(strEqualsIgnoreCase("LPC Adjustment", approvalDetailsRequestInfo.requestType))
           requestTypeId = "WS90300LPC";
           
      filterCondition = filterCondition + (isEmpty(filterCondition) ? "" : andValue) + "requestType%20eq%20"+ quoteValue +requestTypeId + quoteValue;
    }
    }
    
    log.info("Value of filter condition : "+filterCondition);
    
    if(isEmpty(filterCondition))
      return "";
      
    
    filter = filter + filterCondition + "&$expand=IP_RSLT_NAV/RSLT_APPR_NAV&$format=json";
    log.info("Value of filter  : "+filter);
   return filter;
    
}


TaxOnlyReportResponse validateTaxOnlyReportRequest(TaxOnlyReportRequest taxOnlyReportRequest, string resourceCode){
    
    
    
     TaxOnlyReportResponse taxOnlyReportResponse = udrCreate(TaxOnlyReportResponse);
     TaxOnlyReportResponseInfo taxOnlyReportResponseInfo = udrCreate(TaxOnlyReportResponseInfo);
     ErrorInfo errorInfo = udrCreate(ErrorInfo);
     
    HeaderInfo headerInfo = udrCreate(HeaderInfo);
    headerInfo = taxOnlyReportRequest.headerInfo;
    TaxOnlyReportRequestInfo taxOnlyReportRequestInfo = udrCreate(TaxOnlyReportRequestInfo);
    taxOnlyReportRequestInfo = taxOnlyReportRequest.requestInfo;
    
     
     date invDate;
    if(taxOnlyReportRequestInfo == null)
    {
		errorInfo = buildError(resourceCode , "requestInfo is required");
    }
    else if(isEmpty(taxOnlyReportRequestInfo.billingApplicationCd) || isEmpty(taxOnlyReportRequestInfo.billingAccountNumber))
    {
        errorInfo = buildError(resourceCode , "Both billingApplicationCd and billingAccountNumber are required");
    }else if(!isEmpty(taxOnlyReportRequestInfo.billingApplicationCd) &&
     (strEqualsIgnoreCase(taxOnlyReportRequestInfo.billingApplicationCd,"LATIS") ||strEqualsIgnoreCase(taxOnlyReportRequestInfo.billingApplicationCd,"KENAN"))){
         
         errorInfo = buildError(resourceCode ,  taxOnlyReportRequestInfo.billingApplicationCd+ " is not supported.");
         
     }else if(null == taxOnlyReportRequestInfo.invoiceDates || listSize(taxOnlyReportRequestInfo.invoiceDates) <=0){
        errorInfo = buildError(resourceCode , "invoiceDates are empty. Please input the dates in YYYY-MM-DD"); 
    }
    
    if(null != taxOnlyReportRequestInfo.invoiceDates && listSize(taxOnlyReportRequestInfo.invoiceDates) >0){
    for(string invoiceDate : taxOnlyReportRequestInfo.invoiceDates){
          if(!isValidDate(invoiceDate, invDate)){
              errorInfo = buildError(resourceCode , "invoiceDate format is invalid. Please input the date in YYYY-MM-DD");
              break;
              }   
          }  
    }
    
    if(errorInfo != null && !isEmpty(errorInfo.errorCd)){
        
        
        taxOnlyReportResponse.requestInfo = taxOnlyReportRequest.requestInfo;
        taxOnlyReportResponse.headerInfo = taxOnlyReportRequest.headerInfo;
        
        taxOnlyReportResponseInfo.errorInfo = errorInfo;
        taxOnlyReportResponseInfo.transactionStatus ="F";
        
         taxOnlyReportResponse.responseInfo = taxOnlyReportResponseInfo;
         debug("returning response after validation : "+taxOnlyReportResponse);
          log.info("returning response after validation : "+taxOnlyReportResponse);
         return taxOnlyReportResponse;
    }
   
    return null;
}

