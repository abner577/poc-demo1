        errUdr.errorMessage =  "Please Input Valid Code[CCD,CDD,CBK]";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    }
    if(mapGet(mapReqInfo,"fromDate") != null && mapGet(mapReqInfo,"fromDate") != ""){
        date dfromDate;
        strToDate(dfromDate,mapGet(mapReqInfo,"fromDate"),"yyyy-MM-dd");
        if(dfromDate == null){
            CreateReturnAgency_responseInfo responseUdr = udrCreate(CreateReturnAgency_responseInfo);
            ErrorInfo  errUdr = udrCreate(ErrorInfo);
            errUdr.errorCd = resourceCode+CM_DATA_VALIDATION_ERROR_CODE;
            errUdr.errorMessage =  "fromDate Format is Invalid, Please Input[yyyy-MM-dd]";
            responseUdr.errorInfo = errUdr;
            responseUdr.transactionStatus = "F";
            respUdr.responseInfo = responseUdr;
        }
    }
    if(mapGet(mapReqInfo,"toDate") != null && mapGet(mapReqInfo,"toDate") != ""){
        date dtoDate;
        strToDate(dtoDate,mapGet(mapReqInfo,"toDate"),"yyyy-MM-dd");
        if(dtoDate == null){
            CreateReturnAgency_responseInfo responseUdr = udrCreate(CreateReturnAgency_responseInfo);
            ErrorInfo  errUdr = udrCreate(ErrorInfo);
            errUdr.errorCd = resourceCode+CM_DATA_VALIDATION_ERROR_CODE;
            errUdr.errorMessage =  "toDate Format is Invalid, Please Input[yyyy-MM-dd]";
            responseUdr.errorInfo = errUdr;
            responseUdr.transactionStatus = "F";
            respUdr.responseInfo = responseUdr;
        }
    }
    
    if(mapGet(mapReqInfo,"dateOfDeath") != null && mapGet(mapReqInfo,"dateOfDeath") != ""){
        date ddeathDate;
        strToDate(ddeathDate,mapGet(mapReqInfo,"dateOfDeath"),"yyyy-MM-dd");
        if(ddeathDate == null){
            CreateReturnAgency_responseInfo responseUdr = udrCreate(CreateReturnAgency_responseInfo);
            ErrorInfo  errUdr = udrCreate(ErrorInfo);
            errUdr.errorCd = resourceCode+CM_DATA_VALIDATION_ERROR_CODE;
            errUdr.errorMessage =  "dateOfDeath Format is Invalid, Please Input[yyyy-MM-dd]";
            responseUdr.errorInfo = errUdr;
            responseUdr.transactionStatus = "F";
            respUdr.responseInfo = responseUdr;
        }
    }
    respUdr.requestInfo = reqUdr.requestInfo;
    respUdr.headerInfo = reqUdr.headerInfo;
    return respUdr;
}


