ErrorInfo buildError(string resourceCode, string message) {
    ErrorInfo err = udrCreate(ErrorInfo);
    err.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
    err.errorMessage = message;
    return err;
}
boolean isValidDate(string dateStr, date parsedDate) {
    if (isEmpty(dateStr)) return false;
    strToDate(parsedDate, dateStr, "yyyy-MM-dd");
    return parsedDate != null && strREMatches(dateStr, "\\d{4}-\\d{2}-\\d{2}");
}
SurchargeDetailsResponse validateSurchargeDetailsRequest(SurchargeDetailsRequest surchargeDetailsRequest, string resourceCode){
    
    SurchargeDetailsResponse surchargeDetailsResponse = udrCreate(SurchargeDetailsResponse);
    SurchargeDetailsRequestInfo surchargeDetailsRequestInfo = surchargeDetailsRequest.requestInfo;
    HeaderInfo headerInfo = surchargeDetailsRequest.headerInfo;
    
    SurchargeDetailsResponseInfo surchargeDetailsResponseInfo = udrCreate(SurchargeDetailsResponseInfo);
    
    ErrorInfo errorInfo = udrCreate(ErrorInfo);
    if(null == headerInfo || null == surchargeDetailsRequestInfo){
        errorInfo = buildError(resourceCode , "Both headerInfo and requestInfo are required");
    }else if(null != surchargeDetailsRequestInfo && (null ==surchargeDetailsRequestInfo.zipCode || isEmpty(surchargeDetailsRequestInfo.zipCode))){
         errorInfo = buildError(resourceCode , "zipCode,billingAccountNumber and currencyCd are required");
    }else if(null != surchargeDetailsRequestInfo && (null ==surchargeDetailsRequestInfo.billingAccountNumber || isEmpty(surchargeDetailsRequestInfo.billingAccountNumber))){
         errorInfo = buildError(resourceCode , "zipCode,billingAccountNumber and currencyCd are required");
    }else if(null != surchargeDetailsRequestInfo && (null == surchargeDetailsRequestInfo.currencyCd || isEmpty(surchargeDetailsRequestInfo.currencyCd))){
         errorInfo = buildError(resourceCode , "zipCode,billingAccountNumber and currencyCd are required");
    }
    if(errorInfo != null && !isEmpty(errorInfo.errorCd)){
        
        surchargeDetailsResponse.requestInfo = surchargeDetailsRequestInfo;
        surchargeDetailsResponse.headerInfo = headerInfo;
        
        surchargeDetailsResponseInfo.transactionStatus ="F";
        surchargeDetailsResponseInfo.errorInfo = errorInfo;
        
        surchargeDetailsResponse.responseInfo = surchargeDetailsResponseInfo;
        
    }
    return surchargeDetailsResponse;
    
