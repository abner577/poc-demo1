         errorInfo.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errorInfo.errorMessage ="fromCurrencyCd , toCurrencyCd and amount are required.";
    }
    
    if(!isEmpty(currencyConversionRequestInfo.conversionDate)){
    date conversionDate;
    strToDate(conversionDate,currencyConversionRequestInfo.conversionDate,"yyyy-MM-dd");
    debug("conversionDate: "+conversionDate);
    if(null ==conversionDate || !strREMatches(currencyConversionRequestInfo.conversionDate,"\\d{4}-\\d{2}-\\d{2}")){
