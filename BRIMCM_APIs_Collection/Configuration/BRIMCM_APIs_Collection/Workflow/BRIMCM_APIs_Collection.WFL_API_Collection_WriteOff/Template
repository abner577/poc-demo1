                //openapi.BRIMCM_APIs.PRF_CMAPIs.WriteoffReverseReq writeOffReverseReq = udrCreate(openapi.BRIMCM_APIs.PRF_CMAPIs.WriteoffReverseReq);
                WriteOffReversalRequest writeOffReverseReq = udrCreate(WriteOffReversalRequest);
                jsonDecodeUdr(sBody,writeOffReverseReq);           

                writeOffReverseResp.requestInfo = writeOffReverseReq.requestInfo;
                writeOffReverseResp.headerInfo = writeOffReverseReq.headerInfo;            
                
                httpUDR.response.statusCode = input.responseUdr.statusCode;
                debug("writeOffReverseResp : "+writeOffReverseResp);
                udrRoute(httpUDR,"toClient");
                 ConsumeCycleUDR splunkOdataUdr = sendToSplunk(orginalRestUDR,httpUDR,ODATA_RESPONSE,status,httpUDR.path,splunkCtx);
                 udrRoute(splunkOdataUdr,"toSplunk"); 
                 ConsumeCycleUDR ccApiUdr = sendToSplunk(httpUDR,null,API_RESPONSE,status,null,splunkCtx);
                 udrRoute(ccApiUdr,"toSplunk");               
