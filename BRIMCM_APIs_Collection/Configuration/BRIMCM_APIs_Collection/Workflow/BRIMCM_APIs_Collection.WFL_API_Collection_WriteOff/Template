                         }
                    }
                }catch (ExceptionDetails exception) {
                    debug("Exception occured while CDW DATA FETCHING Process:: " + exception);
                    session.isCDWDB_ResponseReceieved = true;
                    if(!session.fetchDataFromBRIM){
                        debug("Inside if condition of catch block for CDW exception");
                        session.responseDescription = "Exception Occured in CM...";
