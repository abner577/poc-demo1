                            errorInfo.errorMessage = DocMsg;
                            errorInfo.errorCd = resourceCode + BRIM_ERROR;     
                            writeOffReverseResp.responseInfo.errorInfo = errorInfo;
                            status = API_STATUS_FAILURE;
                        }
                        else{
                            writeOffReverseResp.responseInfo.transactionStatus = "S";
                            status = API_STATUS_SUCCESS;                            
                        //listAdd(writeOffReverseResp.responseInfo.customerInfo, documentResponse); 
                //} 
                        }
                                     
            }
            else {
                debug("Response is null");
            }
            
            //if(session.iCount == 0) {
