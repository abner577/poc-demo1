                        processWriteOffHistory(cdwWriteOffHistoryView,listDetails);
                        if(!session.fetchDataFromBRIM){
                            debug("Inside if condition of cdwWriteOffHistoryView not null condition");
                            respInfo.writeOffDetails = listDetails;
