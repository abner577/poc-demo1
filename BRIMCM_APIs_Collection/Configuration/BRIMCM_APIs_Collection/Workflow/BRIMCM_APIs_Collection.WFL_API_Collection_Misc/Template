// Helper function to extract request body
string getRequestBody(RequestCycle inputRequest) {
    debug("inputRequest.body : "+inputRequest.body);
    if(inputRequest.body != null) {
        return baToStr(inputRequest.body, "UTF-8");
    }
    return "";
}

void callOdataForSurcharge(RequestCycle cycleUdr, string stateCode, string currencyCode, string billingAccountNumber, string inputChannelCode){
    string surchargeOdataUri = "/sap/opu/odata/SAP/ZGLB_DEVFICA_RTPSRCHRG_CONVFEE_SRV/SurgConvSet";
    string surchargeOdataFilter = "?$filter=BAN%20eq%20'"+billingAccountNumber+"'%20and%20InputChannel%20eq%20'"
                                   +inputChannelCode+"'%20and%20State%20eq%20'"+stateCode+"'%20and%20Currency%20eq%20'"
                                   +currencyCode+"'&$format=json";
    
    if(isEmpty(stateCode))
      surchargeOdataFilter = "?$filter=BAN%20eq%20'"+billingAccountNumber+"'%20and%20InputChannel%20eq%20'"
                              +inputChannelCode+"'%20and%20Currency%20eq%20'"+currencyCode+"'&$format=json";
    
    string surchargeOdataUrl = surchargeOdataUri + surchargeOdataFilter;
    http.RequestCycle reqUDR = accessTokenReq(surchargeOdataUrl);   
    reqUDR.context = cycleUdr; 
    udrRoute(reqUDR,"toS4");   
     //Forwarding log request to Splunk
    udrRoute(sendToSplunk(cycleUdr,reqUDR,ODATA_REQUEST, "",reqUDR.path,splunkCtx),"toSplunk");
    
}



// Helper function to build error response
SurchargeDetailsResponse buildErrorResponse(SurchargeDetailsRequest request, string resCode, string errMsg) {
    SurchargeDetailsResponse response = udrCreate(SurchargeDetailsResponse);
    response.headerInfo = request.headerInfo;
    response.requestInfo = request.requestInfo;
    
    SurchargeDetailsResponseInfo responseInfo = udrCreate(SurchargeDetailsResponseInfo);
    ErrorInfo errorInfo = udrCreate(ErrorInfo);
    errorInfo = buildError(resCode, errMsg);
    
    responseInfo.transactionStatus = "F";
    responseInfo.errorInfo = errorInfo;
    response.responseInfo = responseInfo;
    
    return response;
}

// Helper function to determine state code from jurisdiction
string determineStateCode(string jurisdictionCode) {
    string sGeoCd = "";
    string stateCode = "";
    
    if(strLength(jurisdictionCode) >= 2) {
        sGeoCd = strSubstring(jurisdictionCode, 0, 2);
        debug("Extracted geo code: " + sGeoCd);
    } else {
        log.warn("Jurisdiction code too short: " + jurisdictionCode);
        return "";
    }
    
    if(isEmpty(sGeoCd)) {
        return "";
    }
    
    int iGeoCd;
    strToInt(iGeoCd, sGeoCd);
    
    if(sGeoCd == "13") {
        string tempStateCode = Common.APL_COMMON.getStateCodeUsingStateInp(jurisdictionCode, "-");
        stateCode = (!isEmpty(tempStateCode)) ? tempStateCode : "ID";
        debug("Geo code 13 - State code: " + stateCode);
    } else if(iGeoCd > 0 && iGeoCd <= 51) {
        stateCode = Common.APL_COMMON.getStateCodeUsingStateInp(sGeoCd, "-");
        debug("Geo code " + iGeoCd + " (state range) - State code: " + stateCode);
    } else if(iGeoCd >= 52 && iGeoCd <= 79) {
        stateCode = Common.APL_COMMON.getStateCodeUsingCountryInp(sGeoCd, "-");
        debug("Geo code " + iGeoCd + " (country range) - State code: " + stateCode);
    } else {
        log.warn("Geo code out of range: " + iGeoCd);
    }
    
    return stateCode;
}

// Helper function to calculate surcharge percentage
double calculateSurchargePercent(string stateCode, SurchargeDetailsRequest surchargeDetailsRequest) {
    
    //string surchargeDetailsUrl = "/sap/opu/odata/SAP/ZGLB_DEVFICA_RTPSRCHRG_CONVFEE_SRV/SurgConvSet?filter=BAN";
    double surchargePercent;
    if(isEmpty(stateCode)) {
        log.warn("Empty state code, applying default surcharge: 2.26%");
        return 2.26;
    }
    
    if(strEqualsIgnoreCase(stateCode, "CO")) {
        debug("Colorado rate applied: 2.00%");
        return 2.00;
    } else if(strEqualsIgnoreCase(stateCode, "CT") || 
              strEqualsIgnoreCase(stateCode, "MA") || 
              strEqualsIgnoreCase(stateCode, "PR")) {
        debug("No surcharge state: " + stateCode);
        return 0.00;
    } else {
        debug("Standard surcharge applied: 2.26%");
        strToDouble(surchargePercent, Common.APL_RoundingFunctions.roundUpBigDecValue("2.26",2));
        return surchargePercent;
    }
}

// Helper function to build success response
SurchargeDetailsResponse buildSuccessResponse(
    SurchargeDetailsRequest request,
    SurchargeDetailsRequestInfo requestInfo,
    string stateCode,
    double surchargePercent,map<string,any> mapSurchargeDetailsRequest
) {
    SurchargeDetailsResponse response = udrCreate(SurchargeDetailsResponse);
    response.headerInfo = request.headerInfo;
    response.requestInfo = request.requestInfo;
    
    SurchargeDetailsResponseInfo responseInfo = udrCreate(SurchargeDetailsResponseInfo);
    responseInfo.surchargePercent = surchargePercent;
    responseInfo.stateCode = stateCode;
    
   map<string,string> mapSurchargeReqInfo = (map<string,string>)mapGet(mapSurchargeDetailsRequest,"requestInfo");
   
    if(mapGet(mapSurchargeReqInfo,"amount") != null && requestInfo.amount > 0) {
        double surchargeAmount ;
       string surchargeAmountString = (string)(requestInfo.amount * (surchargePercent / 100));
        
        
        strToDouble(surchargeAmount, Common.APL_RoundingFunctions.roundUpBigDecValue(surchargeAmountString,2));
        double totalAmount;
        string totalAmountString = (string)(requestInfo.amount + surchargeAmount);
         strToDouble(totalAmount, Common.APL_RoundingFunctions.roundUpBigDecValue(totalAmountString,2));
        responseInfo.surchargeAmount = surchargeAmount;
        responseInfo.totalAmount = totalAmount;
        responseInfo.amount = requestInfo.amount;
        debug("Calculation - Amount: " + requestInfo.amount + ", Surcharge: " + surchargeAmount + ", Total: " + totalAmount);
    }
    
    responseInfo.transactionStatus = "S";
    response.responseInfo = responseInfo;
    debug("Response : "+response);
    return response;
}

