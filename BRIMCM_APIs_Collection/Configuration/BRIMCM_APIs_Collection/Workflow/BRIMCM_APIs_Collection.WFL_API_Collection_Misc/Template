                SurchargeDetailsRequest surchargeDetailsRequest = udrCreate(SurchargeDetailsRequest);
                jsonDecodeUdr(inputRequestBody, surchargeDetailsRequest);
        
                SurchargeDetailsResponse errorResponse = buildErrorResponse(
                surchargeDetailsRequest, 
                resourceCode, 
                !isEmpty(errorMessage) ? errorMessage : "An internal error occurred while processing the request."
                );
                sendResponse(inputRequest, errorResponse, 200);
                udrRoute(sendRfcToSplunk(inputRequest,(string)udr.exportParams,RFC_RESPONSE,API_STATUS_FAILURE,"ZFICAF_DETERMINE_JURISDICTION_UDR",splunkCtx),"toSplunk");
                return;
        }
    
