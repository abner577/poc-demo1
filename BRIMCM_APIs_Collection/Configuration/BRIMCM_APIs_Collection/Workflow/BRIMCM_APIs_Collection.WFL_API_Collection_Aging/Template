void convertAndAddAmount(map<any,any> objMap, string key, bigdec existingValue, bigdec newValue){
    if (null != mapGet(objMap, key)) {
        strToBigDec(newValue, (string)mapGet(objMap, key));
        existingValue = existingValue + (double)newValue;
    }
}

// Fetches total dispute amount from the dispute ODATA API using billingAccountNumber (LegacyContractAccount)
// Fetches total dispute amount from the new dispute OData API using raw request inputs.
// Inputs: zzitban (BAN), zzitbusorg (busOrgId), zzimubusorg (ultimateBusOrgId), zzimcuid (collectorUserId).
// Only non-empty inputs are included in the OData $filter.
bigdec fetchDisputeAmount(string ban, string busOrgId, string ultimateBusOrgId, string collectorUserId, string tagId) {
    bigdec totalDisputeAmount = 0;
    string inputsLog = "ban=" + ban + ", busOrgId=" + busOrgId
                     + ", ultimateBusOrgId=" + ultimateBusOrgId + ", collectorUserId=" + collectorUserId;
    try {
        string clientId = getSystemValue(SAP_CLIENT);

        // Build OData $filter from non-empty inputs
        string filterStr = "";
        if (!isEmpty(ban)) {
            filterStr = "zzitban%20eq%20%27" + ban + "%27";
        }
        if (!isEmpty(busOrgId)) {
            if (!isEmpty(filterStr)) filterStr = filterStr + "%20and%20";
            filterStr = filterStr + "zzitbusorg%20eq%20%27" + busOrgId + "%27";
        }
        if (!isEmpty(ultimateBusOrgId)) {
            if (!isEmpty(filterStr)) filterStr = filterStr + "%20and%20";
            filterStr = filterStr + "zzimubusorg%20eq%20%27" + ultimateBusOrgId + "%27";
        }
        if (!isEmpty(collectorUserId)) {
            if (!isEmpty(filterStr)) filterStr = filterStr + "%20and%20";
            filterStr = filterStr + "zzimcuid%20eq%20%27" + collectorUserId + "%27";
        }

        string uri = "/sap/opu/odata/SAP/ZGLB_DEVFICA_OPCON_DISPUTEAMT_SRV/OpconsoleDisputeAmountSet"
                   + "?%24format=json&sap-client=" + clientId;
        if (!isEmpty(filterStr)) {
            uri = uri + "&%24filter=" + filterStr;
        }

        map<string, string> header = mapCreate(string, string);
        mapSet(header, "Accept", "application/json");
        mapSet(header, "Content-Type", "application/json");

        string host = getSystemValue(REST_HOSTNAME);
        string port = getSystemValue(REST_PORT);
        int iport;
        strToInt(iport, port);

        string username          = externalReferenceGet("Common.DB_External_Reference", "BRIM_REST_USER");
        string password          = externalReferenceGet("Common.DB_External_Reference", "BRIM_REST_PASSWORD");
        string decryptedPassword = decryptMZEncryptedString(password);

        debug("Fetching dispute amount — " + inputsLog + " URI: " + uri);

        // LOG: Dispute API request
        string reqLogLine = "[tagId=" + tagId + "] {transactionType=REQUEST,"
                          + " transactionApi=ZGLB_DEVFICA_OPCON_DISPUTEAMT_SRV/OpconsoleDisputeAmountSet,"
                          + " src=BRIMCM, dst=S4, " + inputsLog + "} DISPUTE_REQUEST: " + uri;
        log.info(reqLogLine, tagId);

        http.Response responseUdr = httpReq("GET", host, uri, null, "application/json", "HTTP/1", iport, true, 40000, 40000, username, decryptedPassword, header);

        if (responseUdr.statusCode == 200 || responseUdr.statusCode == 201) {
            string sBody = baToStr((bytearray) responseUdr.body);
            debug("Dispute API response: " + sBody);

            // LOG: Dispute API success response
            string respLogLine = "[tagId=" + tagId + "] {transactionType=RESPONSE,"
                               + " transactionApi=ZGLB_DEVFICA_OPCON_DISPUTEAMT_SRV/OpconsoleDisputeAmountSet,"
                               + " src=S4, dst=BRIMCM, statusCode=" + responseUdr.statusCode + ", status=SUCCESS, " + inputsLog + "}"
                               + " DISPUTE_RESPONSE: " + strREReplaceAll(sBody, "[\n\r\\s]+", " ");
            log.info(respLogLine, tagId);

            JsonObject json    = (JsonObject) jsonDecode(sBody);
            JsonObject d       = (JsonObject) mapGet(json.asMap, "d");
            JsonArray  results = (JsonArray)  mapGet(d.asMap, "results");

            if (results != null) {
                for (any result : results.asList) {
                    JsonObject obj       = (JsonObject) result;
                    string disputeAmtStr = (string) mapGet(obj.asMap, "DisputeAmount");
                    if (!isEmpty(disputeAmtStr)) {
                        bigdec amt = 0;
                        strToBigDec(amt, disputeAmtStr);
                        totalDisputeAmount = totalDisputeAmount + amt;
                    }
                }
            }
            debug("Total dispute amount [" + inputsLog + "]: " + totalDisputeAmount);
        } else {
            string sBody = responseUdr.body != null ? baToStr((bytearray) responseUdr.body) : "No response body";
            debug("Dispute API returned non-200 status: " + responseUdr.statusCode + " [" + inputsLog + "]");

            // LOG: Dispute API error response
            string errLogLine = "[tagId=" + tagId + "] {transactionType=RESPONSE,"
                              + " transactionApi=ZGLB_DEVFICA_OPCON_DISPUTEAMT_SRV/OpconsoleDisputeAmountSet,"
                              + " src=S4, dst=BRIMCM, statusCode=" + responseUdr.statusCode + ", status=FAILURE, " + inputsLog + "}"
                              + " DISPUTE_RESPONSE: " + strREReplaceAll(sBody, "[\n\r\\s]+", " ");
            log.info(errLogLine, tagId);
        }
    } catch (ExceptionDetails e) {
        debug("Failed to fetch dispute amount [" + inputsLog + "] error: " + e.message);

        // LOG: Dispute API exception
        string exLogLine = "[tagId=" + tagId + "] {transactionType=RESPONSE,"
                         + " transactionApi=ZGLB_DEVFICA_OPCON_DISPUTEAMT_SRV/OpconsoleDisputeAmountSet,"
                         + " src=S4, dst=BRIMCM, status=FAILURE, " + inputsLog + "} DISPUTE_RESPONSE: " + e.message;
        log.info(exLogLine, tagId);
    }
    return totalDisputeAmount;
}

string dateConversionFromEPOCToNormal(string epocDate){
   long lMilliSec;
   //debug ("epocDate = " + epocDate);
   if (epocDate != null && epocDate != ""){
       string eDateInMilliSec = strSubstring(epocDate, 6, strLength(epocDate)-2 );
       //debug ("eDateInMilliSec: "+ eDateInMilliSec);
       strToLong(lMilliSec, eDateInMilliSec);
       string sFormattedDate = strSubstring((string)dateCreateFromMilliseconds(lMilliSec), 0, 10); 
       //debug ("sFormattedDate: "+ sFormattedDate);
       return sFormattedDate;
    }
    else{
        return null;
    }
}
map<string,list<string>> getHeader(){
    map<string,list<string> > mapToken = mapCreate(string,list<string>);
    list<string> lContentType = listCreate(string);
    listAdd(lContentType,"application/json");
    mapSet(mapToken,"Content-Type",lContentType) ;
    return (mapToken);
}
/*
[Yesterday 8:52 AM] Anbarasan, Rajesh
Case 1: when input collector id is invalid then "Invalid Collector ID"
Case 2: Input Collector ID and Ultibusorg either of the value is invalid then "Given Collector id or ultibusorg is invalid"
Case 3: Input collector id and busorgid if either of the value is invalid then "Given Collector id or busorgid is invalid"
Case 4: Input Busorg id, if its inavlid then "Invalid Busorgid"
Case 5: Input ultibusorgid, inavlid input then "Invalid ultibusorgid"
Case 6 : Invalid BAN as input then "Inavlid BAN"
*/
string getErrorMessage(AgingBucketDetailsRequestInfo requestInfo) {
    string  filter = "";
    // only Collector update 
    if(isEmpty(requestInfo.collectorUserId) && 
       isEmpty(requestInfo.ultimateBusOrgId) && 
       isEmpty(requestInfo.busOrgId) && 
       isEmpty(requestInfo.billingAccountNumber)) {
       filter = "Atleast one attribute is needed (Collector / Ulti BusOrg / BusOrg / Billing Account Number )";

       }else{
           filter ="No Aging Data found for the given Input.";
       }
    return filter;     
}

AgingBucketDetailsResponse createAgingBucketErrorResponseAging(AgingBucketDetailsRequest req, string sErrorCode, string sErrorMsg, string sReqBody){
	AgingBucketDetailsResponse resp = udrCreate(AgingBucketDetailsResponse);
    AgingBucketDetailsResponseInfo responseInfo = udrCreate(AgingBucketDetailsResponseInfo);
    
    resp.headerInfo = req.headerInfo;
    resp.requestInfo = req.requestInfo;
    ErrorInfo errInfo = udrCreate(ErrorInfo);
    errInfo.errorMessage = sErrorMsg;
    errInfo.errorCd = sErrorCode;
    responseInfo.errorInfo = errInfo;
    responseInfo.transactionStatus =  "F";
    resp.responseInfo = responseInfo;
    return resp;  
}


void handleOdataAgingResponse(RequestCycle cycle) {
    debug("In OData Aging Response Handler");

    int statusCode            = cycle.response.statusCode;
    RequestCycle origReq      = (RequestCycle) cycle.context;
    AgingBucketDetailsRequest agingReq = udrCreate(AgingBucketDetailsRequest);
    jsonDecodeUdr(baToStr(origReq.body), agingReq);
    string resourceCode       = getXrefValue(RESOURCE_CODE_TABLE, origReq.path);
    string sBody              = baToStr((bytearray) cycle.response.body);

    debug("ODATA Status Code: " + (string)statusCode);
    debug("ODATA Response: " + cycle);
    // LOG: ODATA response received
    string isOk = (statusCode == 200 || statusCode == 201) ? "SUCCESS" : "FAILURE";
    udrRoute(sendToSplunk(origReq, cycle, ODATA_RESPONSE, isOk, cycle.path, splunkCtx), "toSplunk");

    // Parse response JSON
    JsonObject json              = udrCreate(JsonObject);
    map<string, any> responseMap = mapCreate(string, any);

    if(instanceOf(jsonDecode(sBody), JsonObject)) {
        json        = (JsonObject) jsonDecode(sBody);
        responseMap = json.asMap;
    }

    // Check for timeout
    if(cycle.response.body != null) {
        if(strREContains(sBody, "Total timeout 30000 ms elapsed")) {
            debug("ODATA Timeout");
            sendAgingErrorResponse(agingReq, origReq, "Request timed out", resourceCode + BRIM_ERROR);
            return;
        }
    }

    // Handle error status codes
    if(!(statusCode == 200 || statusCode == 201)) {
        debug("ODATA Error - Status: " + (string)statusCode);
        string errMsg = "Failure in ODATA call";

        if(instanceOf(mapGet(responseMap, "error"), JsonObject)) {
            json        = (JsonObject) mapGet(responseMap, "error");
            responseMap = json.asMap;
            if(instanceOf(mapGet(responseMap, "message"), JsonObject)) {
                json        = (JsonObject) mapGet(responseMap, "message");
                responseMap = json.asMap;
                errMsg      = (string) mapGet(responseMap, "value");
            }
        } else {
            int index3 = strREIndexOf(sBody, "<message");
            int index4 = strREIndexOf(sBody, "</message>");
            if(index3 != -1 && index4 != -1) {
                errMsg = strSubstring(sBody, index3 + 9, index4);
            }
        }
        sendAgingErrorResponse(agingReq, origReq, errMsg, resourceCode + BRIM_ERROR);
        return;
    }

    // Handle empty response
    if(isEmpty(sBody)) {
        sendAgingErrorResponse(agingReq, origReq, "No record found", resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
        return;
    }

    // =============================================
    // SUCCESS - Parse and map ODATA response
    // =============================================
    json        = (JsonObject) mapGet(responseMap, "d");
    responseMap = json.asMap;
    JsonArray ja = (JsonArray) mapGet(responseMap, "results");

    if(ja == null) {
        sendAgingErrorResponse(agingReq, origReq, "No record found", resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
        return;
    }

    list<any> listResult = ja.asList;

    // Extract inner TRAN_HIST_NAV results with exclusion filtering
    list<any> innerList = listCreate(any);
    for(any result : listResult) {
        json        = (JsonObject) result;
        responseMap = json.asMap;
        JsonObject navObj = (JsonObject) mapGet(responseMap, "TRAN_HIST_NAV");
        if(navObj != null) {
            responseMap  = navObj.asMap;
            JsonArray jaNav = (JsonArray) mapGet(responseMap, "results");
          
            if(jaNav != null) {
                list<any> navList = jaNav.asList;
                  debug("TRAN_HIST_NAV results count: " + listSize(navList));
                for(any navItem : navList) {
                    map<string, any> navMap = ((JsonObject) navItem).asMap;
                    debug("NAV item keys: " + mapKeys(navMap));
                    debug("NAV amount=" + mapGet(navMap, "amount") + " | Amount=" + mapGet(navMap, "Amount") + " | invoiceDueDate=" + mapGet(navMap, "invoiceDueDate") + " | DueDate=" + mapGet(navMap, "DueDate") + " | documentType=" + mapGet(navMap, "documentType") + " | DocumentType=" + mapGet(navMap, "DocumentType"));

                    string docType  = "";
                    string docNotes = "";

                    if(mapGet(navMap, "DocumentType") != null) {
                        docType = (string) mapGet(navMap, "DocumentType");
                    }
                    if(mapGet(navMap, "DocumentNotes") != null) {
                        docNotes = (string) mapGet(navMap, "DocumentNotes");
                    }

                    // Exclude documentType 'MR' or 'SD'
                    if(docType == "SD") {
                        debug("Excluding transaction - DocumentType: " + docType);
                        continue;
                    }

                    // Exclude if documentNotes contains 'Security Deposit' (case-insensitive)
                    if(strREContains(strToUpper(docNotes), "SECURITY DEPOSIT")) {
                        debug("Excluding transaction - DocumentNotes contains Security Deposit: " + docNotes);
                        continue;
                    }

                    listAdd(innerList, navItem);
                }
            }
        }
    }

    // Calculate aging buckets
    AgingBucketDetailsGroupCurrency buckets = calculateAgingBuckets(innerList);

    // Fetch dispute amount from dedicated dispute API using raw request inputs
    buckets.disputeAmount = (double) fetchDisputeAmount(
        agingReq.requestInfo.billingAccountNumber,
        agingReq.requestInfo.busOrgId,
        agingReq.requestInfo.ultimateBusOrgId,
        agingReq.requestInfo.collectorUserId,
        getTagId(origReq));
    debug("Dispute amount set to: " + buckets.disputeAmount);

    // Build success response
    sendAgingSuccessResponse(agingReq, origReq, buckets);
}

// =============================================
// CALCULATE AGING BUCKETS
// =============================================
AgingBucketDetailsGroupCurrency calculateAgingBuckets(list<any> listResult) {
    AgingBucketDetailsGroupCurrency buckets = udrCreate(AgingBucketDetailsGroupCurrency);
    buckets.currencyCd            = "USD";
    buckets.currentDueAmount      = 0.0;
    buckets.pastDueAmount         = 0.0;
    buckets.totalDueAmount        = 0.0;
    buckets.disputeAmount         = 0.0;
    buckets.amountDue0To30Days    = 0.0;
    buckets.amountDue31To60Days   = 0.0;
    buckets.amountDue61To90Days   = 0.0;
    buckets.amountDue91To120Days  = 0.0;
    buckets.amountDue121To150Days = 0.0;
    buckets.amountDue151To180Days = 0.0;
    buckets.amountDue181To210Days = 0.0;
    buckets.amountDue211To240Days = 0.0;
    buckets.amountDue241To270Days = 0.0;
    buckets.amountDue271To300Days = 0.0;
    buckets.amountDue301To330Days = 0.0;
    buckets.amountDue331To360Days = 0.0;
    buckets.amountDue361PlusDays  = 0.0;

    date today = dateCreateNow();

    for(any value : listResult) {
        JsonObject json          = (JsonObject) value;
        map<string, any> responseMap = json.asMap;

        // Get Amount
        string amountStr = (string) mapGet(responseMap, "Amount");
        double amount    = 0.0;
       if(!isEmpty(amountStr)) {
            string roundedAmountStr = roundUpBigDecValue(amountStr, 2);
            strToDouble(amount, roundedAmountStr);
        }

        // Get Currency
        string currency = (string) mapGet(responseMap, "Currency");
        if(!isEmpty(currency)) {
            buckets.currencyCd = currency;
        }

        // Get DueDate and calculate days overdue
        string dueDateRaw = convertToHumanDate(mapGet(responseMap, "DueDate"));
        debug("dueDateRaw : "+dueDateRaw);
        long daysDiff      = 0;

        if(!isEmpty(dueDateRaw)) {
            date dueDate;
            boolean parsed = strToDate(dueDate, dueDateRaw, "yyyy-MM-dd");
            if(parsed && dueDate != null) {
                long diffMs = dateDiff(today, dueDate);
                daysDiff = diffMs / 86400000;
            }
        }
        debug("daysDiff : "+daysDiff);
        // Bucket assignment
        if(daysDiff <= 0) {
            buckets.currentDueAmount = buckets.currentDueAmount + amount;
        } else {
            buckets.pastDueAmount = buckets.pastDueAmount + amount;

            if(daysDiff >= 1 && daysDiff <= 30) {
                buckets.amountDue0To30Days = buckets.amountDue0To30Days + amount;
            } else if(daysDiff >= 31 && daysDiff <= 60) {
                buckets.amountDue31To60Days = buckets.amountDue31To60Days + amount;
            } else if(daysDiff >= 61 && daysDiff <= 90) {
                buckets.amountDue61To90Days = buckets.amountDue61To90Days + amount;
            } else if(daysDiff >= 91 && daysDiff <= 120) {
                buckets.amountDue91To120Days = buckets.amountDue91To120Days + amount;
            } else if(daysDiff >= 121 && daysDiff <= 150) {
                buckets.amountDue121To150Days = buckets.amountDue121To150Days + amount;
            } else if(daysDiff >= 151 && daysDiff <= 180) {
                buckets.amountDue151To180Days = buckets.amountDue151To180Days + amount;
            } else if(daysDiff >= 181 && daysDiff <= 210) {
                buckets.amountDue181To210Days = buckets.amountDue181To210Days + amount;
            } else if(daysDiff >= 211 && daysDiff <= 240) {
                buckets.amountDue211To240Days = buckets.amountDue211To240Days + amount;
            } else if(daysDiff >= 241 && daysDiff <= 270) {
                buckets.amountDue241To270Days = buckets.amountDue241To270Days + amount;
            } else if(daysDiff >= 271 && daysDiff <= 300) {
                buckets.amountDue271To300Days = buckets.amountDue271To300Days + amount;
            } else if(daysDiff >= 301 && daysDiff <= 330) {
                buckets.amountDue301To330Days = buckets.amountDue301To330Days + amount;
            } else if(daysDiff >= 331 && daysDiff <= 360) {
                buckets.amountDue331To360Days = buckets.amountDue331To360Days + amount;
            } else if(daysDiff > 360) {
                buckets.amountDue361PlusDays = buckets.amountDue361PlusDays + amount;
            }
        }
    }

    // Total = current + past
    buckets.totalDueAmount = buckets.currentDueAmount + buckets.pastDueAmount;
 strToDouble(buckets.currentDueAmount,      roundUpBigDecValue((string)buckets.currentDueAmount, 2));
    strToDouble(buckets.pastDueAmount,         roundUpBigDecValue((string)buckets.pastDueAmount, 2));
    strToDouble(buckets.totalDueAmount,        roundUpBigDecValue((string)buckets.totalDueAmount, 2));
    strToDouble(buckets.amountDue0To30Days,    roundUpBigDecValue((string)buckets.amountDue0To30Days, 2));
    strToDouble(buckets.amountDue31To60Days,   roundUpBigDecValue((string)buckets.amountDue31To60Days, 2));
    strToDouble(buckets.amountDue61To90Days,   roundUpBigDecValue((string)buckets.amountDue61To90Days, 2));
    strToDouble(buckets.amountDue91To120Days,  roundUpBigDecValue((string)buckets.amountDue91To120Days, 2));
    strToDouble(buckets.amountDue121To150Days, roundUpBigDecValue((string)buckets.amountDue121To150Days, 2));
    strToDouble(buckets.amountDue151To180Days, roundUpBigDecValue((string)buckets.amountDue151To180Days, 2));
    strToDouble(buckets.amountDue181To210Days, roundUpBigDecValue((string)buckets.amountDue181To210Days, 2));
    strToDouble(buckets.amountDue211To240Days, roundUpBigDecValue((string)buckets.amountDue211To240Days, 2));
    strToDouble(buckets.amountDue241To270Days, roundUpBigDecValue((string)buckets.amountDue241To270Days, 2));
    strToDouble(buckets.amountDue271To300Days, roundUpBigDecValue((string)buckets.amountDue271To300Days, 2));
    strToDouble(buckets.amountDue301To330Days, roundUpBigDecValue((string)buckets.amountDue301To330Days, 2));
    strToDouble(buckets.amountDue331To360Days, roundUpBigDecValue((string)buckets.amountDue331To360Days, 2));
    strToDouble(buckets.amountDue361PlusDays,  roundUpBigDecValue((string)buckets.amountDue361PlusDays, 2));



    debug("Aging Buckets: " + buckets);
    return buckets;
}

// =============================================
// SEND SUCCESS RESPONSE TO CLIENT
// =============================================
// =============================================
// SEND SUCCESS RESPONSE TO CLIENT (Updated)
// =============================================
void sendAgingSuccessResponse(AgingBucketDetailsRequest agingReq, RequestCycle origReq,
                               AgingBucketDetailsGroupCurrency buckets) {

    // Build response UDR
    AgingBucketDetailsResponse resp       = udrCreate(AgingBucketDetailsResponse);
    AgingBucketDetailsResponseInfo respInfo = udrCreate(AgingBucketDetailsResponseInfo);

    // Map headerInfo and requestInfo from original request
    resp.headerInfo  = agingReq.headerInfo;
    resp.requestInfo = agingReq.requestInfo;

    // Set transaction status
    respInfo.transactionStatus = "S";

    // Set report run date
    date now = dateCreateNow();
    string reportDate;
    dateToString(reportDate, now, "yyyy-MM-dd");
    respInfo.reportRunDate = reportDate;

    // Map aging bucket details
    list<AgingBucketDetail> agingBucketList = listCreate(AgingBucketDetail);
    AgingBucketDetail agingDetail           = udrCreate(AgingBucketDetail);

    // Set groupCurrency object
    agingDetail.groupCurrency = buckets;

    // Set additional fields
    agingDetail.billingAccountNumber = agingReq.requestInfo.billingAccountNumber;
    agingDetail.invoiceCurrencyCd    = buckets.currencyCd;

    listAdd(agingBucketList, agingDetail);
    respInfo.agingBucketDetails = agingBucketList;
    resp.responseInfo           = respInfo;

    // Encode and send
    string sResp = jsonEncodeUdr(resp);
    bytearray ba;
    strToBA(ba, sResp);

    Response respUdr   = udrCreate(Response);
    respUdr.body       = ba;
    respUdr.headers    = getHeader();
    respUdr.statusCode = 200;
    origReq.response   = respUdr;

    debug("Sending aging success response: " + sResp);

    udrRoute(sendToSplunk(origReq, null, API_RESPONSE, API_STATUS_SUCCESS, null, splunkCtx), "toSplunk");

    udrRoute(origReq, "toClient");
}

// =============================================
// SEND ERROR RESPONSE TO CLIENT
// =============================================
void sendAgingErrorResponse(AgingBucketDetailsRequest agingReq, RequestCycle origReq,
                             string errorMessage, string errorCode) {

    AgingBucketDetailsResponse resp       = udrCreate(AgingBucketDetailsResponse);
    AgingBucketDetailsResponseInfo respInfo = udrCreate(AgingBucketDetailsResponseInfo);

    resp.headerInfo  = agingReq.headerInfo;
    resp.requestInfo = agingReq.requestInfo;

    respInfo.transactionStatus = "F";

    ErrorInfo errInfo    = udrCreate(ErrorInfo);
    errInfo.errorCd      = errorCode;
    errInfo.errorMessage = errorMessage;
    respInfo.errorInfo   = errInfo;

    resp.responseInfo = respInfo;

    string sErrorResp = jsonEncodeUdr(resp);
    bytearray ba;
    strToBA(ba, sErrorResp);

    Response respUdr   = udrCreate(Response);
    respUdr.body       = ba;
    respUdr.headers    = getHeader();
    respUdr.statusCode = 400;
    origReq.response   = respUdr;

    debug("Sending aging error response: " + sErrorResp);

    udrRoute(sendToSplunk(origReq, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx), "toSplunk");

    udrRoute(origReq, "toClient");
}

// =============================================
// NEW ENT AGEING ODATA RESPONSE HANDLER
// ZGLB_ENT_AGEING_SRV_01/AgeingAPIDataSet
// =============================================
void handleNewOdataAgingResponse(RequestCycle cycle) {
    debug("In New ENT OData Aging Response Handler");

    int statusCode       = cycle.response.statusCode;
    RequestCycle origReq = (RequestCycle) cycle.context;
    AgingBucketDetailsRequest agingReq = udrCreate(AgingBucketDetailsRequest);
    jsonDecodeUdr(baToStr(origReq.body), agingReq);
    string resourceCode  = getXrefValue(RESOURCE_CODE_TABLE, origReq.path);

    string sBody = "";
    if (cycle.response.body != null)
        sBody = baToStr((bytearray) cycle.response.body);

    debug("New ODATA Status Code: " + (string)statusCode);

    // LOG: ODATA_RESPONSE
    string odataStatus = (statusCode == 200 || statusCode == 201) ? "SUCCESS" : "FAILURE";
    udrRoute(sendToSplunk(origReq, cycle, ODATA_RESPONSE, odataStatus, cycle.path, splunkCtx), "toSplunk");

    // Check for timeout
    if (!isEmpty(sBody) && strREContains(sBody, "Total timeout 30000 ms elapsed")) {
        debug("New ODATA Timeout");
        sendAgingErrorResponse(agingReq, origReq, "Request timed out", resourceCode + BRIM_ERROR);
        return;
    }

    // Handle error status codes
    if (!(statusCode == 200 || statusCode == 201)) {
        debug("New ODATA Error - Status: " + (string)statusCode);
        string errMsg = "Failure in ODATA call";
        if (!isEmpty(sBody)) {
            JsonObject errJson = udrCreate(JsonObject);
            if (instanceOf(jsonDecode(sBody), JsonObject)) {
                errJson = (JsonObject) jsonDecode(sBody);
                map<string, any> errMap = errJson.asMap;
                if (instanceOf(mapGet(errMap, "error"), JsonObject)) {
                    JsonObject errorObj = (JsonObject) mapGet(errMap, "error");
                    if (instanceOf(mapGet(errorObj.asMap, "message"), JsonObject)) {
                        JsonObject msgObj = (JsonObject) mapGet(errorObj.asMap, "message");
                        errMsg = (string) mapGet(msgObj.asMap, "value");
                    }
                }
            }
        }
        sendAgingErrorResponse(agingReq, origReq, errMsg, resourceCode + BRIM_ERROR);
        return;
    }

    // Handle empty response
    if (isEmpty(sBody)) {
        sendAgingErrorResponse(agingReq, origReq, "No record found", resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
        return;
    }

    // =============================================
    // SUCCESS - Parse new ENT Ageing response
    // =============================================
    JsonObject json = (JsonObject) jsonDecode(sBody);
    JsonObject d    = (JsonObject) mapGet(json.asMap, "d");
    JsonArray ja    = (JsonArray) mapGet(d.asMap, "results");

    if (ja == null || listSize(ja.asList) == 0) {
        sendAgingErrorResponse(agingReq, origReq,
            getErrorMessage(agingReq.requestInfo), resourceCode + BRIM_ERROR);
        return;
    }

    list<any> listResult = ja.asList;
    debug("New ENT Ageing results count: " + listSize(listResult));

    // Build response — one AgingBucketDetail per account returned
    list<AgingBucketDetail> listOfDetails = listCreate(AgingBucketDetail);
    string tagId = getTagId(origReq);
    string firstErrorMessage = "";

    for (any result : listResult) {
        JsonObject obj          = (JsonObject) result;
        map<string, any> objMap = obj.asMap;

        // Check for error: zzmtype = "E" indicates an error row
        string zzmtype = "";
        if (mapGet(objMap, "zzmtype") != null)
            zzmtype = (string) mapGet(objMap, "zzmtype");

        string zzmessage = "";
        if (mapGet(objMap, "zzmessage") != null)
            zzmessage = (string) mapGet(objMap, "zzmessage");

        if (zzmtype == "E" && !isEmpty(zzmessage)) {
            debug("Error row from ENT Ageing: " + zzmessage);
            if (isEmpty(firstErrorMessage))
                firstErrorMessage = zzmessage;
            continue;
        }

        AgingBucketDetail detail = udrCreate(AgingBucketDetail);

        // Map identifiers
        string ban = "";
        if (mapGet(objMap, "ZZban") != null)
            ban = (string) mapGet(objMap, "ZZban");
        detail.billingAccountNumber = ban;

        if (mapGet(objMap, "zzimbusorg") != null)
            detail.busOrgId = (string) mapGet(objMap, "zzimbusorg");
        if (mapGet(objMap, "zzimubusorg") != null)
            detail.ultimateBusOrgId = (string) mapGet(objMap, "zzimubusorg");

        // Map currency
        string currency = "USD";
        if (mapGet(objMap, "zzwaers") != null && !isEmpty((string) mapGet(objMap, "zzwaers")))
            currency = (string) mapGet(objMap, "zzwaers");
        detail.invoiceCurrencyCd = currency;

        // Map aging bucket amounts — values come pre-bucketed from ENT service
        AgingBucketDetailsGroupCurrency buckets = udrCreate(AgingBucketDetailsGroupCurrency);
        buckets.currencyCd = currency;

        buckets.currentDueAmount      = parseAmount(objMap, "zzcurrentdueamount");
        buckets.pastDueAmount         = parseAmount(objMap, "zzpastdueamount");
        buckets.totalDueAmount        = parseAmount(objMap, "zztotaldueamount");
        buckets.amountDue0To30Days    = parseAmount(objMap, "zzamountdue0to30days");
        buckets.amountDue31To60Days   = parseAmount(objMap, "zzamountdue31to60days");
        buckets.amountDue61To90Days   = parseAmount(objMap, "zzamountdue61to90days");
        buckets.amountDue91To120Days  = parseAmount(objMap, "zzamountdue91to120days");
        buckets.amountDue121To150Days = parseAmount(objMap, "zzamountdue121to150days");
        buckets.amountDue151To180Days = parseAmount(objMap, "zzamountdue151to180days");
        buckets.amountDue181To210Days = parseAmount(objMap, "zzamountdue181to210days");
        buckets.amountDue211To240Days = parseAmount(objMap, "zzamountdue211to240days");
        buckets.amountDue241To270Days = parseAmount(objMap, "zzamountdue241to270days");
        buckets.amountDue271To300Days = parseAmount(objMap, "zzamountdue271to300days");
        buckets.amountDue301To330Days = parseAmount(objMap, "zzamountdue301to330days");
        buckets.amountDue331To360Days = parseAmount(objMap, "zzamountdue331to360days");
        buckets.amountDue361PlusDays  = parseAmount(objMap, "zzamountdue361plusdays");

        // Fetch dispute amount using raw request inputs; ban is resolved per result row
        buckets.disputeAmount = (double) fetchDisputeAmount(
            ban,
            agingReq.requestInfo.busOrgId,
            agingReq.requestInfo.ultimateBusOrgId,
            agingReq.requestInfo.collectorUserId,
            tagId);
        debug("Dispute amount for BAN " + ban + ": " + buckets.disputeAmount);

        detail.groupCurrency = buckets;
        listAdd(listOfDetails, detail);
    }

    // If all rows were error rows, return the actual error message from S/4
    if (listSize(listOfDetails) == 0) {
        string errMsg = !isEmpty(firstErrorMessage) ? firstErrorMessage : getErrorMessage(agingReq.requestInfo);
        sendAgingErrorResponse(agingReq, origReq, errMsg, resourceCode + BRIM_ERROR);
        return;
    }

    // Build success response
    AgingBucketDetailsResponse resp       = udrCreate(AgingBucketDetailsResponse);
    AgingBucketDetailsResponseInfo respInfo = udrCreate(AgingBucketDetailsResponseInfo);

    resp.headerInfo  = agingReq.headerInfo;
    resp.requestInfo = agingReq.requestInfo;
    respInfo.transactionStatus = "S";

    date now = dateCreateNow();
    string reportDate;
    dateToString(reportDate, now, "yyyy-MM-dd");
    respInfo.reportRunDate = reportDate;

    respInfo.agingBucketDetails = listOfDetails;
    resp.responseInfo           = respInfo;

    string sResp = jsonEncodeUdr(resp);
    bytearray ba;
    strToBA(ba, sResp);

    Response respUdr   = udrCreate(Response);
    respUdr.body       = ba;
    respUdr.headers    = getHeader();
    respUdr.statusCode = 200;
    origReq.response   = respUdr;

    debug("Sending new ENT aging success response: " + sResp);
    udrRoute(sendToSplunk(origReq, null, API_RESPONSE, API_STATUS_SUCCESS, null, splunkCtx), "toSplunk");
    udrRoute(origReq, "toClient");
}

// Helper: parse a decimal amount from the response map
double parseAmount(map<string, any> objMap, string key) {
    double val = 0.0;
    if (mapGet(objMap, key) != null) {
        string strVal = (string) mapGet(objMap, key);
        if (!isEmpty(strVal))
            strToDouble(val, strVal);
    }
    return val;
