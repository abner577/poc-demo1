// Function to handle different types of input
void handleInput(any input) {
    if (instanceOf(input, RequestCycle)) {
        handleRequestCycle((RequestCycle)input);
    } else if (instanceOf(input, ZFIF_FM_VKONA_TO_BP_UDR)) {
        handleRFCInput((ZFIF_FM_VKONA_TO_BP_UDR)input);
    } else if(instanceOf(input, ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR)){
        handleRFCInputForEnt((ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR)input);
    }
}

// Function to handle RequestCycle input
void handleRequestCycle(RequestCycle cycleUdr) {
    //uniqueId to track request and responses to/from S/4
    setTagId(cycleUdr);
    udrRoute(sendToSplunk(cycleUdr, null, API_REQUEST, "", null, splunkCtx), "toSplunk");

    if (cycleUdr.path == "/brimcm/collection/aging/agingBucket" && cycleUdr.method == "POST") {
        processAgingBucketRequest(cycleUdr);
    }
}

// Function to process aging bucket request
void processAgingBucketRequest(RequestCycle cycleUdr) {
    AgingBucketDetailsRequest agingReq = parseRequestBody(cycleUdr.body);
    string valid = isValidRequest(agingReq.requestInfo);
    
    if (valid == "") {
        processValidRequest(cycleUdr, agingReq);
    } else {
         string resourceCode = getXrefValue(RESOURCE_CODE_TABLE , cycleUdr.path);
        sendErrorResponse(cycleUdr, agingReq,resourceCode+BRIM_ERROR, valid);
    }
}

// Function to process valid request
void processValidRequest(RequestCycle cycleUdr, AgingBucketDetailsRequest agingReq) {
    boolean isEssential = (!isEmpty(agingReq.requestInfo.agingByEssentialRequired) && 
                           agingReq.requestInfo.agingByEssentialRequired == "Y");
    string agingEntNewCall = getXrefValue("REFERENCE_DATA", "AGING_ENT_NEW_CALL");
    debug("AGING_ENT_NEW_CALL flag: " + agingEntNewCall);

    if (!isEssential && (!isEmpty(agingEntNewCall) && agingEntNewCall == "Y")) {
        // New ENT Ageing OData flow
        if (!isEmpty(agingReq.requestInfo.billingAccountNumber)) {
            // BAN present — must resolve to CA via ZFICAF RFC (never pass BAN directly to OData)
            // If collectorUserId is also present, store it for retrieval after RFC response
            if (!isEmpty(agingReq.requestInfo.collectorUserId)) {
                mapSet(resolvedCuidMap, getTagId(cycleUdr), agingReq.requestInfo.collectorUserId);
                debug("Stored collectorUserId for retrieval after ZFICAF RFC: " + agingReq.requestInfo.collectorUserId);
            }
            ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr = udrCreate(ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR);
            importParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT importParams = udrCreate(importParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT);
            list<ZFITT_VKONA> listOfBans = listCreate(ZFITT_VKONA);
            ZFITT_VKONA bill = udrCreate(ZFITT_VKONA);
            bill.VKONA = agingReq.requestInfo.billingAccountNumber;
            listAdd(listOfBans, bill);
            importParams.IT_VKONA = listOfBans;
            rfcUdr.importParams = importParams;
            rfcUdr.context = cycleUdr;
            udrRoute(sendRfcToSplunk(cycleUdr, (string)rfcUdr.importParams, "RFC_REQUEST", "", "ZFICAF_DERIVE_ACTIVE_ACCOUNT", splunkCtx), "toSplunk");
            udrRoute(rfcUdr, "rfc_req");
        } else {
            // No BAN — pass collectorUserId/busOrgId/ultimateBusOrgId directly to OData
            debug("New ENT OData flow (no BAN): passing inputs directly. collectorUserId=" + agingReq.requestInfo.collectorUserId
                + " busOrgId=" + agingReq.requestInfo.busOrgId
                + " ultimateBusOrgId=" + agingReq.requestInfo.ultimateBusOrgId);
            sendToOdata(cycleUdr, "", "", agingReq.requestInfo.collectorUserId);
        }
    } else {
        // Existing flow — essential or old call
        ZFIF_FM_VKONA_TO_BP_UDR rfcUdr = udrCreate(ZFIF_FM_VKONA_TO_BP_UDR);
        rfcUdr.importParams = udrCreate(importParams_ZFIF_FM_VKONA_TO_BP);
        rfcUdr.context = cycleUdr;
        rfcUdr.importParams.IT_CUID = listCreate(ZFITT_CUID);
        rfcUdr.importParams.IT_AGING_MD = listCreate(ZFITT_AGING_MD);
        ZFITT_AGING_MD aging = udrCreate(ZFITT_AGING_MD);
        if (!isEmpty(agingReq.requestInfo.billingAccountNumber))
            aging.BAN = agingReq.requestInfo.billingAccountNumber;
        if (!isEmpty(agingReq.requestInfo.busOrgId))
            aging.BUSS_ORG = agingReq.requestInfo.busOrgId;
        if (!isEmpty(agingReq.requestInfo.collectorUserId))
            aging.CUID = agingReq.requestInfo.collectorUserId;
        if (!isEmpty(agingReq.requestInfo.ultimateBusOrgId))
            aging.BUSS_ORG_UT = agingReq.requestInfo.ultimateBusOrgId;
        listAdd(rfcUdr.importParams.IT_AGING_MD, aging);
        udrRoute(sendRfcToSplunk(cycleUdr, (string)rfcUdr.importParams, "RFC_REQUEST", "", "ZFIF_FM_VKONA_TO_BP", splunkCtx), "toSplunk");
        udrRoute(rfcUdr, "rfc_req");
    }
}

// Function to handle RFC input
void handleRFCInput(ZFIF_FM_VKONA_TO_BP_UDR rfcUdr) {
    debug(rfcUdr);
    RequestCycle origReq = (RequestCycle) rfcUdr.context;

    if (udrIsPresent(rfcUdr.tableParams.ET_ERROR)) {
        udrRoute(sendRfcToSplunk(origReq, (string)rfcUdr.tableParams.ET_ERROR, "RFC_RESPONSE", API_STATUS_FAILURE, "ZFIF_FM_VKONA_TO_BP", splunkCtx), "toSplunk");
        processRFCError(rfcUdr);
    } else if (udrIsPresent(rfcUdr.tableParams.ET_OUT_FINAL)) {
        udrRoute(sendRfcToSplunk(origReq, (string)rfcUdr.tableParams, "RFC_RESPONSE", "SUCCESS", "ZFIF_FM_VKONA_TO_BP", splunkCtx), "toSplunk");
        processRFCSuccess(rfcUdr, origReq);
    }
}

void handleRFCInputForEnt(ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR input) {
    debug("RFC response received: " + input);
    ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr = (ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR) input;
    RequestCycle reqUdr = (RequestCycle) rfcUdr.context;
    udrRoute(sendRfcToSplunk(reqUdr, (string)rfcUdr.exportParams, "RFC_RESPONSE", "", "ZFICAF_DERIVE_ACTIVE_ACCOUNT", splunkCtx), "toSplunk");
    AgingBucketDetailsRequest agingReq = parseRequestBody(reqUdr.body);
    AgingBucketDetailsRequestInfo agingBucketDetailsRequestInfo = agingReq.requestInfo;

    string resourceCode = getXrefValue(RESOURCE_CODE_TABLE, reqUdr.path);

    // Check if this is the new ENT flow
    string agingEntNewCall = getXrefValue("REFERENCE_DATA", "AGING_ENT_NEW_CALL");
    boolean isEssential = (!isEmpty(agingBucketDetailsRequestInfo.agingByEssentialRequired) && 
                           agingBucketDetailsRequestInfo.agingByEssentialRequired == "Y");

    if (!isEssential && (!isEmpty(agingEntNewCall) && agingEntNewCall == "Y")) {
        // New ENT flow — extract CA, retrieve stored CUID if collectorUserId was present
        if (listSize(rfcUdr.exportParams.ET_GPART_VKONT) > 0) {
            ZFITT_OUTPUT_BILL rfcOutput = listGet(rfcUdr.exportParams.ET_GPART_VKONT, 0);
            string CA = rfcOutput.VKONT;
            if (isEmpty(CA)) {
                sendErrorResponse(reqUdr, agingReq, "Unable to resolve Contract Account", resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
            } else {
                // Retrieve previously resolved CUID (stored by processRFCSuccess if collectorUserId was present)
                string nCUID = "";
                if (!isEmpty(agingBucketDetailsRequestInfo.collectorUserId)) {
                    nCUID = (string)mapGet(resolvedCuidMap, getTagId(reqUdr));
                }
                debug("Resolved CA: " + CA + " CUID: " + nCUID);
                sendToOdata(reqUdr, CA, "", nCUID);
            }
        } else if (listSize(rfcUdr.exportParams.ET_ERROR) > 0) {
            ZFIT_VKONA_ERR_MSG rfcError = listGet(rfcUdr.exportParams.ET_ERROR, 0);
            sendErrorResponse(reqUdr, agingReq, rfcError.E_ERROR_MSG, resourceCode + CM_CONNECTION_ERROR);
        }
    } else {
        // Existing flow — validate CA/BP and send to old OData
        if (listSize(rfcUdr.exportParams.ET_GPART_VKONT) > 0) {
            ZFITT_OUTPUT_BILL rfcOutput = listGet(rfcUdr.exportParams.ET_GPART_VKONT, 0);
            string CA = rfcOutput.VKONT;
            string BP = rfcOutput.GPART;
            string busOrg = rfcOutput.BUSS_ORG;
            if (isEmpty(CA) || isEmpty(BP)) {
                sendErrorResponse(reqUdr, agingReq, "Invalid BAN", resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
            } else if (!isEmpty(agingBucketDetailsRequestInfo.busOrgId) &&
                       !strEqualsIgnoreCase(busOrg, agingBucketDetailsRequestInfo.busOrgId)) {
                sendErrorResponse(reqUdr, agingReq,
                    "Invalid billing account number " + agingBucketDetailsRequestInfo.billingAccountNumber +
                    " and bus org id " + agingBucketDetailsRequestInfo.busOrgId + " combination.",
                    resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
            } else {
                sendToOdata(reqUdr, CA, BP, "");
            }
        } else if (listSize(rfcUdr.exportParams.ET_ERROR) > 0) {
            ZFIT_VKONA_ERR_MSG rfcError = listGet(rfcUdr.exportParams.ET_ERROR, 0);
            sendErrorResponse(reqUdr, agingReq, rfcError.E_ERROR_MSG, resourceCode + CM_CONNECTION_ERROR);
        }
    }
}

// Function to process successful RFC response
void processRFCSuccess(ZFIF_FM_VKONA_TO_BP_UDR rfcUdr, RequestCycle rcUdr) {
      string nCUID;
    AgingBucketDetailsRequest agingReq = parseRequestBody(rcUdr.body);

    if(null != rfcUdr && !isEmpty(agingReq.requestInfo.collectorUserId))
        nCUID = extractCUID(rfcUdr);

    boolean isEssential = (!isEmpty(agingReq.requestInfo.agingByEssentialRequired) && 
                           agingReq.requestInfo.agingByEssentialRequired == "Y");

    // Check DB property for new ENT ODATA call
    string agingEntNewCall = getXrefValue("REFERENCE_DATA", "AGING_ENT_NEW_CALL");
    debug("AGING_ENT_NEW_CALL flag: " + agingEntNewCall);

    // If agingByEssentialRequired is N or empty AND AGING_ENT_NEW_CALL is Y → call sendToOdata
    if(!isEssential && (!isEmpty(agingEntNewCall) && agingEntNewCall == "Y")) {
        // This path is only reached when BAN-only (no collectorUserId) triggers ZFIF RFC
        // collectorUserId case now goes directly to OData without RFC
        debug("Routing to new ENT ODATA call after RFC (BAN-only path), CUID: " + nCUID);
        if (!isEmpty(agingReq.requestInfo.billingAccountNumber)) {
            // BAN present — also need CA from ZFICAF_DERIVE_ACTIVE_ACCOUNT
            if (!isEmpty(nCUID))
                mapSet(resolvedCuidMap, getTagId(rcUdr), nCUID);
            ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr2 = udrCreate(ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR);
            importParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT importParams = udrCreate(importParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT);
            list<ZFITT_VKONA> listOfBans = listCreate(ZFITT_VKONA);
            ZFITT_VKONA bill = udrCreate(ZFITT_VKONA);
            bill.VKONA = agingReq.requestInfo.billingAccountNumber;
            listAdd(listOfBans, bill);
            importParams.IT_VKONA = listOfBans;
            rfcUdr2.importParams = importParams;
            rfcUdr2.context = rcUdr;
            udrRoute(sendRfcToSplunk(rcUdr, (string)rfcUdr2.importParams, "RFC_REQUEST", "", "ZFICAF_DERIVE_ACTIVE_ACCOUNT", splunkCtx), "toSplunk");
            udrRoute(rfcUdr2, "rfc_req");
        } else {
            // No BAN — send directly to OData
            sendToOdata(rcUdr, "", "", nCUID);
        }
        return;
    }

    // Existing logic — agingByEssentialRequired = Y OR AGING_ENT_NEW_CALL != Y
    string filter = isEssential ? getFilterForEssential(agingReq.requestInfo) :
                                  getFilter(agingReq.requestInfo, nCUID);

    string select = isEssential ? getSelectColumnsForEssential(agingReq.requestInfo) :
                                  getSelectColumns(agingReq.requestInfo);

    string dtStr = getEffectiveDate(agingReq.requestInfo);
    string sURI  = buildURI(agingReq.requestInfo, filter, select, dtStr);

    RequestCycle reqUDR = getTokenDetailsForCI(sURI);
    reqUDR.context = rcUdr;
    debug("Request sent to BRIM at : " + dateCreateNow());
    udrRoute(sendToSplunk(rcUdr, reqUDR, "ODATA_REQUEST", "", reqUDR.path, splunkCtx), "toSplunk");
    udrRoute(reqUDR, "toS4");
}

// Function to process RFC error
void processRFCError(ZFIF_FM_VKONA_TO_BP_UDR rfcUdr) {
    RequestCycle reqUdr = (RequestCycle) rfcUdr.context;
    AgingBucketDetailsRequest agingReq = parseRequestBody(reqUdr.body);
    list<ZFITT_BAN_CUID> etError = rfcUdr.tableParams.ET_ERROR;
    debug("etError - " + etError);

    string errorMsg = !isEmpty(etError[0].ERROR_MSG) ? etError[0].ERROR_MSG : "";
    string resourceCode = getXrefValue(RESOURCE_CODE_TABLE, reqUdr.path);

   // logRfcResponse(reqUdr, "", getTagId(reqUdr), (string)etError, errorMsg, "ZFIF_FM_VKONA_TO_BP_UDR");
    sendErrorResponse(reqUdr, agingReq, resourceCode + BRIM_ERROR, errorMsg);
}

// Utility functions
AgingBucketDetailsRequest parseRequestBody(bytearray body) {
    string sJson = baToStr(body);
    AgingBucketDetailsRequest agingReq = udrCreate(AgingBucketDetailsRequest);
    jsonDecodeUdr(sJson, agingReq);
    return agingReq;
}

string getEffectiveDate(AgingBucketDetailsRequestInfo requestInfo) {
    if (isEmpty(requestInfo.effectiveDate)) {
        date dt = dateCreateNow();
        string dtStr;
        dateToString(dtStr, dt, "yyyy-MM-dd'T'00:00:00");
        return dtStr;
    } else {
        date dt;
        boolean success = strToDate(dt, requestInfo.effectiveDate, "yyyy-MM-dd");
        if(success) {
            string dtStr;
            dateToString(dtStr, dt, "yyyy-MM-dd'T'00:00:00");
            return dtStr;
        }
        
    }
    return requestInfo.effectiveDate;
}

string buildURI(AgingBucketDetailsRequestInfo requestInfo, string filter, string select, string dtStr) {
    
    string sURI;
    if(!isEmpty(requestInfo.agingByEssentialRequired) && requestInfo.agingByEssentialRequired == "Y"){ // Only for MM
        sURI = "/sap/opu/odata/sap/ZZ1_ZTCC_CADOCITMESS_M_Q1_CDS/ZZ1_ZTCC_CADOCITMESS_M_Q1(UIDate=datetime'<CURRENTDATE>')/Results?$format=json&$filter=<FILTER>" ;
        sURI = strREReplaceAll(sURI, "<CURRENTDATE>", dtStr);
        sURI = strREReplaceAll(sURI, "<FILTER>", filter);
    }
     
    else{
       sURI = "/sap/opu/odata/sap/ZZ1_ZTCC_CADOCBPITM_Q2_CDS/ZZ1_ZTCC_CADOCBPITM_Q2(UIDate=datetime'<CURRENTDATE>')/Results?$format=json&$filter=<FILTER>&$select=<SELECT>";
       
       sURI = strREReplaceAll(sURI, "<CURRENTDATE>", dtStr);
       sURI = strREReplaceAll(sURI, "<FILTER>", filter);
       sURI = strREReplaceAll(sURI, "<SELECT>", select);
    }
    debug("URI : "+sURI);
    return sURI;
}

void sendErrorResponse(RequestCycle cycleUdr, AgingBucketDetailsRequest agingReq, string errorCode, string errorMessage) {
    AgingBucketDetailsResponse errorUdr = createAgingBucketErrorResponseAging(agingReq, errorCode, errorMessage, "sBody");
    string sErrorResp = jsonEncodeUdr(errorUdr);
    bytearray ba;
    strToBA(ba, sErrorResp);

    Response respUdr = udrCreate(Response);
    respUdr.body = ba;
    respUdr.headers = getHeader();
    respUdr.statusCode = 400;
    cycleUdr.response = respUdr;

    udrRoute(sendToSplunk(cycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx), "toSplunk");
    udrRoute(cycleUdr, "toClient");
}

map<string,list<string>> getHeader(){
    map<string,list<string> > mapToken = mapCreate(string,list<string>);
    list<string> lContentType = listCreate(string);
    listAdd(lContentType,"application/json");
    mapSet(mapToken,"Content-Type",lContentType) ;
    return (mapToken);
}
string extractCUID(ZFIF_FM_VKONA_TO_BP_UDR rfcUdr) {
    string nCUID;
    list<ZFITT_BAN_CUID_ALL> liExCuid = rfcUdr.tableParams.ET_OUT_FINAL;
    for (ZFITT_BAN_CUID_ALL exCuid : liExCuid) {
        nCUID = exCuid.GTY_V_CUID_PARTNER;
    }
    debug("Extracted CUID ::"+nCUID);
    return nCUID;
}
string isValidRequest(AgingBucketDetailsRequestInfo requestInfo) {
    string isValid = "";
    
    if(isEmpty(requestInfo.collectorUserId) && 
       isEmpty(requestInfo.ultimateBusOrgId)&& 
       isEmpty(requestInfo.busOrgId) && isEmpty(requestInfo.billingAccountNumber)) {
           isValid = "Atleast one filter condition is required";
           return isValid;
       } 
       if(!isEmpty(requestInfo.agingByEssentialRequired) && requestInfo.agingByEssentialRequired == "Y"
       && isEmpty(requestInfo.billingAccountNumber)){
        isValid = "billingAccountNumber is required";
           return isValid;
       }
         if(requestInfo.effectiveDate != null) {
          date dt;
          strToDate(dt, requestInfo.effectiveDate, "yyyy-MM-dd");
          if(dt == null) {
              isValid = "Invalid Date format: Effective Date: expeted format: yyyy-MM-dd";
          }
          return isValid;
         }
       
    return isValid;
}

boolean isValidCombination(AgingBucketDetailsRequestInfo requestInfo) {
    boolean isValid = false;
    // only Collector update 
    if(!isEmpty(requestInfo.collectorUserId) && 
    (isEmpty(requestInfo.ultimateBusOrgId) && isEmpty(requestInfo.busOrgId) && isEmpty(requestInfo.billingAccountNumber))) {
     isValid = true;   
    } else if((!isEmpty(requestInfo.collectorUserId) && !isEmpty(requestInfo.ultimateBusOrgId)) && // Collector and ultimateBusOrgId
      (isEmpty(requestInfo.busOrgId) && isEmpty(requestInfo.billingAccountNumber))) {
      isValid = true;  
    } else if((!isEmpty(requestInfo.collectorUserId) && !isEmpty(requestInfo.busOrgId)) &&   // Collector and busOrgId
        (isEmpty(requestInfo.ultimateBusOrgId) && isEmpty(requestInfo.billingAccountNumber))) {
      isValid = true;
    } else if(!isEmpty(requestInfo.ultimateBusOrgId) && // only Ultimate busOrg Id
        (isEmpty(requestInfo.busOrgId) && isEmpty(requestInfo.billingAccountNumber) && isEmpty(requestInfo.collectorUserId))) {
      isValid = true;   
    } else if((!isEmpty(requestInfo.busOrgId)) && // only BusOrgId
              (isEmpty(requestInfo.ultimateBusOrgId) && isEmpty(requestInfo.billingAccountNumber) && isEmpty(requestInfo.collectorUserId))) {
      isValid = true;  
    } else if((!isEmpty(requestInfo.billingAccountNumber)) && // only billing account number.
              (isEmpty(requestInfo.ultimateBusOrgId) && isEmpty(requestInfo.busOrgId) && isEmpty(requestInfo.collectorUserId))) {
      isValid = true;  
    }
    return isValid;   
}

// Helper: appends a filter clause with %20and%20 separator if filter already has content
string appendFilter(string filter, string clause) {
    return filter != null ? filter + "%20and%20" + clause : clause;
}

string getFilter(AgingBucketDetailsRequestInfo requestInfo, string nCUID) {
    string filter = null;
    if (!isEmpty(nCUID))
        filter = appendFilter(filter, "CACollectionsClerk%20eq%20'" + nCUID + "'");
    if (!isEmpty(requestInfo.ultimateBusOrgId))
        filter = appendFilter(filter, "UltiCustBusOrgId%20eq%20'" + requestInfo.ultimateBusOrgId + "'");
    if (!isEmpty(requestInfo.busOrgId))
        filter = appendFilter(filter, "BusOrgId%20eq%20'" + requestInfo.busOrgId + "'");
    if (!isEmpty(requestInfo.billingAccountNumber))
        filter = appendFilter(filter, "BAN%20eq%20'" + requestInfo.billingAccountNumber + "'");
    return filter;
}

string getFilterForEssential(AgingBucketDetailsRequestInfo requestInfo) {
    string filter = null;
    if (!isEmpty(requestInfo.billingAccountNumber))
        filter = appendFilter(filter, "BAN%20eq%20'" + requestInfo.billingAccountNumber + "'");
    return filter;
}

// Helper: returns the leading select columns based on which identifier is present
string getSelectPrefix(AgingBucketDetailsRequestInfo requestInfo) {
    if (!isEmpty(requestInfo.billingAccountNumber) || !isEmpty(requestInfo.busOrgId))
        return "BAN,";
    if (!isEmpty(requestInfo.ultimateBusOrgId))
        return "BusOrgId,";
    if (!isEmpty(requestInfo.collectorUserId))
        return "CACollectionsClerk,UltiCustBusOrgId,UltiCustName,";
    return "";
}

string getSelectColumnsForEssential(AgingBucketDetailsRequestInfo requestInfo) {
    string commonColumns = "CompanyCodeCurrencyUSD,Regulated,OpenAmountUSD,CurrentDueAmountUSD,OverDueAmountUSD,Amnt1to30daysUSD,Amnt31to60daysUSD,Amnt61to90daysUSD,Amnt91to120daysUSD,Amnt121to150daysUSD,Amnt151to180daysUSD,Amnt181to210daysUSD,Amnt211to240daysUSD,Amnt241to270daysUSD,Amnt271to300daysUSD,Amnt301to330daysUSD,Amnt331to360daysUSD,Amnt361plusdaysUSD";
    return getSelectPrefix(requestInfo) + commonColumns;
}

string getSelectColumns(AgingBucketDetailsRequestInfo requestInfo) {
    string commonColumns = "CurrentDueAmountUSD,CompanyCodeCurrencyUSD,OverDueAmountUSD,OpenAmountUSD,DisputeAmountE,Amnt1to30daysUSD,Amnt31to60daysUSD,Amnt61to90daysUSD,Amnt91to120daysUSD,Amnt121to150daysUSD,Amnt151to180daysUSD,Amnt181to210daysUSD,Amnt211to240daysUSD,Amnt241to270daysUSD,Amnt271to300daysUSD,Amnt301to330daysUSD,Amnt331to360daysUSD,Amnt361plusdaysUSD";
    return getSelectPrefix(requestInfo) + commonColumns;
}


RequestCycle getTokenDetailsForCI(string uri){
    RequestCycle udr = udrCreate(RequestCycle);
    map<string,list<string> > mapToken = mapCreate(string,list<string>);
    list<string> lContentType = listCreate(string);
    listAdd(lContentType,"application/json");
    mapSet(mapToken,"Accept",lContentType) ;
    list<string> lToken = listCreate(string);
    listAdd(lToken,"fetch");
    
    map<string,string> mapParams = mapCreate(string,string);
    mapSet(mapParams,"sap-client",getSystemValue(SAP_CLIENT));
    
   // mapSet(mapParams,"format","json");
    udr.host = getSystemValue(REST_HOSTNAME);  //getSystemValue(REST_HOSTNAME); //http://ns2s4dapp2.saperp.corp.intranet:8080/sap/opu/odata/sap/ZGLB_DEVFI_WRITEOFF_REVERSAL_SRV/WriteoffNotesSet
    udr.secure = true;
    udr.port = getSystemValue(REST_PORT);//getSystemValue(REST_PORT);
    udr.path =  uri;
    udr.headers = mapToken;
    udr.method = "GET";
    udr.parameters = mapParams;
    return udr;     
}
AgingBucketDetailsResponse createAgingBucketErrorResponseAging(AgingBucketDetailsRequest req, string sErrorCode, string sErrorMsg, string sReqBody){
	AgingBucketDetailsResponse resp = udrCreate(AgingBucketDetailsResponse);
    AgingBucketDetailsResponseInfo responseInfo = udrCreate(AgingBucketDetailsResponseInfo);
    
    resp.headerInfo = req.headerInfo;
    resp.requestInfo = req.requestInfo;
    ErrorInfo errInfo = udrCreate(ErrorInfo);
    errInfo.errorMessage = sErrorMsg;
    errInfo.errorCd = sErrorCode;
    responseInfo.errorInfo = errInfo;
    responseInfo.transactionStatus =  "F";
    resp.responseInfo = responseInfo;
    return resp;  
}

void sendToOdata(RequestCycle cycle, string CA, string BP, string nCUID) {
    // Parse original request to get filter fields
    AgingBucketDetailsRequest agingReq = parseRequestBody(cycle.body);
    AgingBucketDetailsRequestInfo reqInfo = agingReq.requestInfo;

    // Build filter for new ENT Ageing OData
    // zzimca = CA from ZFICAF_DERIVE_ACTIVE_ACCOUNT (NOT billingAccountNumber)
    // zzimcuid = resolved CUID from ZFIF_FM_VKONA_TO_BP
    // zzimbusorg / zzimubusorg from request directly
    string filter = null;
    if (!isEmpty(CA)) {
        // CA resolved via ZFICAF RFC — use contract account filter
        filter = appendFilter(filter, "zzimca%20eq%20'" + CA + "'");
    }
    if (!isEmpty(nCUID)) {
        filter = appendFilter(filter, "zzimcuid%20eq%20'" + nCUID + "'");
    }
    if (!isEmpty(reqInfo.busOrgId)) {
        filter = appendFilter(filter, "zzimbusorg%20eq%20'" + reqInfo.busOrgId + "'");
    }
    if (!isEmpty(reqInfo.ultimateBusOrgId)) {
        filter = appendFilter(filter, "zzimubusorg%20eq%20'" + reqInfo.ultimateBusOrgId + "'");
    }

    string sURI = "/sap/opu/odata/SAP/ZGLB_ENT_AGEING_SRV_01/AgeingAPIDataSet?$filter=" + filter + "&$format=json";
    debug("sURI :: " + sURI);

    RequestCycle request = requestTokenDetails(sURI);
    request.context = cycle;

    debug("###Ageing GET request sending to ODATA : " + request);
    udrRoute(sendToSplunk(cycle, request, "ODATA_REQUEST", "", request.path, splunkCtx), "toSplunk");
    udrRoute(request, "toS4");
}]]></string>
