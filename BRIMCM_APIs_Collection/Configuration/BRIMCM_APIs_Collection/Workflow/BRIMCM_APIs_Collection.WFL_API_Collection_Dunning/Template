string validateAutoDailerRequest(AutoDailerCallStatusRequest request) {
    string errorString;
    AutoDailerRequestInfo requestInfo =  request.requestInfo;
    debug("requestInfo - " + requestInfo);
    if(requestInfo.billingAccountNumber == null || requestInfo.billingAccountNumber == ""){
       errorString = "Billing Account Number is Mandatory";   
    } 
    if((requestInfo.billingApplicationCd == null || requestInfo.billingApplicationCd == "") && (requestInfo.busOrgId == null || requestInfo.busOrgId == "")) {
        errorString = "Input is missing both Billing Application Code & Bus Org Id, provide any one of it";
    }
    
    return errorString;
}

