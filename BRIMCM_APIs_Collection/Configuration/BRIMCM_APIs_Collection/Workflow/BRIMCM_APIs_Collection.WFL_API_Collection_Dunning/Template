sessionInit {

    //updateCollector_session updateCollectorSession = (updateCollector_session) input;
    session.status = "RECEIVED";
    session.request = input.request;
    session.requestObj = input.requestObj;
    session.timeReceived = input.timeReceived;
    session.uuidKey = input.uuidKey;

    //session.banCount = 0;
    debug("Step 1: Initiated Session for the below request---->>");
    debug("Session Id :: "+session.uuidKey+" Status:: "+session.status); 
    // debug(session);

    sessionTimeout(session, 1000);
}

consume {

    debug("Session Id :: "+session.uuidKey+" Status:: "+session.status);
    // received a request fresh 
    if (input.status == "RECEIVED") {
        // set the status to inprogress and   Collector
        session.status = "LOOKUP_INPROGRESS";
          ZFIF_FM_VKONA_TO_BP_UDR rfcUdr = udrCreate(ZFIF_FM_VKONA_TO_BP_UDR);
            rfcUdr.importParams = udrCreate(importParams_ZFIF_FM_VKONA_TO_BP);
            rfcUdr.context = session;
            //debug(rfcUdr);
            //debug(rfcUdr.importParams);
            rfcUdr.importParams.IT_BAN_BILLAPPCODE = listCreate(ZFITT_REFUND_GET);
            
             ZFITT_REFUND_GET rfcInput = udrCreate(ZFITT_REFUND_GET) ;
             AutoDailerCallStatusRequest req = (AutoDailerCallStatusRequest) session.requestObj;
             rfcInput.BAN = req.requestInfo.billingAccountNumber;
             rfcInput.BUSS_ORG = req.requestInfo.busOrgId;
             rfcInput.BILLAPPCODE = req.requestInfo.billingApplicationCd;
             listAdd(rfcUdr.importParams.IT_BAN_BILLAPPCODE, rfcInput);
             udrRoute(rfcUdr, "rfc_req");
             //Forwarding RFC Request log to Splunk
             udrRoute(sendRfcToSplunk(session.request,(string)rfcUdr.importParams,RFC_REQUEST,"","ZFIF_FM_VKONA_TO_BP",splunkCtx),"toSplunk");
    }
    if(input.status == "RFC_ERROR_RESPONSE") {
          debug("In Consume, consuming the request and setting it -->>> RFC_ERROR_RESPONSE");
          session.status = "RECEIVED_ERROR_RESPONSE";
          session.rfcRequestResponse = input.rfcRequestResponse;
          session.rfcErrors = input.rfcErrors;
          session.inputError = true;
          sessionTimeout(session, -1); 
    }
    if (input.status == "RFC_RESPONSE") {
            debug("Consume:: Step 3: Response received from RFC ---->>> RFC_RESPONSE ");
            session.rfcRequestResponse = input.rfcRequestResponse;
            // GET call to fetch the CSRF token.
            // move the code from timeout block that we are calling s4 here.
             
               RequestCycle reqUdrForGetCall = accessTokenRequest(session);
               reqUdrForGetCall.context = session.uuidKey + ":GET_TOKEN";
                debug("The value of reqUdrForGetCall = " + (reqUdrForGetCall));
                session.status = "CSRF_TOKEN_REQUESTED";
                debug("Session Id :: "+session.uuidKey+" Status:: "+session.status);
                udrRoute(reqUdrForGetCall, "toS4");
                //Forwarding ODATA request log towards Splunk
                udrRoute(sendToSplunk(session.request,reqUdrForGetCall,ODATA_REQUEST,"",reqUdrForGetCall.path,splunkCtx),"toSplunk");                 
    }
    if (input.status == "CSRF_TOKEN_RECEIVED") {
            debug("Consume::  Response received from RFC ---->>> CSRF_TOKEN_RECEIVED ");
            session.status = input.status;
            session.responseHeader = input.responseHeader;
            session.s4ResponseStatus = input.s4ResponseStatus != null? input.s4ResponseStatus: "";
            session.s4ResponseBody = input.s4ResponseBody;
            //RequestCycle cycleUdr = (RequestCycle) session.request;
            //debug("Step 4: The value of cycleUdr = " + (cycleUdr));
            debug("Session Id :: "+session.uuidKey+" Status:: "+session.status +" s4ResponseStatus:: "+session.s4ResponseStatus);
            debug("s4ResponseBody  :: "+session.s4ResponseBody);
            if ( session.s4ResponseStatus == "200" && session.s4ResponseBody != null) {
                debug("--------- Response ---------------");
                //http.RequestCycle reqUDRForPost = accessTokenRequest(session);;
                //reqUDRForPost.context = session.uuidKey + ":POST_TO_S4";
                //debug("---------------------");
                //debug("The value of reqUDRForPost = " + (reqUDRForPost));
                //debug("---------------------");
                session.status = "POST_TO_S4_RECEIVED";
                sessionTimeout(session, -1);   
               //udrRoute(reqUDRForPost, "toS4");
            } else {
                  debug("--------- non 200 Response ---------------");
               // error scenario for token request, timeout
                  session.status = "ERROR_IN_TOKEN_REQUEST";
                  session.inputError = true;
                  debug("Session Id :: "+session.uuidKey+" Status:: "+session.status);
                  sessionTimeout(session, -1);   
            }
    }
}
    timeout {
        debug("Step 6: Timeout block");
        debug("Session Id :: "+session.uuidKey+" Status:: "+session.status);
        RequestCycle cycleUdr = (RequestCycle) session.request;
        string resourceCode = BRIMCM_APIs_Common.APL_FUNCTIONS.getXrefValue(RESOURCE_CODE_TABLE, cycleUdr.path);
        // there was input error or
        // there was error in the rfc response, could not get all ban responses before timeout
        if (session.inputError) {
            debug("Step 6: Timeout inputError");
            AutoDailerCallStatusRequest request  = (AutoDailerCallStatusRequest) session.requestObj;
            
            ErrorInfo errorResponse =  udrCreate(ErrorInfo);
            if(request.requestInfo.busOrgId !=  null) {
            errorResponse.errorMessage = "No AutoDailer call records found for the given Billing Account Number and Bus Org Id"; 
            } else if(request.requestInfo.billingApplicationCd != null) {
            errorResponse.errorMessage = "No AutoDailer call records found for the given Billing Account Number and Bill App Code";             }
            errorResponse.errorCd = resourceCode + BRIM_ERROR;
            AutoDailerCallStatusResponse response = udrCreate(AutoDailerCallStatusResponse);
            AutoDailerResponseInfo responseInfo = udrCreate(AutoDailerResponseInfo);
            responseInfo.errorInfo = errorResponse;
            responseInfo.transactionStatus ="F";
            response.headerInfo = request.headerInfo;
            response.requestInfo = request.requestInfo;
            response.responseInfo = responseInfo;
            
            cycleUdr.response.openAPIUDR = response;  
            cycleUdr.response.statusCode = 400;
            cycleUdr.response.headers=getHeader();
            //logResponse(cycleUdr, ""); 
            udrRoute(cycleUdr, "toClient");
            // Finally remove the session from memory INC7413761
            sessionRemove(session); 
            //Forwarding API response log to Splunk
            udrRoute(sendToSplunk(cycleUdr,null,API_RESPONSE, API_STATUS_FAILURE,null,splunkCtx),"toSplunk");   
            return;
        }
        if (session.status == "POST_TO_S4_RECEIVED") {
