                  <string name="sourceCode"><![CDATA[// import apl.BRIMCM_APIs_EXTENSIONS.APL_Functions_Collection;
import apl.BRIMCM_APIs_Common.APL_FUNCTIONS;
import ultra.SAP_RFC.BRIMCM_APIs_Collection.RFC_LUMN.subUdr;
import ultra.openapi.BRIMCM_APIs_Collection.PRF_Collection_Correspondence;
import apl.Common.APL_LOGGING;
import ultra.Common.UFL_API_LogFormat;
import apl.Common.APL_CONSTANTS;
import ultra.Common.ULF_Logging;
import ultra.wfb;


/*
// This agent handles 4 transaction lifecycle stages:
//
// 1. REQUEST
//    - Initial client HTTP request processing
//    - Request validation
//    - Early error response handling (BAN & BusOrg missing)
//
// 2. RFC_REQUEST
//
// 3. RFC_RESPONSE
//
// 4. ODATA_REQUEST
//
// NOTE:
// ODATA_RESPONSE and final RESPONSE processing occur downstream
// in the Analysis_Response agent.
// ============================================================================
*/

string PATH_COLLECTION_CORRESPONDENCE;
SplunkContext splunkCtx;

initialize {
    PATH_COLLECTION_CORRESPONDENCE = externalReferenceGet("Common.DB_External_Reference","PATH_COLLECTION_CORRESPONDENCE");
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string)mimGet("Workflow","Execution Context");
    splunkCtx.workflowName = (string)mimGet("Workflow" , "Workflow Name");
    splunkCtx.agentName = (string)mimGet("Analysis_Request" , "Agent Name");
}

consume {
    try {

        string resourceCode;
        string str_tagId;
        
        // STAGE 1: REQUEST STAGE -- Initial client request received 
        if (instanceOf(input, RequestCycle)) {
            RequestCycle clientCycleUdr = (RequestCycle) input;
            str_tagId = setTagId(clientCycleUdr);
            
            debug("The value of str_tagId = " + (str_tagId));
            debug("inside Request Cycle instance[Analysis_Request]");
            debug("###clientCycleUdr## " + clientCycleUdr);
            
            resourceCode = getXrefValue(RESOURCE_CODE_TABLE, clientCycleUdr.path);
            
            // Log REQUEST
            ConsumeCycleUDR clientRequestLog = sendToSplunk(clientCycleUdr, null, API_REQUEST, "", null, splunkCtx);
            udrRoute(clientRequestLog, "toSplunk");
            
             // Response Header Structure Setup 
            map<string,list<string>> mapHeaders = mapCreate(string,list<string>);
            list<string> lHeader = listCreate(string);
            listAdd(lHeader, "application/json");
            mapSet(mapHeaders, "Content-Type", lHeader);
            clientCycleUdr.response.headers = mapHeaders;
            
            string sBody;
            any Rec;
            
            if (clientCycleUdr.body != null) {
                sBody = baToStr(clientCycleUdr.body);
                Rec = jsonParse(sBody);
                
                debug("sBody : " + sBody);
                debug("Rec : " + Rec);
            }
            
            string BAN = mapGet(clientCycleUdr.parameters,"billingAccountNumber");
            string BussOrg = mapGet(clientCycleUdr.parameters,"busOrgId");
            
            // Check which API path this request is hitting
            if (clientCycleUdr.path == PATH_COLLECTION_CORRESPONDENCE) {

                debug("BAN = " + (BAN));
                debug("BussOrg = " + (BussOrg));
                
                if(isEmpty(BAN) && isEmpty(BussOrg)){
                     CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr("40101", "Both billingAccountNumber and busOrgId missing", BAN, BussOrg);
                     clientCycleUdr.response.openAPIUDR = errResponseToClient;  
                     clientCycleUdr.response.statusCode = 400;
                     
                     udrRoute(clientCycleUdr, "responseToClient");
                     
                     ConsumeCycleUDR errorResponseLog = sendToSplunk(clientCycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                     udrRoute(errorResponseLog, "toSplunk");  
                     return;                                                                                  
                }
                // STAGE 2: Sending RFC_REQUEST
                else {
                    // SAP RFC needs at least one of BAN (I_VKONA) or BussOrg (I_BPEXT) in Request Params
                    ZFICAF_GPART_VKONT_DERIVE_UDR rfcRequestUdr = udrCreate(ZFICAF_GPART_VKONT_DERIVE_UDR);
                    rfcRequestUdr.importParams = udrCreate(importParams_ZFICAF_GPART_VKONT_DERIVE);

                    if (!isEmpty(BAN)) {
                        rfcRequestUdr.importParams.I_VKONA = BAN;
                    } 
                    if (!isEmpty(BussOrg)) {
                        rfcRequestUdr.importParams.I_BPEXT = BussOrg;
                    }
                    
                    rfcRequestUdr.context = clientCycleUdr; // ###Preserve original HTTP request context###
                    
                    // Send request to RFC and toSplunk
                    udrRoute(rfcRequestUdr, "rfcRequest");
                    
                    ConsumeCycleUDR rfcRequestLog = sendRfcToSplunk(clientCycleUdr, (string) rfcRequestUdr.importParams, RFC_REQUEST, "", "ZFICAF_GPART_VKONT_DERIVE_UDR", splunkCtx);
                    udrRoute(rfcRequestLog, "toSplunk");
                }  
            }
            // CM received an HTTP request routed into this workflow, but this workflow doesnt recognize this path
            else {

                debug("Inside unknown or unsupported API path condition");
                
                CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr("40101", "Unknown or unsupported API path", BAN, BussOrg);
                clientCycleUdr.response.openAPIUDR = errResponseToClient;  
                clientCycleUdr.response.statusCode = 404;
                     
                udrRoute(clientCycleUdr, "responseToClient");
                ConsumeCycleUDR errorResponseLog = sendToSplunk(clientCycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                udrRoute(errorResponseLog, "toSplunk");
                return;
            }
        }
        // STAGE 3: Receive RFC_RESPONSE
        else if (instanceOf(input,ZFICAF_GPART_VKONT_DERIVE_UDR)) {

                debug("###Response from RFC = " + (input));
                log.info("###Response from RFC = " + (input));
                
                ZFICAF_GPART_VKONT_DERIVE_UDR rfcResponseUdr = (ZFICAF_GPART_VKONT_DERIVE_UDR) input;
                
                if (rfcResponseUdr.context == null) {
                    debug("FATAL: Missing RequestCycle context in RFC response processing");
                    log.error("FATAL: Missing RequestCycle context in RFC response processing");
                    return;
                }
                
                RequestCycle originalClientReqUdr = (RequestCycle) rfcResponseUdr.context;
                
                string BussOrg = rfcResponseUdr.importParams.I_BPEXT;
                string BAN = rfcResponseUdr.importParams.I_VKONA;
                
                if (originalClientReqUdr.path == PATH_COLLECTION_CORRESPONDENCE) { 

                    debug("The value of rfcResponseUdr [Analysis_Request] = " + (rfcResponseUdr));
                    string busPartner, contractAcc, sURI;
                    
                    /* 
                     The RFC response (exportParams) contains: ET_GPART_VKONT --> 
                     which is an object that within it, contains the BusinessOrg / BusinessPartner and the VKONT / CA
                     
                     So all we are doing here is just extracting the busOrg and the CA from the result that we got from RFC.
                    */
                    list<FKKVKP_KEY_T> listOfBP_CA = listCreate(FKKVKP_KEY_T);
                    listOfBP_CA = rfcResponseUdr.exportParams.ET_GPART_VKONT;
                    
                    if (listSize(listOfBP_CA) > 0) {
                        busPartner = listOfBP_CA[0].GPART;
                        
                        if(listSize(listOfBP_CA) == 1) {
                            contractAcc = listOfBP_CA[0].VKONT;
                        }
                        else {
                            contractAcc = null;
                        }

                        // Log RFC_RESPONSE
                        ConsumeCycleUDR rfcResponseLog = sendRfcToSplunk(originalClientReqUdr, (string) rfcResponseUdr.exportParams, RFC_RESPONSE, API_STATUS_SUCCESS, "ZFICAF_GPART_VKONT_DERIVE_UDR", splunkCtx);
                        udrRoute(rfcResponseLog, "toSplunk");

                        debug("busPartner = " + busPartner + "::contractAcc = " + contractAcc + "::busOrg = " + BussOrg + "::BAN = " + BAN);
                        log.info("busPartner = " + busPartner + "::contractAcc = " + contractAcc + "::busOrg = " + BussOrg + "::BAN = " + BAN);
                    }
                    // SAP didnt return data --> send error
                    else {

                        debug("###ERROR: No Data found in BRIM for billingAccountNumber or busOrgId");

                        string sBAN = mapGet((map<string,string>)rfcResponseUdr.context.parameters,"billingAccountNumber");
                        string sBussOrg = mapGet((map<string,string>)rfcResponseUdr.context.parameters,"busOrgId");
                        resourceCode = getXrefValue(RESOURCE_CODE_TABLE, originalClientReqUdr.path);

                        CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr(resourceCode + BRIM_ERROR, "No Data found in BRIM for billingAccountNumber or busOrgId", sBAN, sBussOrg);
                        originalClientReqUdr.response.openAPIUDR = errResponseToClient;  
                        originalClientReqUdr.response.statusCode = 400;

                        // Send error response back to client + Splunk
                        udrRoute(originalClientReqUdr, "responseToClient");

                        ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                        ConsumeCycleUDR failedRfcResponseLog = sendRfcToSplunk(originalClientReqUdr, (string) rfcResponseUdr.exportParams, RFC_RESPONSE, API_STATUS_FAILURE, "ZFICAF_GPART_VKONT_DERIVE_UDR", splunkCtx);
                        
                        udrRoute(errorResponseLog, "toSplunk");
                        udrRoute(failedRfcResponseLog, "toSplunk");
                        return; 
                    }
                    // STAGE 4: Call S4 --> ODATA_REQUEST
                    // Build URLs to call ODATA (CA is preferred, busPartner as fallback)
                     string sURICA= "/sap/opu/odata/sap/ZGLB_DEVFI_DISPLAYCORR_SRV/C_CACorrespondenceHistory?$filter=ContractAccount"+"%20"+"eq"+"%20"+"'"+contractAcc+"'&$format=json";
                     string sURIBP= "/sap/opu/odata/sap/ZGLB_DEVFI_DISPLAYCORR_SRV/C_CACorrespondenceHistory?$filter=BusinessPartner"+"%20"+"eq"+"%20"+"'"+busPartner+"'&$format=json";
                     
                      if(!isEmpty(contractAcc)) {
                        sURI = sURICA;
                     }
                     else {
                        sURI = sURIBP;
                     }
                        
                     // Build outbound ODATA RequestCycle object.
                    // Actual HTTP call occurs when routed to requestToS4.
                     http.RequestCycle requestToOdataUDR = requestTokenDetails(sURI);                                      
                     requestToOdataUDR.context = rfcResponseUdr.context;
                     
                     udrRoute(requestToOdataUDR, "requestToS4");
                     
                     ConsumeCycleUDR odataRequestLog = sendToSplunk(originalClientReqUdr, requestToOdataUDR, ODATA_REQUEST, "", requestToOdataUDR.path, splunkCtx);
                     udrRoute(odataRequestLog, "toSplunk");
             }
             // CM received an HTTP request routed into this workflow, but this workflow doesnt recognize this path
             else {

                 debug("Inside Unknown or unsupported API path condition");
                 log.info("Inside Unknown or unsupported API path condition");

                 CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr("40101", "Unknown or unsupported API path", BAN, BussOrg);
                 originalClientReqUdr.response.openAPIUDR = errResponseToClient;  
                 originalClientReqUdr.response.statusCode = 404;
                     
                 udrRoute(originalClientReqUdr, "responseToClient");
                 ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                 udrRoute(errorResponseLog, "toSplunk");
                 return;
            }
        }
        // Case where input type is one that we are not expecting
        else {
            log.info("Inside case where input type is one that we are not expecting");
            log.info("Input value: " + input);
        }
    } catch (ExceptionDetails exception) {

        debug("Exception:: " + exception);
        log.info("Exception:: " + exception);

        RequestCycle clientCycleUdr = null;

        if (instanceOf(input, RequestCycle)) {
            clientCycleUdr = (RequestCycle) input;

        } 
        else if (instanceOf(input, ZFICAF_GPART_VKONT_DERIVE_UDR)) {
            clientCycleUdr = (RequestCycle) ((ZFICAF_GPART_VKONT_DERIVE_UDR) input).context;

        } else {
            
            // Cannot safely return HTTP response or send normal error Splunk log
            // because RequestCycle context is unavailable.
            debug("FATAL: Unable to resolve RequestCycle " + "during exception handling. " + "Original exception: " + exception.message);
            log.info("FATAL: Unable to resolve RequestCycle " + "during exception handling. " + "Original exception: " + exception.message);
            return;
        }

        string BAN = mapGet(clientCycleUdr.parameters, "billingAccountNumber");
        string BussOrg = mapGet(clientCycleUdr.parameters, "busOrgId");

        CorrespondenceHistoryResponse exceptionResponseToClient = buildErrResponseForCorr("50001", "Internal processing error", BAN, BussOrg);
        clientCycleUdr.response.openAPIUDR = exceptionResponseToClient;  
        clientCycleUdr.response.statusCode = 500;

        udrRoute(clientCycleUdr, "responseToClient");
        
        ConsumeCycleUDR exceptionResponseLog = sendToSplunk(clientCycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
        udrRoute(exceptionResponseLog, "toSplunk");
    }
}
/**
 * Builds a standardized Collection Correspondence error response object.
 *
 * The returned response includes:
 *
 * - Original request identifiers (BAN / BUSSORG)
 * - Error code and error message
 * - Failed transaction status ("F")
 *
 * @param errorCode
 *        Standardized workflow/business error code.
 *
 * @param errorMessage
 *        Human-readable failure description.
 *
 * @param BAN
 *        Billing Account Number associated with the request.
 *
 * @param BussOrg
 *        Business Organization identifier associated with the request.
 *
 * @return
 *        Fully populated failed CorrespondenceHistoryResponse object
 *        ready to attach to the HTTP response lifecycle.
 */
CorrespondenceHistoryResponse buildErrResponseForCorr(string errorCode, string errorMessage, string BAN, string BussOrg) {
   CorrespondenceHistoryResponse response = udrCreate(CorrespondenceHistoryResponse);
   CorrespondenceHistoryRequestInfo requestInfo = udrCreate(CorrespondenceHistoryRequestInfo);

   requestInfo.billingAccountNumber = BAN; // Info represents the request that is throwing this error
   requestInfo.busOrgId = BussOrg;
   response.requestInfo = requestInfo;

   ErrorInfo errUdr = udrCreate(ErrorInfo);

   errUdr.errorCd = errorCode;
   errUdr.errorMessage = errorMessage;

   CorrespondenceHistoryResponseInfo responseInfo = udrCreate(CorrespondenceHistoryResponseInfo);
   responseInfo.transactionStatus = "F";
   responseInfo.errorInfo = errUdr;

   response.responseInfo = responseInfo; // What we are sending back to client
   return response;
}]]></string>
