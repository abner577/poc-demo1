/*
// ============================================================================
// This agent handles the final 2 transaction lifecycle stages:
//
// 5. ODATA_RESPONSE
//    - Receives the HTTP/OData response returned from S4
//    - Transforms S4/OData response into client-facing API response format
//
// 6. RESPONSE
//    - Routes final response back through the original HTTP request cycle
//
// NOTE:
// Earlier transaction stages occur upstream in Analysis_Request:

// - REQUEST
// - RFC_REQUEST
// - RFC_RESPONSE
// - ODATA_REQUEST
//
// IMPORTANT:
// Some early error responses never reach this agent.
// Validation failures and some RFC failures are handled directly
// inside Analysis_Request.
// ============================================================================
*/

SplunkContext splunkCtx;

initialize {
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string)mimGet("Workflow","Execution Context");
    splunkCtx.workflowName = (string)mimGet("Workflow" , "Workflow Name");
    splunkCtx.agentName = (string)mimGet("Analysis_Response" , "Agent Name");
}

consume {
    
    try {
        string resourceCode;

        // STAGE 5: Receive ODATA_RESPONSE from S4/OData
        if (instanceOf(input,RequestCycle)) {
            
            RequestCycle s4CycleUdr = (RequestCycle) input; // Response back from S4

            // Cannot log properly because RequestCycle context is lost
            if (s4CycleUdr.context == null) {
                debug("FATAL: Missing RequestCycle context in ODATA response processing");
                log.error("FATAL: Missing RequestCycle context in ODATA response processing");
                return;
            }

            RequestCycle originalClientReqUdr = (RequestCycle) s4CycleUdr.context; // Original client RequestCycle

            string BAN = mapGet(originalClientReqUdr.parameters, "billingAccountNumber");
            string BussOrg = mapGet(originalClientReqUdr.parameters, "busOrgId");
             
            map<string, list<string>> mapToken = tokenReq(s4CycleUdr.response.headers);
            resourceCode = getXrefValue(RESOURCE_CODE_TABLE, originalClientReqUdr.path);

            debug("The value of s4CycleUdr: " + s4CycleUdr);
            debug("mapToken in consume : " + mapToken);

            // Confirm this is the expected OData response
            if (strREContains(s4CycleUdr.path,"/sap/opu/odata/sap/ZGLB_DEVFI_DISPLAYCORR_SRV/C_CACorrespondenceHistory") && s4CycleUdr.method == "GET") {
                debug("Inside GET Call to GET Correspondence details");
                debug("s4CycleUdr For Correspondence = " + s4CycleUdr);

                // Parse response body. Body --> bytearray --> string --> json
                bytearray baRecord = (bytearray)s4CycleUdr.response.body;
                string sResponseBody = baToStr(baRecord);
                map<string,any> response = (map<string,any>)jsonParse(sResponseBody);

                // Final client-facing API response objects.
                CorrespondenceHistoryResponse responseToClientFinal = udrCreate(CorrespondenceHistoryResponse);
                CorrespondenceHistoryResponseInfo responseToClientInfo = udrCreate(CorrespondenceHistoryResponseInfo);
                list<CorrespondenceList> listOfAllCorrespondenceRecords = listCreate(CorrespondenceList);

                debug("s4CycleUdr.response.statusCode: " + s4CycleUdr.response.statusCode);

                // Successful ODATA response received 
                if (s4CycleUdr.response.statusCode == 200) {
                   debug("Inside 200 success condition");
                   debug("response inside 200 condition: " + response);
                   
                   responseToClientInfo.transactionStatus = "S";
                   
                   // So we have d --> and inside d we have results --> And then inside results we have actual values, 
                   // which is why we are progressively drilling deeper into the JSON structure. 
                   map<string,list<any>> mapCorrespondenceDetails = (map<string,list<any>>)mapGet(response,"d");
                   list <any> results = listCreate(any);
                   results = mapGet(mapCorrespondenceDetails, "results");
                   
                   debug("mapCorrespondenceDetails: " + mapCorrespondenceDetails);
                   debug("results: "+ results);

                   string CorrespondenceIssueDate, epocDateInMillisec, responseDate;
                   date resDate; 
                   long longMillisec;

                   if (listSize(results) > 0) { 
                       
                       for (any correspondenceRecord : results) {
                           
                           CorrespondenceList correspondenceRecordItems = udrCreate(CorrespondenceList);
                           CorrespondenceIssueDate = (string)correspondenceRecord.CorrespondenceIssueDate; // Extract raw date

                           // From raw date, extract epoch number and convert into YYYY-MM-DD
                           if (CorrespondenceIssueDate != null) {
                               epocDateInMillisec = strSubstring(CorrespondenceIssueDate, 6, strLength(CorrespondenceIssueDate)-2);
                             // debug ("epocDate - "+ epocDateInMillisec);
                               if (epocDateInMillisec != null) {
                                   strToLong(longMillisec, epocDateInMillisec);
                                   resDate = dateCreateFromMilliseconds (longMillisec); 
                                   responseDate = strSubstring((string) resDate, 0, 10);
                                 // debug ("responseDate - "+ responseDate);  
                               }
                           }
                           
                           // Map raw S4 fields --> API fields client expects 
                           correspondenceRecordItems.correspondenceType = (string) correspondenceRecord.CACorrespncDispatchControlName;                                   
                           correspondenceRecordItems.recipientName = (string) correspondenceRecord.CorrespondenceRecipientName;
                           correspondenceRecordItems.sentOrReceivedOn = responseDate;
                           correspondenceRecordItems.initiatedByUserName = (string) correspondenceRecord.CorrespondenceIssuedByUserName;
                           correspondenceRecordItems.correspondenceURL = (string) correspondenceRecord.CorrespondenceUrl;
                           
                           debug("CorrespondenceURL: " + correspondenceRecordItems.correspondenceURL);
                          
                          // Sometimes S4 returns placeholder URLs
                          if (strStartsWith(correspondenceRecordItems.correspondenceURL,"00000") || strStartsWith(correspondenceRecordItems.correspondenceURL,"0000000000")) {
                            correspondenceRecordItems.correspondenceURL = "";
                          }
                          listAdd(listOfAllCorrespondenceRecords, correspondenceRecordItems);
                        }

                       responseToClientInfo.correspondenceList = listOfAllCorrespondenceRecords; 
                       originalClientReqUdr.response.statusCode = 200;

                       ConsumeCycleUDR successfulOdataResponseLog  = sendToSplunk(originalClientReqUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_SUCCESS, s4CycleUdr.path, splunkCtx);
                       udrRoute(successfulOdataResponseLog , "toSplunk");
                   }
                   // S4/OData request succeeded technically, but no correspondence data exists
                   else {

                    debug("Inside case where S4/OData request succeeded technically, but no correspondence data exists");                    
                    responseToClientInfo.transactionStatus = "F";

                    // Build response for client
                    CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr(resourceCode + BRIM_ERROR, "No Correspondence details Found in BRIM for input billingAccountNumber or busOrgId", BAN, BussOrg);
                    originalClientReqUdr.response.openAPIUDR = errResponseToClient;
                    originalClientReqUdr.response.statusCode = 404;
                    
                    udrRoute(originalClientReqUdr, "responseToClient");

                    // Log failed RESPONSE back to client
                    ConsumeCycleUDR failedResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);

                    // Log failed ODATA_RESPONSE
                    ConsumeCycleUDR failedOdataResponseLog = sendToSplunk(originalClientReqUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_FAILURE, s4CycleUdr.path, splunkCtx);
                    
                    udrRoute(failedOdataResponseLog, "toSplunk");
                    udrRoute(failedResponseLog, "toSplunk");
                    
                    return;
                   }    
                }
                // S4 returned non-200 HTTP response
                else {
                    
                    debug("Inside case where S4/OData returns non-200 HTTP response");                    

                    // Build response for client
                    map<string,string> mapCode = (map<string,string>)mapGet(response,"error");
                    string errorMessage = mapGet(mapCode,"message");

                    CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr(resourceCode + BRIM_ERROR, errorMessage, BAN, BussOrg);
                    originalClientReqUdr.response.openAPIUDR = errResponseToClient;
                    originalClientReqUdr.response.statusCode = 400;

                    udrRoute(originalClientReqUdr, "responseToClient");
                    
                    // Log failed ODATA_RESPONSE
                    ConsumeCycleUDR failedOdataResponseLog = sendToSplunk(originalClientReqUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_FAILURE, s4CycleUdr.path, splunkCtx);
                    // Log failed RESPONSE back to client
                    ConsumeCycleUDR failedResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);

                    udrRoute(failedOdataResponseLog, "toSplunk");
                    udrRoute(failedResponseLog, "toSplunk");
                    return;
                }
                
                // Preparing final response payload for client
                CorrespondenceHistoryRequestInfo requestInfoFromClient = udrCreate(CorrespondenceHistoryRequestInfo);
                requestInfoFromClient.billingAccountNumber = BAN;
                requestInfoFromClient.busOrgId = BussOrg;

                responseToClientFinal.responseInfo = responseToClientInfo; 
                responseToClientFinal.requestInfo = requestInfoFromClient;
                originalClientReqUdr.response.openAPIUDR = responseToClientFinal;

                debug("####originalClientReqUdr Towards Client = " + originalClientReqUdr);
                
                ConsumeCycleUDR successfulResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_SUCCESS, null, splunkCtx);

                udrRoute(originalClientReqUdr, "responseToClient");
                udrRoute(successfulResponseLog, "toSplunk");
            }
            // CM received an HTTP response from S4 but path isnt what it expected
           else {
            
            debug("Unexpected ODATA response path or method");

            // Build response for client
            CorrespondenceHistoryResponse errResponseToClient = buildErrResponseForCorr(resourceCode + "50001", "Unexpected ODATA response path", BAN, BussOrg);
            originalClientReqUdr.response.openAPIUDR = errResponseToClient;
            originalClientReqUdr.response.statusCode = 500;

            udrRoute(originalClientReqUdr, "responseToClient");
            
            // Log failed ODATA_RESPONSE
            ConsumeCycleUDR failedOdataResponseLog = sendToSplunk(originalClientReqUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_FAILURE, s4CycleUdr.path, splunkCtx);
            // Log failed RESPONSE back to client
            ConsumeCycleUDR failedResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);

            udrRoute(failedOdataResponseLog, "toSplunk");
            udrRoute(failedResponseLog, "toSplunk");
            return;
        }
        }
        // Input type isnt RequestCycle cant do much here because we dont have access to RequestCycle context
        else {
            log.info("Inside case where Input type is one that we are not expecting");
            log.info("Input value: " + input);
        }
    } catch (ExceptionDetails exception) {

        debug("Exception: " + exception.message);
        RequestCycle originalClientReqUdr = null;
        RequestCycle s4CycleUdr = null;

            if (instanceOf(input, RequestCycle)) {
                s4CycleUdr = (RequestCycle) input;
                originalClientReqUdr = (RequestCycle) s4CycleUdr.context;
            }
            else {
                debug("FATAL: Unable to resolve RequestCycle during exception handling. Original exception: " + exception.message);
                log.error("FATAL: Unable to resolve RequestCycle during exception handling. Original exception: " + exception.message);
            }

            if (originalClientReqUdr != null) {

                string BAN = mapGet(originalClientReqUdr.parameters, "billingAccountNumber");
                string BussOrg = mapGet(originalClientReqUdr.parameters, "busOrgId");

                CorrespondenceHistoryResponse exceptionResponseToClient = buildErrResponseForCorr("50001","Internal processing error", BAN, BussOrg);

                originalClientReqUdr.response.openAPIUDR = exceptionResponseToClient;
                originalClientReqUdr.response.statusCode = 500;

                udrRoute(originalClientReqUdr, "responseToClient");

                // Log failed RESPONSE
                ConsumeCycleUDR exceptionResponseLog = sendToSplunk(originalClientReqUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                udrRoute(exceptionResponseLog, "toSplunk");
    }
}
}

/**
 * Builds a standardized Collection Correspondence error response object.
 *
 * The returned response includes:
 *
 * - Original request identifiers (BAN / BUSSORG)
 * - Error code and error message
 * - Failed transaction status ("F")
 *
 * @param errorCode
 *        Standardized workflow/business error code.
 *
 * @param errorMessage
 *        Human-readable failure description.
 *
 * @param BAN
 *        Billing Account Number associated with the request.
 *
 * @param BussOrg
 *        Business Organization identifier associated with the request.
 *
 * @return
 *        Fully populated failed CorrespondenceHistoryResponse object
 *        ready to attach to the HTTP response lifecycle.
 */
CorrespondenceHistoryResponse buildErrResponseForCorr(string errorCode, string errorMessage, string BAN, string BussOrg) {
   CorrespondenceHistoryResponse response = udrCreate(CorrespondenceHistoryResponse);
   CorrespondenceHistoryRequestInfo requestInfo = udrCreate(CorrespondenceHistoryRequestInfo);

   requestInfo.billingAccountNumber = BAN; // Info represents the request that is throwing this error
   requestInfo.busOrgId = BussOrg;
   response.requestInfo = requestInfo;

   ErrorInfo errUdr = udrCreate(ErrorInfo);

   errUdr.errorCd = errorCode;
   errUdr.errorMessage = errorMessage;

   CorrespondenceHistoryResponseInfo responseInfo = udrCreate(CorrespondenceHistoryResponseInfo);
   responseInfo.transactionStatus = "F";
   responseInfo.errorInfo = errUdr;

   response.responseInfo = responseInfo; // What we are sending back to client
   return response;
}]]></string>
