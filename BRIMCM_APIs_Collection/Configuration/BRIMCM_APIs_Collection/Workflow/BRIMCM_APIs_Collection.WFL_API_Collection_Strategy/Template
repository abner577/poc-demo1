//Payload for History/Get WorkItem
string getHistoryPayload(RequestCycle origReq, StrategyWorkItemHistoryRequestInfo request, string userId) {
    string payload = "{" +
        "\"Userid\": \"" + (string)(userId != null ? userId : "") + "\"," +
        "\"CollectorCUID\": \"" + (string)(request.collectorCUID != null ? request.collectorCUID : "") + "\"," +
        "\"Assignedto\": \"" + (string)(request.assignedTo != null ? request.assignedTo : "") + "\"," +
        "\"Workitemcategory\": \"" + (string)(request.workItemCategory != null ? request.workItemCategory : "") + "\"," +
        "\"Completedby\": \"" + (string)(request.completedBy != null ? request.completedBy : "") + "\"," +
        "\"Strategyid\": \"" + (string)(request.strategyId != null ? request.strategyId : "") + "\"," +
        "\"Workitemnamekey\": \"" + (string)(request.workItemNameKey != null ? request.workItemNameKey : "") + "\"," +
        "\"Createddatefrom\": \"" + (string)(request.createdDateFrom != null ? request.createdDateFrom : "") + "\"," +
        "\"Createddateto\": \"" + (string)(request.createdDateTo != null ? request.createdDateTo : "") + "\"" +
        ",";
    list < string > banList = (list < string > ) origReq.context; //request.billingAccountNumber;
    list < string > dunList = request.dunningLockIndicator;
    list < string > statusList = request.workItemStatus;
    list < StrategyWorkItemDetail > workItemList = request.strategyWorkItemDetails;
    debug("##List Size :" + listSize(request.billingAccountNumber));
    if (listSize(request.billingAccountNumber) > 0) {
        payload = payload + "\"WD_H2_BAN_Nav\" : [ ";
        string Dpayload = "";
        if (listSize(banList) > 0) {
            for (any value: banList) {
                Dpayload = Dpayload + "{" +
                    "\"Ban\" : \"" + (string) value + "\" },";
            }
            Dpayload = strSubstring(Dpayload, 0, strLength(Dpayload) - 1);
            payload = payload + Dpayload + "],";
        }
    }

    if (listSize(dunList) > 0) {
        payload = payload + "\"WD_H2_DI_Nav\" : [ ";
        string Dpayload = "";
        for (any value: dunList) {
            Dpayload = Dpayload + "{" +
                "\"Dunninglockindicator\" : \"" + (string) value + "\" },";
        }
        Dpayload = strSubstring(Dpayload, 0, strLength(Dpayload) - 1);
        payload = payload + Dpayload + "],";
    }

    if (listSize(statusList) > 0) {
        payload = payload + "\"WD_H2_WIS_Nav\" : [ ";
        string Dpayload = "";
        for (any value: statusList) {
            Dpayload = Dpayload + "{" +
                "\"Stat\" : \"" + (string) value + "\" },";
        }
        Dpayload = strSubstring(Dpayload, 0, strLength(Dpayload) - 1);
        payload = payload + Dpayload + "],";
    }

    if (listSize(workItemList) > 0) {
        payload = payload + "\"WD_H2_SWID_Nav\" : [ ";
        string Dpayload = "";
        for (any value: workItemList) {
            Dpayload = Dpayload + "{" +
                "\"Workitemname\" : \"" + (string) value.workItemName + "\"," +
                "\"Strategyname\" : \"" + (string) value.strategyName + "\"},";
        }
        Dpayload = strSubstring(Dpayload, 0, strLength(Dpayload) - 1);
        payload = payload + Dpayload + "],";
    }

    /*payload = payload + "\"WD_H2_WI_NAV\" : { "
         + "\"Agent\" : \"" + (string)(request.assignedTo != null ? request.assignedTo : "") + "\","
         + "\"Wlicat\" : \"" + (string)(request.workItemCategory != null ? request.workItemCategory : "") + "\","
         + "\"Aenam\" : \"" + (string)(request.completedBy != null ? request.completedBy : "") + "\","
         + "\"Strat\" : \"" + (string)(request.strategyId != null ? request.strategyId : "") + "\","
         + "\"Wliguid\" : \"" + (string)(request.workItemNameKey != null ? request.workItemNameKey : "") + "\","
         + "\"Startdate\" : \"" + (string)(request.createdDateFrom != null ? request.createdDateFrom : "") + "\","
         + "\"Enddate\" : \"" + (string)(request.createdDateTo != null ? request.createdDateTo : "") + "\""
         + " },";*/

    payload = payload + "\"WD_H2_WILIST_Nav\" : [ { \"Billingaccountnumber\" : \"\", \"Busorgid\" : \"\", \"Strategyname\" : \"\", \"Workitemname\" : \"\" } ] }";

    return payload;

}

string getDateInFormat(string st) {
    string str = "";
    if (st != null || strLength(strTrim(st)) != 0) {
        str = strSubstring(st, 0, 4) + "-" + strSubstring(st, 4, 6) + "-" + strSubstring(st, 6, 8) + "T" + strSubstring(st, 8, 10) + ":" + strSubstring(st, 10, 12) + ":" + strSubstring(st, 12, 14);
    }
    return str;
}

string formatUUID(string st) {
    string str = "";
    if (st != null || strLength(strTrim(st)) != 0) {
        st = strToUpper(st);
        list < string > listSt = strSplit(st, "-");
        for (string value: listSt) {
            str = str + value;
        }
    }
    return str;
}

string ValidDate(string dt) {
    //validate date if 0 then send ""
    if (strREContains(dt, "0000"))
        return "";
    else
        return dt;
}

CollectionResetResp resetResponse(http.RequestCycle cycleUdr, string sReqBody) {
    CollectionResetResp respUdr = udrCreate(CollectionResetResp);
    CollectionResetResp_ResponseInfo responseUdr = udrCreate(CollectionResetResp_ResponseInfo);
    CollectionResetReq reqUdr = udrCreate(CollectionResetReq);
    jsonDecodeUdr(sReqBody, reqUdr);
    string sErrorMesssage, sRecord;
    try {
        bytearray baRec = (bytearray) cycleUdr.response.body;
        sRecord = baToStr(baRec);
        if (cycleUdr.response.statusCode == 200) {
            map < string, any > mapResponseInfo = (map < string, any > ) jsonParse(sRecord);
            map < string, any > responseInfo = (map < string, any > ) mapGet(mapResponseInfo, "d");
            string errorCd = (string) mapGet(responseInfo, "errorCode");
            if (errorCd != "") {
                ErrorInfo errUdr = udrCreate(ErrorInfo);
                errUdr.errorMessage = (string) mapGet(responseInfo, "errorMessage");;
                errUdr.errorCd = errorCd;
                responseUdr.errorInfo = errUdr;
                responseUdr.transactionStatus = "F";
            } else {
                responseUdr.transactionStatus = "S";
            }
        } else {
            ErrorInfo errUdr = udrCreate(ErrorInfo);
            try {
                map < string, map < string, map < string, string >>> mapErrorInfo = (map < string, map < string, map < string, string >>> ) jsonParse(sRecord);
                map < string, any > mapCode = mapGet(mapErrorInfo, "error");
                map < string, string > mapErrorValue = (map < string, string > ) mapGet(mapCode, "message");
                sErrorMesssage = mapGet(mapErrorValue, "value");
                errUdr.errorCd = "500";
            } catch (ExceptionDetails e) {
                sRecord = (string) cycleUdr.response.body;
                if (cycleUdr.response.statusCode == 401) {
                    sErrorMesssage = "NOT AUTHORIZED IN BRIM";
                } else {
                    sErrorMesssage = sRecord;
                }
                errUdr.errorCd = (string) cycleUdr.response.statusCode;
            }
            errUdr.errorMessage = sErrorMesssage;
            responseUdr.transactionStatus = "F";
            responseUdr.errorInfo = errUdr;
        }
    } catch (ExceptionDetails e) {
        sRecord = (string) cycleUdr.response.body;
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorMessage = sRecord;
        errUdr.errorCd = (string) cycleUdr.response.statusCode;
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        responseUdr.errorInfo = errUdr;
    }

    CollectionResetResp_RequestInfo requestUdr = udrCreate(CollectionResetResp_RequestInfo);
    requestUdr.billingAccountNumber = reqUdr.requestInfo.billingAccountNumber;
    respUdr.requestInfo = requestUdr;
    respUdr.headerInfo = reqUdr.headerInfo;
    respUdr.responseInfo = responseUdr;
    return respUdr;
}


RequestCycle collectionResetReq(string bp, string ca, string userId, map < string, list < string > > mapToken, string stepsFrom, string stepsTo, string fullRest, string inputChannelCd) {
    RequestCycle udr = udrCreate(RequestCycle);
    map < string, string > mapParams = mapCreate(string, string);;
    mapSet(mapParams, "sap-client", getSystemValue(SAP_CLIENT));
    mapSet(mapParams, "format", "json");
    udr.host = getSystemValue(REST_HOSTNAME);
    udr.secure = true;
    udr.port = getSystemValue(REST_PORT);
    udr.path = "/sap/opu/odata/SAP/ZGLB_O2C_FICA_DUNNNOTICE_MAIN_SRV/Reverse?BusinessPartner='" + bp + "'&ContractAccount='" + ca + "'&UserID='" + userId + "'&StepsFrom='" + stepsFrom + "'&StepsTo='" + stepsTo + "'&FullReset='" + fullRest + "'&InputChannelCd='" + inputChannelCd + "'";
    udr.headers = mapToken;
    udr.method = "POST";
    udr.parameters = mapParams;
    return udr;
}

//validation for collection steps retrieve  API
CollectionResetResp validateResetReq(map < string, map < string, string >> Rec, string req, string resourceCode) {
    map < string, any > mapHeaderInfo = mapGet(Rec, "headerInfo");
    map < string, any > mapReqInfo = mapGet(Rec, "requestInfo");

    CollectionResetResp respUdr = udrCreate(CollectionResetResp);
    CollectionResetResp_RequestInfo requestInfoUdr = udrCreate(CollectionResetResp_RequestInfo);
    CollectionResetResp_ResponseInfo responseUdr = udrCreate(CollectionResetResp_ResponseInfo);
    CollectionResetReq reqUdr = udrCreate(CollectionResetReq);
    jsonDecodeUdr(req, reqUdr);

    if (mapGet(mapHeaderInfo, "srcApplicationCd") == "" || mapGet(mapHeaderInfo, "srcApplicationCd") == null) {
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errUdr.errorMessage = "srcApplicationCd IS NULL";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    } else if (mapGet(mapHeaderInfo, "inputChannelCd") == "" || mapGet(mapHeaderInfo, "inputChannelCd") == null) {
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errUdr.errorMessage = "inputChannelCd IS NULL";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    } else if (mapGet(mapHeaderInfo, "userId") == "" || mapGet(mapHeaderInfo, "userId") == null) {
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errUdr.errorMessage = "userId IS NULL";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    } else if (mapGet(mapReqInfo, "billingAccountNumber") == "" || mapGet(mapReqInfo, "billingAccountNumber") == null) {
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errUdr.errorMessage = "billingAccountNumber IS NULL";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    } else if (((mapGet(mapReqInfo, "stepsFrom") == "" && mapGet(mapReqInfo, "stepsTo") == "") ||
            (mapGet(mapReqInfo, "stepsTo") == null && mapGet(mapReqInfo, "stepsDrom") == null)) && mapGet(mapReqInfo, "fullReset") != "Y") {
        ErrorInfo errUdr = udrCreate(ErrorInfo);
        errUdr.errorCd = resourceCode + CM_DATA_VALIDATION_ERROR_CODE;
        errUdr.errorMessage = "Invalid Request for Full Reset";
        responseUdr.errorInfo = errUdr;
        responseUdr.transactionStatus = "F";
        respUdr.responseInfo = responseUdr;
    }

    requestInfoUdr.billingAccountNumber = reqUdr.requestInfo.billingAccountNumber;
    respUdr.requestInfo = requestInfoUdr;
    respUdr.headerInfo = reqUdr.headerInfo;
    return respUdr;
