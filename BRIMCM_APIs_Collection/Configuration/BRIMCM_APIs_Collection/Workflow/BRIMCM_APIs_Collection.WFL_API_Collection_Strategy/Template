void sendToGetCSRF(string sURI, RequestCycle cycle) {
    RequestCycle request = getRequestTokenForCollUp();
    request.path = sURI;
    request.context = cycle;
    debug("###Token request sending to ODATA : " + request);
    udrRoute(request, "toOdata");	
}

void sendToPostWorkItem(string sURI, RequestCycle cycle, string payload) {
    RequestCycle request = getRequestTokenForWorkItem(sURI, cycle.response.headers, cycle);

    strToBA(request.body, payload);
    request.path = sURI;
    request.context = cycle.context;
    debug("### WorkItem request sending to ODATA : " + request);
    log.info("### WorkItem request sending to ODATA : " + request);
    udrRoute(request, "toOdata");
    udrRoute(sendToSplunk(cycle,request,ODATA_REQUEST, "",request.path,splunkCtx),"toSplunk");
      
}

string getPayload(string workItemId, string UserId) {
    string s_workItemId = strSubstring(workItemId, 0, 8) + "-" + strSubstring(workItemId, 8, 12) + "-" + strSubstring(workItemId, 12, 16) + "-" + strSubstring(workItemId, 16, 20) + "-" + strSubstring(workItemId, 20, strLength(workItemId));
    string payload = "{\"Ernam\":\"" + UserId + "\"," +
        "\"WITM_H21_NAV\":" +
        "[" +
        "{" +
        "\"Wliguid\" : \"" + s_workItemId + "\"" +
        "}" +
        "]" +
        "}";
    return payload;
}

