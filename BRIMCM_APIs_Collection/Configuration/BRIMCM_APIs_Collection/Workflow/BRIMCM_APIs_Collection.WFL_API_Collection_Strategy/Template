                        importParams_ZFICAF_GPART_VKONT_DERIVE importUdr = udrCreate(importParams_ZFICAF_GPART_VKONT_DERIVE);
                        importUdr.I_VKONA = mapGet(mapRequestrInfo, "billingAccountNumber");
                        importUdr.I_ACC_HOLDER_ONLY = "X";
                        rfcUdr.importParams = importUdr;
                        rfcUdr.context = cycle;
			udrRoute(rfcUdr, "toRFC");
			ConsumeCycleUDR splunkRfcUdr  = sendRfcToSplunk(cycle, (string)rfcUdr.importParams,RFC_REQUEST, "", "ZFICAF_GPART_VKONT_DERIVE_UDR", splunkCtx);
			udrRoute(splunkRfcUdr,"toSplunk");
                    }
                } catch (ExceptionDetails exception) {
                    debug("exception " + exception);
                }
            } else if (strREIndexOf(cycle.path, "ZGLB_O2C_FICA_DUNNNOTICE_MAIN_SRV") >= 0) {
                if (instanceOf(cycle.context, banRecords)) {
                    banRecords banUdr = (banRecords) cycle.context;
                    RequestCycle cycleUdr = (RequestCycle) banUdr.cycleUdr;
                    string sBody = baToStr(cycleUdr.body);
                    map < string, list < string > > mapToken = APL_CMAPIs.tokenReq(cycle.response.headers); //Creating Headers request with token for POST API CALL  
                    map < string, map < string, string >> mapCollectionReset = (map < string, map < string, string >> ) jsonParse(sBody);
                    map < string, string > headerInfo = mapGet(mapCollectionReset, "headerInfo");
                    map < string, string > requestInfo = mapGet(mapCollectionReset, "requestInfo");
                    RequestCycle reqUdr = collectionResetReq(banUdr.BP, banUdr.CA, mapGet(headerInfo, "userId"), mapToken, mapGet(requestInfo, "stepsFrom"), mapGet(requestInfo, "stepsTo"), mapGet(requestInfo, "fullReset"), mapGet(headerInfo, "inputChannelCd"));
                    reqUdr.context = cycleUdr;
                    udrRoute(reqUdr, "toOdata");
                    
                    ConsumeCycleUDR splunkUdr = sendToSplunk(cycleUdr,reqUdr,ODATA_REQUEST, "",reqUdr.path,splunkCtx);
                    udrRoute(splunkUdr,"toSplunk");
                } else {
                    debug("The value of cycle = " + (cycle));
                    RequestCycle requestCycleUdr = (RequestCycle) cycle.context;
                    CollectionResetResp responseUdr = resetResponse(cycle, (string) requestCycleUdr.body);
                    map < string, list < string > > mapHeaders = mapCreate(string, list < string > );
                    list < string > lHeader = listCreate(string);
                    listAdd(lHeader, "application/json");
                    mapSet(mapHeaders, "Content-Type", lHeader);
                    requestCycleUdr.response.headers = mapHeaders;
                    requestCycleUdr.response.openAPIUDR = responseUdr;
                    udrRoute(requestCycleUdr, "res");
					
                }
            } else if (cycle.path == "/brimcm/collection/strategyworkitem/collectionSteps/retrieve") {
                debug(" resourceCode : " + resourceCode);
                debug("resourceCode+CM_DATA_VALIDATION_ERROR_CODE : " + resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
                string sBody = baToStr(cycle.body);
                map < string, map < string, any >> mapRec = (map < string, map < string, any >> ) jsonParse(sBody);
                openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsResp respUdr = APL_CMAPIs.checkCollectionStepsReq(mapRec, sBody, resourceCode + CM_DATA_VALIDATION_ERROR_CODE);
                if (respUdr.responseInfo != null) {
                    cycle.response.openAPIUDR = respUdr;
                    cycle.response.statusCode = 200;
                    udrRoute(cycle, "res");
		    udrRoute(sendToSplunk(cycle,null, API_RESPONSE ,"", cycle.path, splunkCtx), "toSplunk");
                    return;
                } else {
                    map < string, any > reqInfo = mapGet(mapRec, "requestInfo");
                    map < string, any > headerInfo = mapGet(mapRec, "headerInfo");
                    string sUri = "/sap/opu/odata/sap/ZGLB_DEVFI_DISPLAY_FUTURE_COLL_SRV/CollectionHeaders";
                    string expand = "TOCollStepList,TONonEssenColl,TOEssenColl";
                    string filter = "BAN eq '" + mapGet(reqInfo, "billingAccountNumber") + "'";
                    http.RequestCycle reqUDR = getS4DetailsWithFilter(sUri, expand, filter);
                    reqUDR.context = cycle;
                    ConsumeCycleUDR splunkUdr = sendToSplunk(reqUDR,null,ODATA_REQUEST, "",cycle.path,splunkCtx);
                    udrRoute(splunkUdr,"toSplunk");
                    udrRoute(reqUDR, "toOdata");
                }
            } else if (strREIndexOf(cycle.path, "ZGLB_DEVFI_DISPLAY_FUTURE_COLL_SRV") >= 0) {
                debug("Inside POST Call");
                RequestCycle reqUdr = (RequestCycle) cycle.context;
                resourceCode = getXrefValue(RESOURCE_CODE_TABLE, reqUdr.path);
                string sReqBody, sResponseBody;
                sReqBody = baToStr(reqUdr.body);
                bytearray baRecord = (bytearray) cycle.response.body;
                sResponseBody = baToStr(baRecord);
                openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsReq collectionStepsReq = udrCreate(openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsReq);
                jsonDecodeUdr(sReqBody, collectionStepsReq);
                openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsResp collectionStepsResp = udrCreate(openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsResp);
                openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsResp_responseInfo responseUdr = udrCreate(openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.CollectionStepsResp_responseInfo);
                collectionStepsResp.requestInfo = collectionStepsReq.requestInfo;
                collectionStepsResp.headerInfo = collectionStepsReq.headerInfo;
                try {
                    map < string, any > response = (map < string, any > ) jsonParse(sResponseBody);
                    map < string, any > collectionStepsRespFullDetails = (map < string, any > ) mapGet(response, "d");
                    list < map < string, any >> collectionStepsDetailsList = (list < map < string, any >> ) mapGet(collectionStepsRespFullDetails, "results");
                    map < string, any > collectionStepsDetails = listGet(collectionStepsDetailsList, 0);

                    string transactionStatus = (string) mapGet(collectionStepsDetails, "TransactionStatus");

                    debug("before success condition");
                    if (transactionStatus == "S") {
                        debug("Inside 200 success condition");
                        collectionStepsResp = mapCollectionStepsSuccessResponse(response, collectionStepsReq);
			status = API_STATUS_SUCCESS;
                    } else if (transactionStatus == "F") {
                        debug("inside else condition of status code 200");
			status = API_STATUS_FAILURE;
                        collectionStepsResp = mapCollectioStepsFailureResponse(response, collectionStepsReq, resourceCode + BRIM_ERROR);
                    } else {
                        openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.ErrorInfo errUdr = udrCreate(openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.ErrorInfo);
                        errUdr.errorCd = resourceCode + BRIM_ERROR;

                        errUdr.errorMessage = sResponseBody != null && strREContains(sResponseBody, "The OData request processing") ? "The OData request processing has been abnormally terminated" : sResponseBody;
                        responseUdr.transactionStatus = "F";
                        responseUdr.errorInfo = errUdr;
                        collectionStepsResp.responseInfo = responseUdr;
			status = API_STATUS_FAILURE;
                    }
                } catch (ExceptionDetails e) {
                    openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.ErrorInfo errUdr = udrCreate(openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_Collection_Strategy.ErrorInfo);
                    errUdr.errorCd = resourceCode + BRIM_ERROR;
					status = API_STATUS_FAILURE;
                    errUdr.errorMessage = sResponseBody != null && strREContains(sResponseBody, "The OData request processing") ? "The OData request processing has been abnormally terminated" : sResponseBody;
                    responseUdr.transactionStatus = "F";
                    responseUdr.errorInfo = errUdr;
                    collectionStepsResp.responseInfo = responseUdr;
                }
				
                //debug("Response in POST Call : "+response);

                map < string, list < string > > mapHeaders = mapCreate(string, list < string > );
                list < string > lHeader = listCreate(string);
                listAdd(lHeader, "application/json");
                mapSet(mapHeaders, "Content-Type", lHeader);
                reqUdr.response.headers = mapHeaders;
                reqUdr.response.openAPIUDR = collectionStepsResp;
                reqUdr.response.statusCode = 200;
                udrRoute(reqUdr, "res");
		ConsumeCycleUDR splunkUdr = sendToSplunk(reqUdr,null,API_RESPONSE, status,cycle.path,splunkCtx);
                udrRoute(splunkUdr,"toSplunk");
            }

        } else if (instanceOf(input, ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR)) {

            debug("RFC response received: " + input);
            log.info("RFC response received for strategeyWorkItem retrieve API: " + input);
            ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr = (ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR) input;

            RequestCycle cycle = (RequestCycle) rfcUdr.context;
            resourceCode = getXrefValue(RESOURCE_CODE_TABLE, cycle.path);
            if (udrIsPresent(rfcUdr.exportParams.ET_ERROR)) { //failure
                string errorMsg;
                list < ZFIT_VKONA_ERR_MSG > etError = rfcUdr.exportParams.ET_ERROR;
                log.error("etError - " + etError);
                if (!isEmpty(etError[0].E_ERROR_MSG))
                    errorMsg = etError[0].E_ERROR_MSG;
                debug("The value of ErrorMsg = " + (errorMsg));


                string sBody = baToStr(cycle.body);
                StrategyWorkItemHistoryRequest historyUDR = udrCreate(StrategyWorkItemHistoryRequest);
                jsonDecodeUdr(sBody, historyUDR);
                debug("###historyUDR object ------ >> " + historyUDR);
                debug("received RFC response is not as expected: " + input);
                sendHistoryErrorResponse(historyUDR, cycle, errorMsg, resourceCode + BRIM_ERROR);
                ConsumeCycleUDR splunkUdr = sendToSplunk(cycle,null,RFC_RESPONSE,API_STATUS_FAILURE,cycle.path,splunkCtx);
                udrRoute(splunkUdr,"toSplunk");
            } else if (udrIsPresent(rfcUdr.exportParams.ET_GPART_VKONT)) { //success
                list < ZFITT_OUTPUT_BILL > liBill = rfcUdr.exportParams.ET_GPART_VKONT;
                list < string > rfcList = listCreate(string);
                for (ZFITT_OUTPUT_BILL bill: liBill) {
                    listAdd(rfcList, bill.VKONT);
                }
                cycle.context = rfcList;
                string sURI = "/sap/opu/odata/sap/ZGLB_DEVFI_STRAT_WORK_ITEM_SRV/WORK_DUNN_HEADERSet";
                sendToGetCSRF(sURI, cycle);
				
                udrRoute(sendToSplunk(cycle,null,RFC_RESPONSE,API_STATUS_SUCCESS,cycle.path,splunkCtx),"toSplunk");
            }
        } else if (instanceOf(input, ZFICAF_GPART_VKONT_DERIVE_UDR)) {
            ZFICAF_GPART_VKONT_DERIVE_UDR rfcUdr = (ZFICAF_GPART_VKONT_DERIVE_UDR) input;
            debug("The value of rfcUdr = " + (rfcUdr));
            RequestCycle cycleUdr = (RequestCycle) rfcUdr.context;
            exportParams_ZFICAF_GPART_VKONT_DERIVE exportUdr = rfcUdr.exportParams;
            banRecords banUdr = udrCreate(banRecords);
            for (FKKVKP_KEY_T udr: exportUdr.ET_GPART_VKONT) {
                banUdr.BP = udr.GPART;
                banUdr.CA = udr.VKONT;
                break;
            }
            banUdr.cycleUdr = cycleUdr;
            string sURI = "/sap/opu/odata/sap/ZGLB_O2C_FICA_DUNNNOTICE_MAIN_SRV/$metadata";
            http.RequestCycle reqUDR = APL_CMAPIs.accessTokenReq(sURI);
            reqUDR.context = banUdr;
            udrRoute(reqUDR, "toOdata");
	    ConsumeCycleUDR splunkRfcUdr  = sendRfcToSplunk(cycleUdr, (string)rfcUdr.importParams,RFC_REQUEST, "", "ZFICAF_GPART_VKONT_DERIVE_UDR", splunkCtx);
            udrRoute(splunkRfcUdr,"toSplunk");
        }
    } catch (ExceptionDetails exception) {
        debug("Not of RequestCycle" + exception);
    }
}

