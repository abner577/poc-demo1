RequestCycle getRequestTokenForWorkItem(string sURI, map < string, list < string > > responseHeader, RequestCycle cycle) {
    RequestCycle udr = udrCreate(RequestCycle);
    RequestCycle originalRequest = (RequestCycle) cycle.context;


    string sBody = baToStr(originalRequest.body);
    map < string, map < string, any >> mapRec = (map < string, map < string, any >> ) jsonParse(sBody);

    map < string, any > headerInfo = mapGet(mapRec, "headerInfo");
    long top;
    if (null != mapGet(headerInfo, "pageSize"))
        top = (long) headerInfo.pageSize;
    debug("value of top : " + top);
    long pageNumber;
    if (null != mapGet(headerInfo, "pageNumber"))
        pageNumber = (long) headerInfo.pageNumber;
    debug("Value of pageNumber : " + pageNumber);
    long skip;
    skip = (pageNumber - 1) * top;
    debug("Value of skip : " + skip);
    map < string, string > mapParams = mapCreate(string, string);
    mapSet(mapParams, "sap-client", getSystemValue(SAP_CLIENT));
    // mapSet(mapParams,"$format","json");
    udr.host = getSystemValue(REST_HOSTNAME);
    udr.secure = true;
    udr.port = getSystemValue(REST_PORT);
    udr.path = sURI;
    udr.method = "POST";
    udr.headers = headerForWorkItem(responseHeader, top, skip);
    udr.parameters = mapParams;
    return udr;
}

map < string, list < string > > headerForWorkItem(map < string, list < string > > responseHeader, long top, long skip) {
    map < string, list < string > > mapToken = mapCreate(string, list < string > );
    list < string > contentType = listCreate(string);
    list < string > topString = listCreate(string);
    list < string > skipString = listCreate(string);
    listAdd(contentType, "application/json");

    mapSet(mapToken, "x-csrf-token", mapGet(responseHeader, "x-csrf-token"));
    mapSet(mapToken, "Content-Type", contentType);
    mapSet(mapToken, "Accept", contentType);

    listAdd(topString, (string) top);
    listAdd(skipString, (string) skip);
    mapSet(mapToken, "$top", topString);
    mapSet(mapToken, "$skip", skipString);

    return mapToken;
}

boolean validateRequest(StrategyWorkItemHistoryRequestInfo request) {
    list < string > banList = request.billingAccountNumber;
    list < string > dunList = request.dunningLockIndicator;
    list < string > statusList = request.workItemStatus;
    list < StrategyWorkItemDetail > workItemList = request.strategyWorkItemDetails;
    if (listSize(banList) < 0 && listSize(dunList) < 0 && listSize(statusList) < 0 && listSize(workItemList) < 0) {
        return false;
    }
    return true;
}

