string API_TAXONLY_EMAIL_DIR =   externalReferenceGet("Common.DB_External_Reference","API_TAXONLY_EMAIL_DIR");

string fileName, zipFileName;

initialize{
    sender = externalReferenceGet("Utility.EXT_REF_AUDIT_REPORT","REPORT_EMAIL_SENDER");
    envName = externalReferenceGet("Utility.EXT_REF_AUDIT_REPORT","ENV_NAME");
}
beginBatch{
    //Get email from file name
    string inputFilename = (string)mimGet("Collection","Source Filename");
    debug("inputFileName = " + inputFilename);
    int idx = strIndexOf(inputFilename, "_");
    string email = strSubstring(inputFilename, 0, idx);
    fileName =  strSubstring(inputFilename, idx+1, strLength(inputFilename));
    zipFileName = fileName  + ".zip";
    debug("Email = " + email + " fileName = " + fileName);
    
    ScriptResult sr = scriptExec("cp " +   API_TAXONLY_EMAIL_DIR+ "/" + inputFilename  +  " " +  API_TAXONLY_EMAIL_DIR+ "/" + fileName);
    
    
    sr = scriptExec("/bin/zip -j " +   API_TAXONLY_EMAIL_DIR+ "/" + zipFileName  +  " " +  API_TAXONLY_EMAIL_DIR+ "/" + fileName);
    if(sr.hasMZError || sr.ExitValue != 0) {
        abort("Error while zip the tax report file");
    } else {
        list<string> liMailFiles = listCreate(string);
        listAdd(liMailFiles, API_TAXONLY_EMAIL_DIR+ "/" + zipFileName);
        mailNotify(email,envName + " tax report " + fileName, "Hello, \n\nPlease find the attached tax report "+ fileName +" \n\nNote: This is a system generated email. Please do not reply to this message.",sender,liMailFiles);
    }
}

consume {    
}

drain{
    //Delete the zip file
    fileDelete(API_TAXONLY_EMAIL_DIR+ "/" + fileName);
    fileDelete(API_TAXONLY_EMAIL_DIR+ "/" + zipFileName);
}]]></string>
