/*
============================================================================
Aggregation Agent

This agent coordinates the /create Promise To Pay path. It keeps the original
client request in session memory, sends the RFC and S4/OData requests, receives
session updates from the inspect agents, and builds the final client response.

This agent handles these transaction lifecycle stages:

1. RFC_REQUEST
   - Builds and sends the RFC request used to derive CA and BP details for the create request.

2. ODATA_REQUEST
   - Sends the S4 GET request used to fetch the CSRF token/header.
   - Sends the final S4 POST request used to create the Promise To Pay record.

3. RESPONSE
   - Builds the final client response for successful create processing.
   - Builds error responses when RFC or S4/OData processing fails.

Important session statuses handled in this agent:

- RECEIVED
  - A new create request has entered the aggregation path and the session has
    been initialized.

- REQUESTING_RFC
  - The agent has started downstream lookup processing and is preparing the RFC
    request.

- RFC_RESPONSE
  - The RFC response was received and mapped by Inspect_RFC_Resp, so the agent
    can now build the S4 CSRF-token GET request.

- RFC_ERROR_RESPONSE
  - The RFC returned an error, so the agent stops normal processing and builds
    an error response back to the client.

- CSRF_TOKEN_RECEIVED
  - The S4 GET token response was received, so the agent can now build and send
    the actual S4 POST create request.

- P2P_CREATE_RESPONSE
  - The final S4 POST create response was received, so the agent can map the S4
    result into the final client response.

- ODATA_ERROR_RESPONSE
  - An S4/OData error occurred, so the agent builds an error response back to
    the client.
============================================================================
*/


SplunkContext splunkCtx;


initialize {
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string )mimGet("Workflow", "Execution Context");
    splunkCtx.workflowName = (string) mimGet("Workflow", "Workflow Name");
    splunkCtx.agentName = (string) mimGet("Aggregation", "Agent Name");    
}


sessionInit {

    session.status = "RECEIVED";
    session.request = input.request;
    session.timeReceived = input.timeReceived;
    session.uuidKey = input.uuidKey;
    session.requestObj = input.requestObj;
    session.responseObj = input.responseObj;
    session.counter = 0;

    debug("Step 1: Initiated Session for the below request---->>");
    debug("Session Id :: " + session.uuidKey + " Status:: " + session.status); 

    sessionTimeout(session, 1000);
}

// Consume block is mainly used to advance the session through the downstream steps
// sessionTimeout(session, -1); --> Means to stop waiting and immediately jump to the timeout block so we can finish this session and send the final response
consume {
    debug("Input -- " + input);

    session.status = input.status;

    RequestCycle originalClientCycleUdr = (RequestCycle) session.request;

    /******STAGE 2: Build and send RFC_REQUEST for create Promise to Pay******/
    if (input.status == "RECEIVED") {
        session.status = "REQUESTING_RFC";

        /************START OF DEVELOPMENT OF CREATE P2P****************/
        if (instanceOf(session.requestObj, CreatePromiseToPayRequest)) {
            CreatePromiseToPayResponse respItem = (CreatePromiseToPayResponse) session.responseObj;

            debug("###p2p respItem object ------ >> " + respItem);

            list<PromiseToPayDetailResponse> p2pResList = respItem.promiseToPay.promiseToPayDetails;

            // Preparing request object for RFC_REQUEST
            ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr = udrCreate(ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR);
            rfcUdr.importParams = udrCreate(importParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT);
            rfcUdr.context = session.uuidKey;
            rfcUdr.importParams.IT_VKONA = listCreate(ZFITT_VKONA);

            debug("### listSize(p2pResList: " + listSize(p2pResList));

            for (int i = 0; i < listSize(p2pResList); i++) {
                PromiseToPayDetailResponse resUdr = listGet(p2pResList, i);

                if (isEmpty(resUdr.errorInfo.errorMessage)) {
                    debug("###Inside resUdr.errorInfo != null - ");

                    ZFITT_VKONA bill = udrCreate(ZFITT_VKONA);
                    bill.VKONA = resUdr.billingAccountNumber;

                    listAdd(rfcUdr.importParams.IT_VKONA, bill);
                }
            }

            debug("request to RFC: " + rfcUdr);
            udrRoute(rfcUdr, "reqToRfc");

            // Splunk log RFC_REQUEST before sending account lookup request to BRIM
            ConsumeCycleUDR rfcRequestLog = sendRfcToSplunk(originalClientCycleUdr, (string) rfcUdr.importParams, RFC_REQUEST, "", "ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR", splunkCtx);
            udrRoute(rfcRequestLog, "toSplunk");
        }
        /************END OF DEVELOPMENT OF CREATE P2P****************/
    }

    /******STAGE 3: Handle RFC error response state******/
    if (input.status == "RFC_ERROR_RESPONSE") {
        session.rfcRequestResponse = input.rfcRequestResponse;
        session.rfcErrors = input.rfcErrors;
        session.inputError = true;
 
        // Splunk log RFC_RESPONSE failure after receiving the processed RFC error response from Inspect_RFC_Resp
        ConsumeCycleUDR rfcErrorResponseLog = sendRfcToSplunk(originalClientCycleUdr, (string) session.rfcErrors, RFC_RESPONSE, API_STATUS_FAILURE, "ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR", splunkCtx);
        udrRoute(rfcErrorResponseLog, "toSplunk");

        sessionTimeout(session, -1);
    }

    /******STAGE 3: Receive RFC_RESPONSE and build ODATA CSRF-token GET request******/
    if (input.status == "RFC_RESPONSE") {
        debug("###Session : " + session);
        debug("Step 3: Response received from RFC ---->>> ");

        if (instanceOf(session.requestObj, CreatePromiseToPayRequest)) {
            session.DetailList = input.DetailList;
            session.caBAN = input.caBAN;
            session.rfcRequestResponse = input.rfcRequestResponse;

            // Splunk log RFC_RESPONSE success after receiving the processed RFC response from Inspect_RFC_Resp
            ConsumeCycleUDR rfcSuccessResponseLog = sendRfcToSplunk(originalClientCycleUdr, (string) session.rfcRequestResponse, RFC_RESPONSE, API_STATUS_SUCCESS, "ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR", splunkCtx);
            udrRoute(rfcSuccessResponseLog, "toSplunk");

            string sURI = "/sap/opu/odata/SAP/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/CR_P2P_HEADSet";
            RequestCycle request = sendToGetCSRF(sURI, session.request, session.uuidKey);

            udrRoute(request, "reqToS4");
            log.info("Calling ODATA for CSRF Token");
        }
    }

    /******STAGE 4: Receive CSRF token and build ODATA create POST request******/
    if (input.status == "CSRF_TOKEN_RECEIVED") {
        session.responseHeader = input.responseHeader;

        if (instanceOf(session.requestObj, CreatePromiseToPayRequest)) {
            string sURI = "/sap/opu/odata/SAP/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/CR_P2P_HEADSet";

            RequestCycle odataGetResponseCycle = udrCreate(RequestCycle);
            odataGetResponseCycle.path = sURI;
            odataGetResponseCycle.method = "GET";
            odataGetResponseCycle.context = session.uuidKey;
            odataGetResponseCycle.body = input.s4ResponseBody;
            odataGetResponseCycle.response.body = input.s4ResponseBody;
            odataGetResponseCycle.response.headers = input.responseHeader;
           
           if (input.s4ResponseStatus == "200") {
                log.info("Received 200 for ODATA CSRF call");

                CreatePromiseToPayResponse respUdr = (CreatePromiseToPayResponse) session.responseObj;

                // Build the create POST payload from the prepared response object and RFC detail list
                string payload = getCreatePayload(respUdr.headerInfo, respUdr.promiseToPay, session.DetailList);

                debug("payload - " + payload);

                RequestCycle request = sendToCreateP2P(sURI, session.request, payload, session.responseHeader);
                request.context = session.uuidKey;

                debug("###request for Post call :" + request);
                udrRoute(request, "reqToS4");

                // Splunk log ODATA_REQUEST before sending the actual create POST request to S4
                ConsumeCycleUDR odataPostRequestLog = sendToSplunk(originalClientCycleUdr, request, ODATA_REQUEST, "", sURI, splunkCtx);
                udrRoute(odataPostRequestLog, "toSplunk");

            // Error case where the CSRF-token GET response was not successful
            } else {
                session.responseDescription = "Unknown Error while fetching CSRF token from S4";
                session.status = "ODATA_ERROR_RESPONSE";

                log.info("Received non-200 for ODATA CSRF call");

                sessionTimeout(session, -1);
            }
        }
    }

    /******STAGE 5: Receive ODATA_RESPONSE for create Promise to Pay POST******/
    if (input.status == "P2P_CREATE_RESPONSE") {
        string sURI = "/sap/opu/odata/SAP/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/CR_P2P_HEADSet";

        RequestCycle odataPostResponseCycle = udrCreate(RequestCycle);
        odataPostResponseCycle.path = sURI;
        odataPostResponseCycle.method = "POST";
        odataPostResponseCycle.context = session.uuidKey;
        odataPostResponseCycle.body = input.s4ResponseBody;
        odataPostResponseCycle.response.body = input.s4ResponseBody;

        if (input.s4ResponseStatus == "200" || input.s4ResponseStatus == "201") {
            // send success -- mapping each CA with BAN
            session.status = input.status;
            session.s4ResponseStatus = input.s4ResponseStatus != null ? input.s4ResponseStatus : "";
            session.s4ResponseBody = input.s4ResponseBody;

            // Splunk log ODATA_RESPONSE SUCCESS (POST)
            ConsumeCycleUDR odataPostResponseLog = sendToSplunk(originalClientCycleUdr, odataPostResponseCycle, ODATA_RESPONSE, API_STATUS_SUCCESS, sURI, splunkCtx);
            udrRoute(odataPostResponseLog, "toSplunk");

            // Once you receive the final response we timeout, in the timeout handle the client response.
            sessionTimeout(session, -1);

        // Error case where S4 did not return a successful create response
        } else {
            session.responseDescription = "Unknown Error while creating P2P in S4";
            session.status = "ODATA_ERROR_RESPONSE";

            // Splunk log ODATA_RESPONSE FAILURE (POST)
            ConsumeCycleUDR odataPostResponseLog = sendToSplunk(originalClientCycleUdr, odataPostResponseCycle, ODATA_RESPONSE, API_STATUS_FAILURE, sURI, splunkCtx);
            udrRoute(odataPostResponseLog, "toSplunk");
        }

        sessionTimeout(session, -1);
    }

    /******STAGE 5: Handle ODATA error response state******/
    if (input.status == "ODATA_ERROR_RESPONSE") {
        session.status = "ODATA_ERROR_RESPONSE";
        session.responseDescription = input.responseDescription;
        session.inputError = true;

        string sURI = "/sap/opu/odata/SAP/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/CR_P2P_HEADSet";

        RequestCycle odataErrorResponseCycle = udrCreate(RequestCycle);
        odataErrorResponseCycle.path = sURI;
        odataErrorResponseCycle.context = session.uuidKey;
        odataErrorResponseCycle.body = input.s4ResponseBody;
        odataErrorResponseCycle.response.body = input.s4ResponseBody;

        // Splunk log ODATA_RESPONSE failure
        ConsumeCycleUDR odataErrorResponseLog = sendToSplunk(originalClientCycleUdr, odataErrorResponseCycle, ODATA_RESPONSE, API_STATUS_FAILURE, sURI, splunkCtx);
        udrRoute(odataErrorResponseLog, "toSplunk");

        sessionTimeout(session, -1);
    }
}

// Timeout block is where the session gets finalized and the response is sent back to the client.
timeout {
    debug("Step 6: Timeout block");
    debug("Session Id :: " + session.uuidKey + " Status:: " + session.status);

    string sBody;
    string resourceCode;

    RequestCycle cycleUdr = (RequestCycle) session.request;
    resourceCode = getXrefValue(RESOURCE_CODE_TABLE, cycleUdr.path);

    /******STAGE 6: Send final RESPONSE for RFC error******/
    if (session.status == "RFC_ERROR_RESPONSE") {
        RFCRequestResponse requestRes = udrCreate(RFCRequestResponse);
        requestRes = listGet(session.rfcErrors, 0);

        string errorMsg = requestRes.errorMsg;

        if (instanceOf(session.requestObj, CreatePromiseToPayRequest)) {
            CreatePromiseToPayResponse respUdr = (CreatePromiseToPayResponse) session.responseObj;

            debug("###respUdr object ------>> " + respUdr);

            cycleUdr = sendP2PCreateErrorResponse(respUdr, cycleUdr, errorMsg, resourceCode + BRIM_ERROR);

            udrRoute(cycleUdr, "respToClient");

            // Splunk log RESPONSE failure after the client-facing RFC error response is populated
            ConsumeCycleUDR errorResponseLog = sendToSplunk(cycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
            udrRoute(errorResponseLog, "toSplunk");
        }
    }

    /******STAGE 6: Send final RESPONSE for ODATA error******/
    if (session.status == "ODATA_ERROR_RESPONSE") {
        debug("###Inside timeout ODATA response");

        if (instanceOf(session.requestObj, CreatePromiseToPayRequest)) {
            CreatePromiseToPayResponse respUdr = (CreatePromiseToPayResponse) session.responseObj;

            debug("###respUdr object ------>> " + respUdr);

            cycleUdr = sendP2PCreateErrorResponse(respUdr, cycleUdr, session.responseDescription, resourceCode + BRIM_ERROR);

            udrRoute(cycleUdr, "respToClient");

            // Splunk log RESPONSE failure after the client-facing ODATA error response is populated
            ConsumeCycleUDR errorResponseLog = sendToSplunk(cycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
            udrRoute(errorResponseLog, "toSplunk");
        }
    }

    /******STAGE 6: Build and send final RESPONSE for create Promise to Pay******/
    if (session.status == "P2P_CREATE_RESPONSE") {
        CreatePromiseToPayResponse respUdr = (CreatePromiseToPayResponse) session.responseObj;
        string sResponseBody = baToStr(session.s4ResponseBody);

        // Parse the S4 response body so the final client response can be mapped by contract account and Promise To Pay date
        map<string, any> response = (map<string, any>) jsonParse(sResponseBody);
        map<string, any> mapD = (map<string, any>) mapGet(response, "d");

        debug("###Coverted Map -->" + mapD);

        map<string, any> mapItemsmsg = (map<string, any>) mapGet(mapD, "Itemsmsg");
        list<any> listResult = (list<any>) mapGet(mapItemsmsg, "results");

        debug("###Converted Results to List -->" + listResult);

        map<string, list<string>> outMap = mapCreate(string, list<string>);

        for (any value : listResult) {
            list<string> stList = listCreate(string);

            listInsert(stList, 0, (string) value.PromiseToPayId);
            listInsert(stList, 1, (string) value.MsgId);
            listInsert(stList, 2, (string) value.Message);

            mapSet(outMap, ((string) value.ContractAccount + (string) value.PromiseToPayDate), stList);
        }

        respUdr = finalCreateResponsePayload(respUdr, session.DetailList, outMap, resourceCode + BRIM_ERROR);

        // If all success, then only transanction status as S, else F
        if (allSuccess(respUdr.promiseToPay.promiseToPayDetails)) {
            respUdr.promiseToPay.transactionStatus = "S";
            cycleUdr.response.statusCode = 200;

        // Error case where at least one Promise to Pay detail did not succeed
        } else {
            respUdr.promiseToPay.transactionStatus = "F";
            cycleUdr.response.statusCode = 400;
        }

        cycleUdr.response.openAPIUDR = respUdr;
        cycleUdr.response.headers = APL_FUNCTIONS.getHeader();
        cycleUdr.response.openAPIUDR = respUdr;

        udrRoute(cycleUdr, "respToClient");

        // Splunk log RESPONSE success/failure based on the final client response status
        if (cycleUdr.response.statusCode == 200) {
            ConsumeCycleUDR successResponseLog = sendToSplunk(cycleUdr, null, API_RESPONSE, API_STATUS_SUCCESS, null, splunkCtx);
            udrRoute(successResponseLog, "toSplunk");

        // Error case where the final client response status is not successful
        } else {
            ConsumeCycleUDR failureResponseLog = sendToSplunk(cycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
            udrRoute(failureResponseLog, "toSplunk");
        }
    }

    // Finally remove the session from memory INC7413761
    sessionRemove(session);
