                  <string name="sourceCode"><![CDATA[import ultra.http;
import ultra.json;
import ultra.openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_API_Collection_PromiseToPay;
import apl.BRIMCM_APIs_Common.APL_FUNCTIONS;
import ultra.BRIMCM_APIs_Common.ULF_CMAPIs;
import apl.BRIMCM_APIs_Collection.APL_Collection_PromiseToPay;
import apl.Common.APL_LOGGING;
import ultra.Common.UFL_API_LogFormat;
import ultra.Common.ULF_Logging;
import ultra.wfb;
import apl.Common.APL_CONSTANTS;

/*
============================================================================
Analysis_Response Agent

This agent handles S4/OData responses for the /history and /withdraw endpoints.

This agent handles these transaction lifecycle stages:

1. ODATA_RESPONSE
   - For /history, receives the S4 GET response containing Promise To Pay
     history data.
   - For /withdraw, receives the S4 GET token response.
   - For /withdraw, receives the final S4 POST response after the withdraw
     request is submitted.

2. ODATA_REQUEST
   - For /withdraw, builds the actual S4 POST request after the CSRF token/header
     has been received from the first GET call.

3. RESPONSE
   - Builds the final client response for /history.
   - Builds the final client response for /withdraw.
   - Handles S4/OData error responses and maps them back to the client response.
============================================================================
*/


string PATH_COLLECTION_P2P_WITHDRAW_ODATA_GET;
string PATH_COLLECTION_P2P_HISTORY_ODATA_GET;
SplunkContext splunkCtx;


initialize {
    PATH_COLLECTION_P2P_WITHDRAW_ODATA_GET = "/sap/opu/odata/sap/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/WITHDRAWN_P2PSet";
    PATH_COLLECTION_P2P_HISTORY_ODATA_GET = "/sap/opu/odata/sap/ZGLB_DEVFI_PROMISE_TO_PAY_SRV/GET_P2P_HEADSet";
    
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string)mimGet("Workflow","Execution Context");
    splunkCtx.workflowName = (string)mimGet("Workflow", "Workflow Name");
    splunkCtx.agentName = (string)mimGet("Analysis_Response", "Agent Name");    
}


consume {
    try {
        if (instanceOf(input, RequestCycle)) {
            RequestCycle s4CycleUdr = (RequestCycle) input;
            RequestCycle originalClientRequestUdr = (RequestCycle) s4CycleUdr.context;

            debug("Analysis_Response received S4/OData RequestCycle response: " + s4CycleUdr);
            
            /*****P2P Withdraw ODATA CSRF GET Call Response*****/
            if (strREContains(s4CycleUdr.path, PATH_COLLECTION_P2P_WITHDRAW_ODATA_GET) && s4CycleUdr.method == "GET") {
                debug("Processing Promise To Pay withdraw CSRF-token GET response from S4.");
                debug("Withdraw CSRF-token GET response status code: " + s4CycleUdr.response.statusCode);

                if ((string) s4CycleUdr.response.statusCode == "200") {
                    debug("Promise To Pay withdraw CSRF-token GET response succeeded. Preparing withdraw POST request.");

                    if (s4CycleUdr.context == null ) {
                        debug("Promise To Pay withdraw CSRF-token GET response is missing original client request context: " + s4CycleUdr);
                        log.info("Promise To Pay withdraw CSRF-token GET response is missing original client request context.");
                    }

                    // We are pulling the CSRF token values from the GET response headers and attaching it to the POST request
                    map <string, list<string>> mapToken = APL_Collection_PromiseToPay.tokenReq(s4CycleUdr.response.headers);

                    // Builds the S4 POST request for withdraw
                    http.RequestCycle reqUDRForPost = APL_Collection_PromiseToPay.prepareWithdrawPostCall(PATH_COLLECTION_P2P_WITHDRAW_ODATA_GET, (RequestCycle) s4CycleUdr.context, mapToken);
                    reqUDRForPost.context = s4CycleUdr.context;

                    debug("Prepared Promise To Pay withdraw POST request for S4: " + reqUDRForPost);
                    udrRoute(reqUDRForPost, "postReqToS4");

                    // Splunk log ODATA_REQUEST for withdraw actual POST request
                    ConsumeCycleUDR odataPostRequestLog = sendToSplunk(originalClientRequestUdr, reqUDRForPost, ODATA_REQUEST, "", reqUDRForPost.path, splunkCtx);
                    udrRoute(odataPostRequestLog, "toSplunk");

                    return;
                } 
                // Error case for token request. ODATA responded with non-200 status
                else {
                    debug("Promise To Pay withdraw CSRF-token GET request failed. Status code: " + s4CycleUdr.response.statusCode);
                    log.info("Promise To Pay withdraw CSRF-token GET request failed. Status code: " + s4CycleUdr.response.statusCode);

                    bytearray bArespBody = (bytearray) s4CycleUdr.response.body;
                    ErrorInfo errInfo = udrCreate(ErrorInfo);

                    map<string,map<string,map<string,string>>> mapErrorInfo = (map<string,map<string,map<string,string>>>)jsonParse((string)bArespBody);
                    map<string,any> mapCode = mapGet(mapErrorInfo, "error");
                    map<string,string> mapErrorValue = (map<string,string>) mapGet(mapCode, "message");

                    string sErrorMesssage = mapGet(mapErrorValue, "value");

                    debug("Promise To Pay withdraw CSRF-token GET error message from S4: " + sErrorMesssage);
                    log.info("Promise To Pay withdraw CSRF-token GET error message from S4: " + sErrorMesssage);

                    errInfo.errorCd = "40621";
                    errInfo.errorMessage = sErrorMesssage;
                    
                    WithdrawPromiseToPayRequest request = udrCreate(WithdrawPromiseToPayRequest) ;
                    jsonDecodeUdr(baToStr(originalClientRequestUdr.body), request);

                    WithdrawPromiseToPayResponse finalResponse = udrCreate(WithdrawPromiseToPayResponse);
                    WithdrawPromiseToPayResponseInfo status = udrCreate(WithdrawPromiseToPayResponseInfo);
                    
                    status.transactionStatus = "F";
                    status.errorInfo = errInfo;

                    finalResponse.headerInfo = request.headerInfo;
                    finalResponse.requestInfo = request.requestInfo;
                    finalResponse.responseInfo = status;

                    originalClientRequestUdr.response.openAPIUDR = finalResponse;
                    originalClientRequestUdr.response.statusCode = 400;

                    debug("Returning Promise To Pay withdraw failure response to client because CSRF-token GET request failed.");
                    log.info("Returning Promise To Pay withdraw failure response to client because CSRF-token GET request failed.");

                    udrRoute(originalClientRequestUdr, "respToClient");

                    // Splunk logging for ODATA_RESPONSE and RESPONSE FAILURE cases

                    ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientRequestUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                    udrRoute(errorResponseLog, "toSplunk");

                    return;
                }
            } 
            /*****P2P Withdraw ODATA POST Call Response*****/
            else if (strREContains(s4CycleUdr.path, PATH_COLLECTION_P2P_WITHDRAW_ODATA_GET) && s4CycleUdr.method == "POST") {
                    debug("Processing Promise To Pay withdraw POST response from S4.");
                    debug("Withdraw POST response status code: " + s4CycleUdr.response.statusCode);

                    originalClientRequestUdr = (RequestCycle) s4CycleUdr.context;
                    WithdrawPromiseToPayRequest request = udrCreate(WithdrawPromiseToPayRequest);
                    jsonDecodeUdr(baToStr(originalClientRequestUdr.body), request);

                    debug("Original Promise To Pay withdraw client request body: " + baToStr(originalClientRequestUdr.body));
                    debug("Promise To Pay withdraw POST response body from S4: " + baToStr(s4CycleUdr.body));
                   
                    WithdrawPromiseToPayResponse finalResponse  = udrCreate(WithdrawPromiseToPayResponse);

                    finalResponse.headerInfo = request.headerInfo;
                    finalResponse.requestInfo = request.requestInfo;
                    
                    WithdrawPromiseToPayResponseInfo status = udrCreate(WithdrawPromiseToPayResponseInfo);

                    status.transactionStatus = strStartsWith((string)s4CycleUdr.response.statusCode, "2")? "S":"F";

                    if (status.transactionStatus == "F") {
                        debug("Promise To Pay withdraw POST request failed. Status code: " + s4CycleUdr.response.statusCode);
                        log.info("Promise To Pay withdraw POST request failed. Status code: " + s4CycleUdr.response.statusCode);

                        bytearray bArespBody = (bytearray) s4CycleUdr.response.body;
                        ErrorInfo errInfo = udrCreate(ErrorInfo);

                        map<string,map<string,map<string,string>>> mapErrorInfo = (map<string,map<string,map<string,string>>>)jsonParse((string)bArespBody);
                        map<string,any> mapCode = mapGet(mapErrorInfo, "error");
                        map<string,string> mapErrorValue = (map<string,string>) mapGet(mapCode,"message");

                        string sErrorMesssage = mapGet(mapErrorValue, "value");

                        debug("Promise To Pay withdraw POST error message from S4: " + sErrorMesssage);
                        log.info("Promise To Pay withdraw POST error message from S4: " + sErrorMesssage);

                        if (strREContains(sErrorMesssage, "already Withdrawn")) {
                            errInfo.errorCd = "40621";//P2P already withdrawn
                        } else {
                            errInfo.errorCd = "40621";//unknown error
                        }

                        errInfo.errorMessage = sErrorMesssage;
                        status.errorInfo = errInfo;
                        
                        finalResponse.responseInfo = status;
                        originalClientRequestUdr.response.openAPIUDR = finalResponse;
                        originalClientRequestUdr.response.statusCode = 400;

                        debug("Returning Promise To Pay withdraw failure response to client because POST request failed.");
                        log.info("Returning Promise To Pay withdraw failure response to client because POST request failed.");

                        udrRoute(originalClientRequestUdr, "respToClient");

                        // Splunk log ODATA_RESPONSE failure for withdraw POST response
                        ConsumeCycleUDR odataPostResponseLog = sendToSplunk(originalClientRequestUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_FAILURE, s4CycleUdr.path, splunkCtx);
                        udrRoute(odataPostResponseLog, "toSplunk");

                        // Splunk log RESPONSE failure for final withdraw response
                        ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientRequestUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                        udrRoute(errorResponseLog, "toSplunk");

                        return;
                    }

                    originalClientRequestUdr.response.statusCode = 200;
                    finalResponse.responseInfo = status;
                    originalClientRequestUdr.response.openAPIUDR = finalResponse;

                    debug("Promise To Pay withdraw POST request succeeded. Returning success response to client.");
                    debug("Final Promise To Pay withdraw response: " + originalClientRequestUdr.response);

                    udrRoute(originalClientRequestUdr, "respToClient");

                    // Splunk log ODATA_RESPONSE success for withdraw POST response
                    ConsumeCycleUDR odataPostResponseLog = sendToSplunk(originalClientRequestUdr, s4CycleUdr, ODATA_RESPONSE, API_STATUS_SUCCESS, s4CycleUdr.path, splunkCtx);
                    udrRoute(odataPostResponseLog, "toSplunk");

                    // Splunk log RESPONSE success for final withdraw response
