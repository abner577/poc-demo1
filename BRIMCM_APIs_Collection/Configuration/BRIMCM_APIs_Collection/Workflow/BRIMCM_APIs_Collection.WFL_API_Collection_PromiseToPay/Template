                            originalClientCycleUdr.response.openAPIUDR = p2pFinalResp;  
                            originalClientCycleUdr.response.statusCode = 400;

                            debug("Returning Promise To Pay history failure response to client because contract account was missing from RFC response.");
                            log.info("Returning Promise To Pay history failure response to client because contract account was missing from RFC response.");

                            udrRoute(originalClientCycleUdr, "respToClient");

                            // Splunk logging for RFC_RESPONSE Failure case and RESPONSE Failure case
                            ConsumeCycleUDR rfcResponseLog = sendRfcToSplunk(originalClientCycleUdr, (string) rfcCycleUdr.exportParams, RFC_RESPONSE, API_STATUS_FAILURE, "ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR", splunkCtx);
                            udrRoute(rfcResponseLog, "toSplunk");

                            ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientCycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                            udrRoute(errorResponseLog, "toSplunk");

                            return; 
                        }
                        
                        PromiseToPayRequest  p2pRequestUDR = udrCreate(PromiseToPayRequest);
                        jsonDecodeUdr(baToStr(originalClientCycleUdr.body), p2pRequestUDR);
                       
                        PromiseToPayRequestInfo p2pRequestInfo = p2pRequestUDR.requestInfo;
                        BRIMCM_APIs_Collection.PRF_OPENAPI_API_Collection_PromiseToPay.HeaderInfo headerInfo = p2pRequestUDR.headerInfo;

                        debug("busPartner = " + busPartner + "::contractAcc = " + contractAcc + "::busOrg = " + bussOrg + "::BAN = " + BAN);

                        // Checking if client busOrgId matches with business org returned by RFC
                        if (!isEmpty(p2pRequestInfo.busOrgId) && !strEqualsIgnoreCase(p2pRequestInfo.busOrgId, bussOrg)) {
