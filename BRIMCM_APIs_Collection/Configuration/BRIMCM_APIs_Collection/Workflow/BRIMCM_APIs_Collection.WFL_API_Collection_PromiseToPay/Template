/*
============================================================================
Inspect_S4_Resp Agent

This agent handles S4/OData responses for the /create Promise To Pay aggregation
path. It inspects both the CSRF-token GET response and the final POST create
response, then sends a session update back to the Aggregation agent.

This agent handles this transaction lifecycle stage:

1. ODATA_RESPONSE
   - Receives the S4 GET response used to fetch the CSRF token/header.
   - Receives the S4 POST response from the actual Promise To Pay create call.

Session statuses produced by this agent:

- CSRF_TOKEN_RECEIVED
  - The S4 GET token response was received, and Aggregation can now build the
    actual S4 POST create request.

- P2P_CREATE_RESPONSE
  - The final S4 POST create response was received, and Aggregation can now
    build the final client response.

- ODATA_ERROR_RESPONSE
  - The S4/OData call failed or timed out, and Aggregation should build an
    error response back to the client.

NOTE:
This agent does not send the final response to the client. It only inspects
S4/OData responses and routes the result back to Aggregation.
============================================================================
*/

SplunkContext splunkCtx;

initialize {
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string) mimGet("Workflow", "Execution Context");
    splunkCtx.workflowName = (string) mimGet("Workflow", "Workflow Name");
    splunkCtx.agentName = (string) mimGet("Inspect_S4_Resp", "Agent Name");    
}

consume {
    debug("[Inspect_S4_Resp][PROCESSING] Input received: " + input);

    if (instanceOf(input, RequestCycle)) {
        RequestCycle cycleUdr = (RequestCycle) input;

        debug("[Inspect_S4_Resp][ODATA_RESPONSE] Response path received from S4: " + cycleUdr.path);

        if (strREContains(cycleUdr.path, "ZGLB_DEVFI_PROMISE_TO_PAY_SRV/CR_P2P_HEADSet")) {

            /******STAGE 1: Receive S4 ODATA_RESPONSE******/
            promiseToPay_session sessionUdr = udrCreate(promiseToPay_session);
            sessionUdr.uuidKey = (string) cycleUdr.context;
            sessionUdr.s4ResponseStatus = (string) cycleUdr.response.statusCode;

            if (instanceOf(cycleUdr.response.body, bytearray)) {
                sessionUdr.s4ResponseBody = (bytearray) cycleUdr.response.body;
            }

            debug("[Inspect_S4_Resp][ODATA_RESPONSE] Response body received from S4: " + baToStr((bytearray) cycleUdr.response.body));

            /******STAGE 2: Update session status from S4 response method******/

            if (cycleUdr.method == "GET") {
                sessionUdr.status = "CSRF_TOKEN_RECEIVED";
                sessionUdr.responseHeader = cycleUdr.response.headers;

            } else if (cycleUdr.method == "POST") {
                sessionUdr.status = "P2P_CREATE_RESPONSE";
            }

            /******STAGE 3: Handle S4 ODATA error response******/

            if (cycleUdr.response.body != null) {
                // Error case where S4 returned a timeout message
                if (strREContains((string) cycleUdr.response.body, "Total timeout 30000 ms elapsed")) {
                    debug("[Inspect_S4_Resp][ERROR] S4 ODATA response failed because the request timed out.");
                    log.warn("[Inspect_S4_Resp][ERROR] S4 ODATA response failed because the request timed out.");

                    sessionUdr.responseDescription = (string) cycleUdr.body;
                    sessionUdr.status = "ODATA_ERROR_RESPONSE";

                // Error case where S4 returned a non-success status
                } else if (!(cycleUdr.response.statusCode == 200 || cycleUdr.response.statusCode == 201)) {
                    debug("[Inspect_S4_Resp][ERROR] S4 ODATA response returned a non-success status, mapping error message.");
                    log.warn("[Inspect_S4_Resp][ERROR] S4 ODATA response returned a non-success status, mapping error message.");

                    // Decode the S4 error body and pull the nested error.message.value field
                    JsonObject json = (JsonObject) jsonDecode(baToStr((bytearray) cycleUdr.response.body));
                    map<string, any> responseMap = json.asMap;

                    json = (JsonObject) mapGet(responseMap, "error");
                    responseMap = json.asMap;

                    json = (JsonObject) mapGet(responseMap, "message");
                    responseMap = json.asMap;

                    string errMsg = (string) mapGet(responseMap, "value");

                    sessionUdr.responseDescription = errMsg;
                    sessionUdr.status = "ODATA_ERROR_RESPONSE";
                }
            }

            /******STAGE 4: Route updated session back to Aggregation******/

            udrRoute(sessionUdr, "toAgg");

            debug("[Inspect_S4_Resp][SESSION] Session UDR routed to Aggregation: " + sessionUdr);
            debug("[Inspect_S4_Resp][SESSION] Sent session object toAgg.");
        }
    }
}]]></string>
