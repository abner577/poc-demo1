            }          
        }       
     }
     // Encountered some unknown error in some unknown state
      catch (ExceptionDetails exception) {
        debug("Exception in Analysis_Request while processing Promise To Pay request :: " + exception);
        log.info("Exception in Analysis_Request while processing Promise To Pay request :: " + exception);


