            // RFC Response returned an unsupported Promise To Pay path
            else {
                debug("Unexpected RFC response received in Analysis_Request for unsupported Promise To Pay path: " + originalClientCycleUdr.path);
                log.info("Unexpected RFC response received in Analysis_Request for unsupported Promise To Pay path: " + originalClientCycleUdr.path);

                originalClientCycleUdr = setP2PGeneralErrorResponse(originalClientCycleUdr, resourceCode + CM_DATA_VALIDATION_ERROR_CODE,
                    "Unexpected account lookup response received for unsupported Promise To Pay request path", 500);
