                    ConsumeCycleUDR rfcResponseLog = sendRfcToSplunk(originalClientCycleUdr, (string) rfcCycleUdr.exportParams, RFC_RESPONSE, API_STATUS_FAILURE, "ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR", splunkCtx);
                    udrRoute(rfcResponseLog, "toSplunk");

                    ConsumeCycleUDR errorResponseLog = sendToSplunk(originalClientCycleUdr, null, API_RESPONSE, API_STATUS_FAILURE, null, splunkCtx);
                    udrRoute(errorResponseLog, "toSplunk");

                    return;
                }
