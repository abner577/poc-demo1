/*
============================================================================
Inspect_RFC_Resp Agent

This agent handles RFC responses for the /create Promise To Pay aggregation
path. It inspects the SAP RFC result, maps the returned account data or errors,
and sends a session update back to the Aggregation agent.

This agent handles this transaction lifecycle stage:

1. RFC_RESPONSE
   - Receives the RFC response from SAP_RFC.
   - Checks whether RFC returned account mapping data or error data.

Session statuses produced by this agent:

- RFC_RESPONSE
  - RFC returned usable account mapping data and Aggregation can continue to
    the S4/OData token request.

- RFC_ERROR_RESPONSE
  - RFC returned an error and Aggregation should build an error response back
    to the client.

NOTE:
This agent does not build the final client response. It only prepares the
RFC result as a session update and routes it back to Aggregation.
============================================================================
*/

SplunkContext splunkCtx;

initialize {
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string) mimGet("Workflow", "Execution Context");
    splunkCtx.workflowName = (string) mimGet("Workflow", "Workflow Name");
    splunkCtx.agentName = (string) mimGet("Inspect_RFC_Resp", "Agent Name");
}

consume {
    debug("[Inspect_RFC_Resp][PROCESSING] Received response for inspection.");

    if (instanceOf(input, ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR)) {
        debug("[Inspect_RFC_Resp][RFC_RESPONSE] RFC response input received: " + input);

        /******STAGE 1: Receive RFC_RESPONSE******/

        ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR rfcUdr = (ZFICAF_DERIVE_ACTIVE_ACCOUNT_UDR) input;
        exportParams_ZFICAF_DERIVE_ACTIVE_ACCOUNT tableParams = rfcUdr.exportParams;

        debug("[Inspect_RFC_Resp][SESSION] RFC UDR context value: " + rfcUdr.context);
        debug("[Inspect_RFC_Resp][RFC_RESPONSE] Input object being inspected: " + input);

        promiseToPay_session sessionUdr = udrCreate(promiseToPay_session);
        sessionUdr.uuidKey = (string) rfcUdr.context;
        sessionUdr.rfcRequestResponse = listCreate(RFCRequestResponse);

        debug("[Inspect_RFC_Resp][SESSION] Created Promise To Pay session UDR.");
        debug("[Inspect_RFC_Resp][SESSION] Session UUID key: " + sessionUdr.uuidKey);
        debug("[Inspect_RFC_Resp][RFC_RESPONSE] RFC ET_ERROR row count: " + listSize(tableParams.ET_ERROR));
        debug("[Inspect_RFC_Resp][RFC_RESPONSE] RFC ET_GPART_VKONT row count: " + listSize(tableParams.ET_GPART_VKONT));
        debug("[Inspect_RFC_Resp][SESSION] Initialized RFC request-response list on session UDR.");
        debug("[Inspect_RFC_Resp][RFC_RESPONSE] Determining RFC response status.");

        sessionUdr.status = listSize(tableParams.ET_ERROR) == 0 ? "RFC_RESPONSE" : "RFC_ERROR_RESPONSE";

        debug("[Inspect_RFC_Resp][SESSION] Session status after RFC inspection: " + sessionUdr.status);

        /******STAGE 2: Map RFC error rows when present******/

        if (listSize(tableParams.ET_ERROR) > 0) {
            debug("[Inspect_RFC_Resp][ERROR] RFC response contains error rows.");

            for (ZFIT_VKONA_ERR_MSG item : tableParams.ET_ERROR) {
                debug("[Inspect_RFC_Resp][ERROR] Processing RFC error row: " + item);

                RFCRequestResponse requestRes = udrCreate(RFCRequestResponse);
                requestRes.ban = item.VKONA;
                requestRes.errorMsg = item.E_ERROR_MSG;

                debug("[Inspect_RFC_Resp][ERROR] Built RFC error response entry: " + requestRes);
                debug("[Inspect_RFC_Resp][ERROR] Adding RFC error response entry to session UDR.");

                listAdd(sessionUdr.rfcErrors, requestRes);

                debug("[Inspect_RFC_Resp][ERROR] Added RFC error response entry to session UDR.");
            }

            debug("[Inspect_RFC_Resp][ERROR] Finished processing RFC error rows.");
        }

        /******STAGE 3: Map successful RFC account rows when present******/

        if (listSize(tableParams.ET_GPART_VKONT) > 0) {
            sessionUdr.caBAN = mapCreate(string, string);
            sessionUdr.DetailList = mapCreate(string, list<string>);

            for (ZFITT_OUTPUT_BILL item : tableParams.ET_GPART_VKONT) {
                debug("[Inspect_RFC_Resp][RFC_RESPONSE] Processing RFC account detail row: " + item);

                RFCRequestResponse requestRes = udrCreate(RFCRequestResponse);
                requestRes.ban = item.BAN;
                requestRes.contractAccount = item.VKONT;
                requestRes.bussOrg = item.BUSS_ORG;
                requestRes.businessPartner = item.GPART;

                listAdd(sessionUdr.rfcRequestResponse, requestRes);

                // Store contract account and business partner details by BAN for downstream processing
                list<string> caBP = listCreate(string);
                listInsert(caBP, 0, requestRes.contractAccount);
                listInsert(caBP, 1, requestRes.businessPartner);
                mapSet(sessionUdr.DetailList, requestRes.ban, caBP);
            }
        }

        /******STAGE 4: Route updated session back to Aggregation******/

        debug("[Inspect_RFC_Resp][SESSION] Final session UDR before routing to Aggregation: " + sessionUdr);
        debug("[Inspect_RFC_Resp][SESSION] Routing session UDR toAgg with status: " + sessionUdr.status);

        udrRoute(sessionUdr, "toAgg");
    }
