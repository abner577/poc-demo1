                  <string name="sourceCode"><![CDATA[import ultra.http;
import ultra.json;
import ultra.openapi.BRIMCM_APIs_Collection.PRF_OPENAPI_API_Collection_PromiseToPay;
import apl.BRIMCM_APIs_Common.APL_FUNCTIONS;
import ultra.BRIMCM_APIs_Common.ULF_CMAPIs;
import apl.BRIMCM_APIs_Collection.APL_Collection_PromiseToPay;
import apl.Common.APL_LOGGING;
import ultra.Common.UFL_API_LogFormat;
import apl.Common.APL_CONSTANTS;
import ultra.Common.ULF_Logging;
import ultra.wfb;
import ultra.BRIMCM_APIs_Collection.ULF_Collection_PromiseToPay;

/*
============================================================================
Collect Agent

This agent is the first processing point after the client HTTP request enters
the workflow. It identifies which Promise To Pay endpoint was called and routes
the request to the correct workflow branch.

This agent handles these transaction lifeclientCycleUdr stages:

1. REQUEST
   - Logs the original client HTTP request.
   - Routes /create requests to the Aggregation path.
   - Routes /history and /withdraw requests to the top/direct path.

2. RESPONSE
   - Handles early validation error responses for create requests before the
     request is sent downstream.
============================================================================
*/


string PATH_COLLECTION_P2P_WITHDRAW;
string PATH_COLLECTION_P2P_CREATE;
string PATH_COLLECTION_P2P_HISTORY;
SplunkContext splunkCtx;

initialize {
    PATH_COLLECTION_P2P_WITHDRAW = "/brimcm/collection/promisetopay/withdraw";
    PATH_COLLECTION_P2P_CREATE = "/brimcm/collection/promisetopay/create";
    PATH_COLLECTION_P2P_HISTORY = "/brimcm/collection/promisetopay/history";
   
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string)mimGet("Workflow","Execution Context");
    splunkCtx.workflowName = (string)mimGet("Workflow", "Workflow Name");
    splunkCtx.agentName = (string)mimGet("Collect", "Agent Name");    
}

consume {

    try {
       
        string resourceCode;
        string str_tagId;
           
        if (instanceOf(input,RequestCycle)) {
            RequestCycle clientCycleUdr = (RequestCycle) input;
            
            resourceCode = getXrefValue(RESOURCE_CODE_TABLE, clientCycleUdr.path);
            str_tagId = setTagId(clientCycleUdr);

            ConsumeCycleUDR clientRequestLog = sendToSplunk(clientCycleUdr, null, API_REQUEST, "", null, splunkCtx);
            udrRoute(clientRequestLog, "toSplunk");

            debug("The value of str_tagId = " + (str_tagId));
            string sBody;

            if(clientCycleUdr.body != null) {
                sBody = baToStr(clientCycleUdr.body);
                any Rec = jsonParse(sBody);
                debug("Rec: " + Rec);

                /******Create P2P Path******/
                if (clientCycleUdr.path == PATH_COLLECTION_P2P_CREATE) {
                    debug("###Inside Create P2P path");

                    CreatePromiseToPayRequest p2pUdr = udrCreate(CreatePromiseToPayRequest);
                    jsonDecodeUdr(sBody, p2pUdr);

