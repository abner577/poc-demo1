            resourceCode = getXrefValue(RESOURCE_CODE_TABLE, originalClientCycleUdr.path);

            if(originalClientCycleUdr.body != null) {
                sBody = baToStr(originalClientCycleUdr.body);
                Rec = jsonParse(sBody);

                debug("sBody: " + sBody);
                debug("Rec: " + Rec);
            }

            if (originalClientCycleUdr.path == PATH_COLLECTION_P2P_HISTORY) {
                debug("The value of rfcCycleUdr [Analysis_Request] = " + (rfcCycleUdr));

                string busPartner, contractAcc, bussOrg, BAN, sURI;

                if (udrIsPresent(rfcCycleUdr.exportParams.ET_GPART_VKONT)) {
                    list<ZFITT_OUTPUT_BILL> liBill = rfcCycleUdr.exportParams.ET_GPART_VKONT;

                    for (ZFITT_OUTPUT_BILL bill : liBill) {
                            busPartner = bill.GPART;
                            contractAcc = bill.VKONT;
                            bussOrg = bill.BUSS_ORG;
                        }

                        // Error case where CA is empty
                        if (isEmpty(contractAcc)) {
                            debug("Promise To Pay history request failed: RFC response did not return a contract account.");
                            log.info("Promise To Pay history request failed: RFC response did not return a contract account.");

