        /*
        Some unexpected UDR reached this catch block. Since we do not have a
        RequestCycle, we cannot safely build a client response or Splunk RESPONSE log.
        */
        else {
            debug("FATAL: Unable to resolve RequestCycle during Analysis_Request exception handling. Original exception: " + exception.message);
