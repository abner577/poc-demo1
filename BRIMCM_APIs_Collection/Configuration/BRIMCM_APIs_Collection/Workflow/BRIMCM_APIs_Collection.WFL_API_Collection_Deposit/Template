SplunkContext splunkCtx;

initialize{
    splunkCtx = udrCreate(SplunkContext);
    splunkCtx.pico = (string)mimGet("Workflow","Execution Context");
    splunkCtx.workflowName = (string)mimGet("Workflow" , "Workflow Name");
    splunkCtx.agentName = (string)mimGet("response" , "Agent Name");
}

consume {
    try{
        string resourceCode;
        if(instanceOf(input,RequestCycle)){
            RequestCycle cycleUdr = (RequestCycle)input;
            debug("The value of cycleUdr = " + (cycleUdr));
            RequestCycle reqUdr = (RequestCycle)cycleUdr.context;
            string sReqBody,sResponseBody;
            if(reqUdr.body != null){
                sReqBody = baToStr(reqUdr.body);
            }
            
            resourceCode = getXrefValue(RESOURCE_CODE_TABLE,reqUdr.path);
            if(strREContains(cycleUdr.path, "/sap/opu/odata/SAP/ZGLB_DEVFI_SECURITY_DEPOSIT_SRV/requestInfoSet") && cycleUdr.method == "GET"){
                debug("Inside deposit history API GET call");
                try{
                    bytearray baRecord = (bytearray)cycleUdr.response.body;
                    sResponseBody = baToStr(baRecord);   
                }catch(ExceptionDetails e){
                    sResponseBody = "Timeout Occured in BRIM";
                }               
                map<string,any> response = (map<string,any>)jsonParse(sResponseBody);
                DepositHistoryRequest depositHistoryReq = udrCreate(DepositHistoryRequest);
                jsonDecodeUdr(sReqBody,depositHistoryReq);
                DepositHistoryResponse depositHistoryResp = udrCreate(DepositHistoryResponse);
                DepositHistoryResponseInfo responseUdr = udrCreate(DepositHistoryResponseInfo);                
                depositHistoryResp.headerInfo = depositHistoryReq.headerInfo;
                depositHistoryResp.requestInfo = depositHistoryReq.requestInfo;
                //debug("cycleUdr.response.statusCode : "+cycleUdr.response.statusCode);
                string status;
                if(cycleUdr.response.statusCode == 200){
                    debug("Inside 200 success condition");
                    depositHistoryResp = mapDepositHistorySuccessResponse(response,depositHistoryReq,resourceCode);
                    debug("depositHistoryResp.responseInfo.transactionStatus : "+depositHistoryResp.responseInfo.transactionStatus);
                    //Added extra condition to check Success or Failure in statusCode 200 condition as its expected to receive RFC errors too under statusCode 200
                    if(depositHistoryResp.responseInfo.transactionStatus == "S") {
                        status = API_STATUS_SUCCESS;
                    } else {
                        status = API_STATUS_FAILURE;
                    }
                } else {
                    debug("inside else condition of status code 200");
                    depositHistoryResp = mapDepositHistoryFailureResponse(response, depositHistoryReq, resourceCode);  
                    status = API_STATUS_FAILURE;                   
                }
                reqUdr.response.openAPIUDR = depositHistoryResp;
                reqUdr.response.statusCode = 200;
                //logResponse(reqUdr, ""); 
                udrRoute(reqUdr,"toClient");
                //Forwarding ODATA response log towards Splunk
                udrRoute(sendToSplunk(reqUdr,cycleUdr,ODATA_RESPONSE, status,cycleUdr.path,splunkCtx),"toSplunk");
                //Forwarding response log towards Splunk
                udrRoute(sendToSplunk(reqUdr,null,API_RESPONSE, status,null,splunkCtx),"toSplunk");
            } else if(cycleUdr.path == "/sap/opu/odata4/sap/api_casecuritydeposit/srvd_a2x/sap/casecuritydeposit/0002/$metadata" && cycleUdr.method == "GET"){
                  debug("Inside POST call for deposit release API");
                  map<string,list<string> > mapToken = tokenReq(cycleUdr.response.headers); //Creating Headers request with token for POST API CALL  
                  map<string, map<string,string>> mapInputRequestDetails = (map<string, map<string,string>>)jsonParse(sReqBody);
                  http.RequestCycle udr = mapDepositReleaseDetails(mapToken,mapInputRequestDetails);
                  udr.context = reqUdr;
                  udrRoute(udr,"toS4");
                  //Forwarding ODATA request log towards Splunk
                  udrRoute(sendToSplunk(reqUdr,udr,ODATA_REQUEST,"",udr.path,splunkCtx),"toSplunk"); 
            } else if(strREContains(cycleUdr.path, "/sap/opu/odata4/sap/api_casecuritydeposit/srvd_a2x/sap/casecuritydeposit/0002") && cycleUdr.method == "POST"){
                debug("Inside response for deposit release API POST call");
                try{
                    bytearray baRecord = (bytearray)cycleUdr.response.body;
                    sResponseBody = baToStr(baRecord);   
                }catch(ExceptionDetails e){
                    sResponseBody = (string)cycleUdr.response.body;
                }
                
                map<string,any> response = (map<string,any>)jsonParse(sResponseBody);
                DepositReleaseRequest releaseReq = udrCreate(DepositReleaseRequest); 
                jsonDecodeUdr(sReqBody,releaseReq);
                DepositReleaseResponse releaseResp = udrCreate(DepositReleaseResponse);
                
                DepositReleaseResponseInfo responseUdr = udrCreate(DepositReleaseResponseInfo);
                releaseResp.requestInfo = releaseReq.requestInfo;
                releaseResp.headerInfo = releaseReq.headerInfo;
                debug("cycleUdr.response.statusCode : "+cycleUdr.response.statusCode);
                string status;
                if(cycleUdr.response.statusCode == 200  ){
                    responseUdr.transactionStatus = "S";
                    status = API_STATUS_SUCCESS;
                }else{
                    status = API_STATUS_FAILURE;
                    ErrorInfo errUdr = udrCreate(ErrorInfo);
                    
                    map<string,string> mapCode = (map<string,string>)mapGet(response,"error");
                    //debug("mapCode : "+mapCode);
  
                    //debug("error Message : "+mapGet(mapCode,"message"));
                    errUdr.errorMessage = mapGet(mapCode,"message");
                    //debug("errUdr.errorMessage after assigning : "+errUdr.errorMessage);
                    errUdr.errorCd = resourceCode + BRIM_ERROR;
                    responseUdr.transactionStatus = "F";
                    responseUdr.errorInfo = errUdr;
                }
                releaseResp.responseInfo = responseUdr;
                //debug("The value of releaseResp = " + (releaseResp));
                reqUdr.response.openAPIUDR = releaseResp;
                reqUdr.response.statusCode = 200;
               // logResponse(reqUdr, "");
                udrRoute(reqUdr,"toClient");
                //Forwarding ODATA response log towards Splunk
                udrRoute(sendToSplunk(reqUdr,cycleUdr,ODATA_RESPONSE, status,cycleUdr.path,splunkCtx),"toSplunk");
                //Forwarding response log towards Splunk
                udrRoute(sendToSplunk(reqUdr,null,API_RESPONSE, status,null,splunkCtx),"toSplunk");                
            }
        }else{
             debug("In else part : "+input);
        }
    }catch(ExceptionDetails e){
        debug("Exception occured : "+e.stackTrace);
    }
