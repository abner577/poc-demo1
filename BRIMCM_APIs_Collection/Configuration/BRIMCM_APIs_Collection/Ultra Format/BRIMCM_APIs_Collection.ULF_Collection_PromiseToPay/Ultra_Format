internal p2pGetUltra{
    list<BrimRespResultsL1> resultsL1;
};

internal BrimRespResultsL1{
    string ContractAccount;
    string BusinessPartner;
    ultra_P2P_HEAD2BAN_NAV obj_P2P_HEAD2BAN_NAV;
};

internal ultra_P2P_HEAD2BAN_NAV{
    list<BrimRespResultsL2> resultsL2;
};

internal BrimRespResultsL2{
    string BillingAccountNumber;
    string FinanceAccountNumber;
    string BusOrgId;
    string ContractAccount;
    string CurrencyCd;
    ultra_P2P_BAN2PAYD_NAV obj_P2P_BAN2PAYD_NAV;
};

internal ultra_P2P_BAN2PAYD_NAV{
    string createdBy;
    string createdDttm;
    string lastModifiedBy;
    string lastModifiedDttm;
    string promiseToPayConfirmationId;
    string promiseToPayDate;
    string status;
    string paymentMethodCd;
    string maskedAccountNumber;
    string bankAccountType;
    string cardType;
    string totalPromiseAmount;
    string brokenAmount;
    ultra_P2P_PAYD2INV_NAV obj_P2P_PAYD2INV_NAV;
};

