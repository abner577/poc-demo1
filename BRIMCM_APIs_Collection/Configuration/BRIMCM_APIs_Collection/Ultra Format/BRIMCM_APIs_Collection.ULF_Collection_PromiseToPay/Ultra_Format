};
// Modified from TestBranch
internal BrimRespResultsL3{
    string InvoiceNo;
    string InvoiceDt;
    string InvoiceDueDt;
    string PromiseAmount;
};

// Generic Promise To Pay error response used for unexpected technical errors.
// This is mainly intended for catch-block failures where we may not safely know
// whether the request was create, history, or withdraw.
internal p2pGeneralErrorResponse {
    p2pGeneralErrorRequestInfo requestInfo;
    p2pGeneralErrorResponseInfo responseInfo;
};

internal p2pGeneralErrorRequestInfo {
    string billingAccountNumber;
    string busOrgId;
};

internal p2pGeneralErrorResponseInfo {
    string transactionStatus;
    p2pGeneralErrorInfo errorInfo;
};

internal p2pGeneralErrorInfo {
    string errorCd;
    string errorMessage;
};]]></string>
