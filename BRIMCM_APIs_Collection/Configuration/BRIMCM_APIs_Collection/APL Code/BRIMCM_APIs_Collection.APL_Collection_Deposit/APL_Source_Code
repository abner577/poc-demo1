//function to call partial release or full release for security deposit towards S4
http.RequestCycle mapDepositReleaseDetails(map<string,list<string>> mapheaders, map<string, map<string,string>> depositReleaseDetails){
    DepositReleaseRequestInfo releaseUdr = udrCreate(DepositReleaseRequestInfo);
    http.RequestCycle udr = udrCreate(http.RequestCycle);

    map<string,string> mapReqInfo = (map<string,string>) mapGet(depositReleaseDetails,"requestInfo");
    
    string isPartial = mapGet(mapReqInfo,"isPartial");
    string depositId = mapGet(mapReqInfo,"depositId");
    
    //debug("isPartial : "+isPartial);
    //debug("depositId : "+depositId);
    
    if(isPartial == "Y"){
        debug("Inside isPartial Y condition");
        string depositAmount = !isEmpty(mapGet(mapReqInfo,"toBeReleasedDepositAmt")) ? getAmount(mapGet(mapReqInfo,"toBeReleasedDepositAmt")):"";
        double dDepositAmount;
        if(!isEmpty(depositAmount)) {
            strToDouble(dDepositAmount,depositAmount);
        }
        string currency = mapGet(mapReqInfo,"currencyCd");
        
        map<string,any> partialMap = mapCreate(string,any);
        
        mapSet(partialMap,"CAToBeReldAmtInPaymentCurrency",dDepositAmount);
        mapSet(partialMap,"TransactionCurrency",currency);
        mapSet(partialMap,"CAPaymentMethod","");
        //debug("partialMap : "+partialMap);
        
        udr.host = getSystemValue(REST_HOSTNAME);
        udr.secure = true;
        udr.port = getSystemValue(REST_PORT);
        udr.path = "/sap/opu/odata4/sap/api_casecuritydeposit/srvd_a2x/sap/casecuritydeposit/0002/CASecurityDeposit('"+depositId+"')/SAP__self.ReleasePartially";
        udr.headers = mapheaders;
        udr.method = "POST";
        string sRequest =  jsonEncodeMap(partialMap);
        strToBA(udr.body,sRequest);
        map<string,string> mapParams = mapCreate(string,string);
        mapSet(mapParams,"sap-client",getSystemValue(SAP_CLIENT));
        mapSet(mapParams,"format","json");
    } else if(isPartial == "N"){
        debug("Inside isPartial N condition");
        
        udr.host = getSystemValue(REST_HOSTNAME);
        udr.secure = true;
        udr.port = getSystemValue(REST_PORT);
        udr.path = "/sap/opu/odata4/sap/api_casecuritydeposit/srvd_a2x/sap/casecuritydeposit/0002/CASecurityDeposit('"+depositId+"')/SAP__self.Release";
        udr.headers = mapheaders;
        udr.method = "POST";
        string sRequest = "";
        strToBA(udr.body,sRequest);
        map<string,string> mapParams = mapCreate(string,string);
        mapSet(mapParams,"sap-client",getSystemValue(SAP_CLIENT));
        mapSet(mapParams,"format","json");
    }
    
   return udr;

}]]></string>
