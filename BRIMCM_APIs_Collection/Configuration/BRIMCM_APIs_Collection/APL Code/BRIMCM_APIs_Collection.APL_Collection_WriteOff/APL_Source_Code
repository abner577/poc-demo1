RequestCycle sendHistoryErrorResponse(WriteOffHistoryResponse respItem, RequestCycle cycleUdr, string errMsg,string resourceCode, string context) {
        WriteOffHistoryResponseInfo respInfo = udrCreate(WriteOffHistoryResponseInfo);
        
        ErrorInfo errorInfo = udrCreate(ErrorInfo);
        if(context!=null && strLength(context) == 3){
            //for different scenarios
            respInfo.transactionStatus = strSubstring(context,0,1);
            context = context + " ";
            errorInfo.errorCd = strSubstring(resourceCode,0,3)+strSubstring(context,1,3);
        }else{
            errorInfo.errorCd = resourceCode;
        }
          
          errorInfo.errorMessage = errMsg;
          respInfo.errorInfo = errorInfo;
          respItem.responseInfo = respInfo;
          if(respInfo.transactionStatus == "S")
            cycleUdr.response.statusCode = 200;
          else
            cycleUdr.response.statusCode = 400;
          respInfo.transactionStatus = "F";
          cycleUdr.response.headers=getHeader();
          cycleUdr.response.openAPIUDR = respItem;
          debug("##Error Response :" + cycleUdr);
          return cycleUdr;
}

