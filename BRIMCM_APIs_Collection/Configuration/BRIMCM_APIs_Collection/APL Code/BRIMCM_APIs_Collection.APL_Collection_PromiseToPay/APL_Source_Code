string getpaymentMethodCd(string pmc){
   // Payment Method ( ACH/CARD/PAYPAL )	Payment Method ( A/C/P )
    if(pmc == "ACH") return "A";
    if(pmc == "CARD") return "C";
    if(pmc == "PAYPAL") return "P";
    return "";
}

string formatPayloadDate(string st){
     string str = "";
   if(st !=null || strLength(strTrim(st)) != 0){   
       list<string> listSt = strSplit(st,"-");
       for(string value : listSt){
           str=str+value;
       }
    }
   return str;   
}

string getCardExpDate(string st){
    //MM-YYYY to YYYYMMDD
    string str = "";
   if(st !=null || strLength(strTrim(st)) != 0){   
       list<string> listSt = strSplit(st,"-");
       string m = listSt[0];
       string day = "31";
       if(m == "04" || m == "06" || m == "09" || m == "11" )
            day ="30";
       else if(m == "02"){
           str = "01" + m + listSt[1];
           date dt;
           if(strToDate(dt,str) && dateIsLeapYear(dt))
                day = "29";
           else
                day = "28";
       }
       str = listSt[1] + m + day;
   }
   return str;
}

string getCreatePayload(HeaderInfo headerUdr, PromiseToPayResponseInfo respItem, map<string,list<string>> mapBAN) {
    list<PromiseToPayDetailResponse> p2pResList = respItem.promiseToPayDetails;

    string payload = "{\"SrcApplicationCd\" : \"" + headerUdr.srcApplicationCd + "\","
                   + "\"InputChannelCd\"   : \"" + headerUdr.inputChannelCd + "\","
                   + "\"UserId\" : \"" + headerUdr.userId + "\",";

    payload = payload + "\"Itemsdet\" : [";

    for(int i = 0; i < listSize(p2pResList); i++) {
        PromiseToPayDetailResponse resUdr = listGet(p2pResList, i);

        if(isEmpty(resUdr.errorInfo.errorMessage)) {

            string surcharge         = "";
            string convenienceFeeAmt = "";

            if(resUdr.surchargeAmount > 0) {
                surcharge         = (string)resUdr.surchargeAmount;
                convenienceFeeAmt = "";
            } else if(resUdr.convenienceFeeAmount > 0) {
                surcharge         = "";
                convenienceFeeAmt = (string)resUdr.convenienceFeeAmount;
            }

            payload = payload + "{\"ContractAccount\"      : \"" + listGet(mapGet(mapBAN, resUdr.billingAccountNumber), 0) + "\","
                              + "\"CurrencyCd\"            : \"" + resUdr.currencyCd + "\","
                              + "\"BusinessPartner\"       : \"" + listGet(mapGet(mapBAN, resUdr.billingAccountNumber), 1) + "\","
                              + "\"NoteText\"              : \"" + resUdr.noteText + "\","
                              + "\"PromiseToPayDate\"      : \"" + formatPayloadDate(resUdr.promiseToPayDate) + "\","
                              + "\"PromiseToPayReason\"    : \"" + resUdr.PromiseToPayReason + "\","
                              + "\"TotalPromiseAmount\"    : \"" + resUdr.totalPromiseAmount + "\","
                              + "\"Surcharge\"             : \"" + surcharge + "\","
                              + "\"convenienceFeeAmount\"  : \"" + convenienceFeeAmt + "\",";

            // for invoice
            if(listSize(resUdr.invoiceDetails) > 0) {
                payload = payload + "\"Itemsop\" : [";
                for(int j = 0; j < listSize(resUdr.invoiceDetails); j++) {
                    InvoiceDetail invoiceUdr = listGet(resUdr.invoiceDetails, j);
                    payload = payload + "{\"InvoiceNumber\" : \"" + invoiceUdr.invoiceNumber + "\","
                                     + "\"PromiseAmount\"  : \"" + invoiceUdr.promiseAmount + "\"},";
                }
                payload = strSubstring(payload, 0, strLength(payload) - 1);
                payload = payload + "]},";
            } else {
                payload = payload + "\"Itemsop\" : ["
                                  + "{\"InvoiceNumber\" : \"\","
                                  + "\"PromiseAmount\"  : \"0.00\"}]},";
            }
        }
    }

    payload = strSubstring(payload, 0, strLength(payload) - 1);
    payload = payload + "],";

    if(!isEmpty(respItem.paymentMethodCd)) {
        payload = payload + "\"Itemspym\" : ["
                          + "{\"Pymet\" : \"" + getpaymentMethodCd(respItem.paymentMethodCd) + "\",";

        if(respItem.paymentMethodDetails.cardDetails != null) {
            CardDetails   cardDetails   = respItem.paymentMethodDetails.cardDetails;
            WalletDetails walletDetails = respItem.paymentMethodDetails.walletDetails;
            payload = payload + "\"InstrumentId\"       : \"" + walletDetails.instrumentId + "\","
                              + "\"CardNum\"            : \"" + cardDetails.maskedAccountNumber + "\","
                              + "\"CardType\"           : \"" + cardDetails.cardType + "\","
                              + "\"CardExpirationDate\" : \"" + getCardExpDate(cardDetails.cardExpirationDate) + "\",";
        } else {
            payload = payload + "\"InstrumentId\"       : \"\","
                              + "\"CardNum\"            : \"\","
                              + "\"CardType\"           : \"\","
                              + "\"CardExpirationDate\" : \"\",";
        }

        if(respItem.paymentMethodDetails.bankAccountDetails != null) {
            BankAccountDetails bankAccountDetails = respItem.paymentMethodDetails.bankAccountDetails;
            payload = payload + "\"BankRoutingNumber\" : \"" + bankAccountDetails.bankRoutingNumber + "\","
                              + "\"BankAccountType\"   : \"" + bankAccountDetails.bankAccountType + "\","
                              + "\"BankAccountNumber\" : \"" + bankAccountDetails.bankAccountNumber + "\"}],";
        } else {
            payload = payload + "\"BankRoutingNumber\" : \"\","
                              + "\"BankAccountType\"   : \"\","
                              + "\"BankAccountNumber\" : \"\"}],";
        }
    }

    payload = payload + "\"Itemsmsg\" : [{\"ContractAccount\" : \"\",\"PromiseToPayId\" : \"\",\"PromiseToPayDate\" : \"\",\"MsgId\" : \"\",\"Message\" : \"\"}]}";

    return payload;
}

