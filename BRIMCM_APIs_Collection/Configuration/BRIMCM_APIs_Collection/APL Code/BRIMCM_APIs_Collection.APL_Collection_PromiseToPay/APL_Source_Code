/**
 * Builds the general error response body for Promise To Pay failures.
 *
 * Practical use:
 * - Stores the BAN and busOrgId, if we were able to extract them.
 * - Stores the error code and error message.
 * - Marks the transaction status as failed using "F".
 *
 * @param errorCode Error code to return in the response.
 * @param errorMessage Error message to return in the response.
 * @param BAN Billing account number to include in requestInfo. Can be blank.
 * @param busOrgId Business organization ID to include in requestInfo. Can be blank.
 * @return General Promise To Pay error response UDR.
 */

p2pGeneralErrorResponse buildErrResponseForP2P(string errorCode, string errorMessage, string BAN, string busOrgId) {
    p2pGeneralErrorResponse response = udrCreate(p2pGeneralErrorResponse);

    p2pGeneralErrorRequestInfo requestInfo = udrCreate(p2pGeneralErrorRequestInfo);
    requestInfo.billingAccountNumber = BAN;
    requestInfo.busOrgId = busOrgId;
    response.requestInfo = requestInfo;

    p2pGeneralErrorInfo errorInfo = udrCreate(p2pGeneralErrorInfo);
    errorInfo.errorCd = errorCode;
    errorInfo.errorMessage = errorMessage;

    p2pGeneralErrorResponseInfo responseInfo = udrCreate(p2pGeneralErrorResponseInfo);
    responseInfo.transactionStatus = "F";
    responseInfo.errorInfo = errorInfo;
    response.responseInfo = responseInfo;

    return response;
}


/**
 * Builds the standard JSON response headers for Promise To Pay error responses.
 * 
