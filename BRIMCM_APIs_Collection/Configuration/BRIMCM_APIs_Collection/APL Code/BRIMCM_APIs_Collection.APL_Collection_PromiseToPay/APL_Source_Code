CreatePromiseToPayResponse toCreateResponsePayload(CreatePromiseToPayRequest request){
    CreatePromiseToPayResponse resp = udrCreate(CreatePromiseToPayResponse);
    resp.headerInfo                 = request.headerInfo;
    
    PromiseToPayInfo reqInfo                    = request.promiseToPay; 
    debug("reqInfo : "+reqInfo);
    list<CreatePromiseToPayDetail> p2pReqList   = reqInfo.promiseToPayDetails;
    list<PromiseToPayDetailResponse> p2pResList = listCreate(PromiseToPayDetailResponse);
    for(any item : p2pReqList){
        PromiseToPayDetailResponse p2pResUdr = udrCreate(PromiseToPayDetailResponse);
        p2pResUdr.billingAccountNumber  = (string)item.billingAccountNumber;
        p2pResUdr.busOrgId              = (string)item.busOrgId;
        p2pResUdr.currencyCd            = (string)item.currencyCd;
        p2pResUdr.invoiceDetails        = (list<InvoiceDetail>)item.invoiceDetails;
        p2pResUdr.noteText              = (string)item.noteText;
        p2pResUdr.promiseToPayDate      = (string)item.promiseToPayDate;
        p2pResUdr.PromiseToPayReason    = (string)item.promiseToPayReason;
        p2pResUdr.totalPromiseAmount    = (double)item.totalPromiseAmount;
        p2pResUdr.surchargeAmount       = (double)item.surchargeAmount;
        p2pResUdr.convenienceFeeAmount  = (double)item.convenienceFeeAmount ;
        listAdd(p2pResList,p2pResUdr);
    }
    
    PromiseToPayResponseInfo respItem = udrCreate(PromiseToPayResponseInfo);
    respItem.paymentMethodDetails     = reqInfo.paymentMethodDetails;
    respItem.paymentMethodCd          = reqInfo.paymentMethodCd;
    respItem.promiseToPayDetails      = p2pResList; 
    
    resp.promiseToPay = respItem;
    
 return resp;  
}
    
