CreatePromiseToPayResponse isValidRequest(CreatePromiseToPayResponse resp,string resourceCode){
    PromiseToPayResponseInfo respItem = resp.promiseToPay;
    
/*    1. Remove Payment method Cod from Mandatory Check .
Payment Method Code = ACH ( You need to check if BANK Details are provided ) Mandatory
Payment Method Code = CARD / PAYPAL ( We need to check that Wallet and Card Section is filled ) Mandatory
Payment Method Code = Null ( No check on Bank or Card Details ) nothing is mandatory payment detail section */
    debug("### respItem.paymentMethodCd---" + respItem.paymentMethodCd);
    if (!isEmpty(respItem.paymentMethodCd)) {
        if (respItem.paymentMethodDetails == null) {
            //failure - no payment method defined
            respItem.transactionStatus = "F";
            ErrorInfo errorInfo = udrCreate(ErrorInfo);
            errorInfo.errorMessage = "Failure -- No payment Details defined";
            errorInfo.errorCd = resourceCode;
            respItem.errorInfo = errorInfo;
            resp.promiseToPay = respItem;
            return resp;
        } else if(respItem.paymentMethodCd == "ACH" && respItem.paymentMethodDetails.bankAccountDetails == null){
             //failure - invalid payment method
            respItem.transactionStatus = "F";
            ErrorInfo errorInfo = udrCreate(ErrorInfo);
            errorInfo.errorMessage = "Failure -- Invalid payment method - Need Bank Account Details";
            errorInfo.errorCd = resourceCode;
            respItem.errorInfo = errorInfo;
            resp.promiseToPay = respItem;
            return resp;
        } else if((respItem.paymentMethodCd == "CARD" || respItem.paymentMethodCd == "PAYPAL") && (respItem.paymentMethodDetails.cardDetails == null && respItem.paymentMethodDetails.walletDetails == null)){
             //failure - invalid payment method
            respItem.transactionStatus = "F";
            ErrorInfo errorInfo = udrCreate(ErrorInfo);
            errorInfo.errorMessage = "Failure -- Invalid payment method - Need Card and Wallet Details";
            errorInfo.errorCd = resourceCode;
            respItem.errorInfo = errorInfo;
            resp.promiseToPay = respItem;
            return resp;
        } else if(respItem.paymentMethodDetails.bankAccountDetails != null && respItem.paymentMethodDetails.cardDetails != null){
            //failure - invalid payment method
            respItem.transactionStatus = "F";
            ErrorInfo errorInfo = udrCreate(ErrorInfo);
            errorInfo.errorMessage = "Failure -- Cannot have both bank and card payment methods";
            errorInfo.errorCd = resourceCode;
            respItem.errorInfo = errorInfo;
            resp.promiseToPay = respItem;
            return resp;
        } else if((respItem.paymentMethodCd == "CARD" || respItem.paymentMethodCd == "PAYPAL") && respItem.paymentMethodDetails.cardDetails != null){
            debug("#####Inside card expiration date validation####");
            //Adding card expiration date validation
            CardDetails cdUdr = udrCreate(CardDetails);
            cdUdr = (CardDetails)respItem.paymentMethodDetails.cardDetails;
            if(cdUdr.cardExpirationDate != null){
               if(strLength(cdUdr.cardExpirationDate) != 6 && strIndexOf(cdUdr.cardExpirationDate,"-") != 2){
                   //error - expected format MM-YYYY
                    respItem.transactionStatus = "F";
                    ErrorInfo errorInfo = udrCreate(ErrorInfo);
                    errorInfo.errorMessage = "Failure -- Expected format for cardExpirationDate is MM-YYYY";
                    errorInfo.errorCd = resourceCode;
                    respItem.errorInfo = errorInfo;
                    resp.promiseToPay = respItem;
                    return resp;
               }
            }
        }
      }
    
        list<PromiseToPayDetailResponse> p2pResList = respItem.promiseToPayDetails;
        int count = 0;
        for(int i=0; i < listSize(p2pResList); i++){
            PromiseToPayDetailResponse resUdr = listGet(p2pResList,i);
            if(isEmpty((string)resUdr.billingAccountNumber)){
              ErrorInfo errorInfo = udrCreate(ErrorInfo);
              errorInfo.errorMessage = "Mandatory BAN missing";
              errorInfo.errorCd = resourceCode;
              resUdr.errorInfo = errorInfo;
              count = count + 1;
              continue;
            }
        
    /*    if(listSize(resUdr.invoiceDetails ) <= 0){
            ErrorInfo errorInfo = udrCreate(ErrorInfo);
          errorInfo.errorMessage = "Mandatory invoiceDetails missing";
          errorInfo.errorCd = "40401";
          resUdr.errorInfo = errorInfo;
          count = count + 1;
          continue;
        }else{
            boolean isValid = true;
            for(int j=0; j < listSize(resUdr.invoiceDetails);j++){
                InvoiceDetail invoiceUdr = listGet(resUdr.invoiceDetails,j);
                if(isEmpty(invoiceUdr.invoiceNumber)|| isEmpty((string)invoiceUdr.promiseAmount)){
                    isValid = false;
                    ErrorInfo errorInfo = udrCreate(ErrorInfo);
                    errorInfo.errorMessage = "Mandatory invoice Number or promise amount missing";
                    errorInfo.errorCd = "40401";
                    resUdr.errorInfo = errorInfo;
                    break;
                }
            }
            if(!isValid){
                count = count + 1;
                continue;
            }
        } */
        if(isEmpty((string)resUdr.promiseToPayDate)){
          ErrorInfo errorInfo = udrCreate(ErrorInfo);
          errorInfo.errorMessage = "Mandatory promiseToPayDate missing";
          errorInfo.errorCd = resourceCode;
          resUdr.errorInfo = errorInfo;
          count = count + 1;
          continue;
        }
        if(isEmpty((string)resUdr.totalPromiseAmount)){
          ErrorInfo errorInfo = udrCreate(ErrorInfo);
          errorInfo.errorMessage = "Mandatory totalPromiseAmount missing";
          errorInfo.errorCd = resourceCode;
          resUdr.errorInfo = errorInfo;
          count = count + 1;
          continue;
        }
        listSet(p2pResList,i,resUdr);
    }
    if(count == listSize(p2pResList)){
        //all details have error
         respItem.transactionStatus = "F";
         ErrorInfo errorInfo = udrCreate(ErrorInfo);
          errorInfo.errorMessage = "Failure -- Invalid promiseToPayDetails";
          errorInfo.errorCd = resourceCode;
          respItem.errorInfo = errorInfo;
          resp.promiseToPay = respItem;
          return resp;
    }
    return resp;
}
    

