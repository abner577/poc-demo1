CreatePromiseToPayResponse finalCreateResponsePayload(CreatePromiseToPayResponse resp, map<string,list<string>> mapBAN, map<string,list<string>> outMap,string resourceCode){
    
    list<PromiseToPayDetailResponse> p2pResList = resp.promiseToPay.promiseToPayDetails;
    list<PromiseToPayDetailResponse> p2pFinalList   = listCreate(PromiseToPayDetailResponse);
    
    for(PromiseToPayDetailResponse item : p2pResList){
        
         PromiseToPayDetailResponse p2pResUdr = item;
         if(isEmpty(p2pResUdr.errorInfo.errorMessage)){
            string CA = listGet(mapGet(mapBAN,item.billingAccountNumber), 0);
            CA = CA+formatPayloadDate(p2pResUdr.promiseToPayDate);
            if(listGet(mapGet(outMap,CA),1) == "S")
                p2pResUdr.promiseToPayConfirmationId = listGet(mapGet(outMap,CA), 0);
        
            if(listGet(mapGet(outMap,CA),1) == "E"){
                ErrorInfo errorInfo = udrCreate(ErrorInfo);
                errorInfo.errorCd = resourceCode;
                errorInfo.errorMessage = listGet(mapGet(outMap,CA),2);
                p2pResUdr.errorInfo = errorInfo;
            }
         }
        listAdd(p2pFinalList,p2pResUdr);
    }    
    resp.promiseToPay.promiseToPayDetails  = p2pFinalList;
    
 return resp;  
}

