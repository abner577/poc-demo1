<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<openapiprofile category="Internal">
   <storable name="openapiprofile" storable-id="dr.Configuration" ver="10.1">
      <array classname="java.lang.String" name="Access Groups -read -write -execute" size="3">
         <string name="0" value="Cust_Support"/>
         <string name="1" value="Cust_Admin"/>
         <string name="2" value="Cust_Admin"/>
      </array>
      <storable name="Auxiliary Data" null="true"/>
      <storable name="Data" storable-id="dr.OpenApiProfileData" ver="1.2">
         <boolean name="enable_additional_properties" value="false"/>
         <list classname="java.util.ArrayList" name="ext_refs_files"/>
         <string name="fileName"><![CDATA[CenturyLink_APIs-BRIMCM-APIs-0.3-oas3-resolved.yaml]]></string>
         <boolean name="ignore_readonly" value="false"/>
         <string name="scheme"><![CDATA[---
openapi: 3.0.1
info:
  title: BRIMCM_APIs
  description: This is to document all the APIs that CM wil host to communicate between different portals and BRIM
  version: 0.3-oas3
servers:
- url: https://api-test1.test.intranet
- url: https://api-test2.test.intranet
paths:
  /brimcm/payment/createPayment:
    post:
      tags:
      - payment
      summary: To Capture Payment Information from Portals
      description: "API to capture payment information from various Lumen portals (IVR, Control Centre, MyAccount, EPP etc) and send that information to BRIM"
      operationId: Add payment
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreatePaymentReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreatePaymentResponse'
        "405":
          description: Method Not Allowed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        "400":
          description: "CM will check for Mandatory fields, if the fields are not present then CM send error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreatePaymentResponse'
              example:
                transactionStatus: F
                errorCd: 401
                errorMessage: billingAccountNumber IS NULL
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreatePaymentResponse'
      servers:
      - url: http://148.155.130.78:8088
    servers:
    - url: http://148.155.130.78:8088
  /brimcm/payment/transactions/post:
    post:
      tags:
      - payment
      summary: To Capture Payment Information from Portals
      description: "API to capture payment information from various Lumen portals (IVR, Control Centre, MyAccount, EPP etc) and send that information to BRIM"
      operationId: post payment operation
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PostPaymentReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PostPaymentResp'
        "405":
          description: Method Not Allowed
          content:
