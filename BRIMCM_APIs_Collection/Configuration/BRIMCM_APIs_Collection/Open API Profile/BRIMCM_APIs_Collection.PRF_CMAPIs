          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WriteoffReverseResp'
  /brimcm/account/productMaster:
    post:
      tags:
      - account
      summary: Interface between Product Data Hub and BRIM to send the Material Master Records
      description: API to create or update Material Master Records in SAP S4 System
      operationId: Product Master API
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreateProductMasterReq'
      responses:
        "200":
