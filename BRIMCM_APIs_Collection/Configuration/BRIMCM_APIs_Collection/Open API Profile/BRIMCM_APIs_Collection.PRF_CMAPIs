        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCode in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreateProductMasterResp'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreateProductMasterResp'
components:
  schemas:
    ErrorResponse:
      type: object
      properties:
        status:
          type: string
        error:
          type: string
        message:
          type: string
        path:
          type: string
    PaymentHistoryHeaderInfo:
      type: object
      properties:
        sendTimeStamp:
          type: string
        srcApplicationCd:
          type: string
        requestId:
          type: string
        inputChannelCd:
          type: string
        srcSysTransactionId:
          type: string
      example:
        sendTimeStamp: 2022-01-19T15:47:01.151Z
        srcApplicationCd: KENAN
        requestId: 1234567890
        inputChannelCd: CC_BMG
        srcSysTransactionId: 2346245768
    PaymentHistoryRequestInfo:
      required:
      - searchType
      type: object
      properties:
        searchType:
          type: string
          enum:
          - BillingAccountNumber
          - MasterPaymentId
          - InvoiceNumber
          - TransactionConfirmationId
        paymentScheduleType:
          type: string
          enum:
          - OneTime
          - Scheduled
          - Recurring
          - ALL
        transactionStatus:
          type: string
          enum:
          - Pending
          - Completed
          - Cancelled
          - Error
          - ALL
        startDate:
          type: string
        transactionType:
          type: string
          enum:
          - Payment
          - Refund
          - Chargeback
          - ChargebackReversal
          - ALL
        endDate:
          type: string
        searchValue:
          type: string
      example:
        searchType: BillingAccountNumber
        searchValue: "16181-WIL,1-4321119"
        transactionStatus: ALL
        transactionType: ALL
        paymentScheduleType: ALL
        startDate: 2023-08-01
        endDate: 2023-08-11
    PaymentHistoryReq:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/PaymentHistoryHeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/PaymentHistoryRequestInfo'
    PaymentHistoryResp:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/PaymentHistoryHeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/PaymentHistoryRequestInfo'
        responseInfo:
          $ref: '#/components/schemas/PaymentHistoryTransactionList'
    BillingInvReq:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/ReqInfo'
    BillingInvResp:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/ReqInfo'
        responseInfo:
          $ref: '#/components/schemas/BillingInvResp_responseInfo_1'
    BillingInvResp_responseInfo:
      type: object
      properties:
        transactionStatus:
          type: string
        errorInfo:
          $ref: '#/components/schemas/ErrorInfo'
        billingAccountNumber:
          type: string
        financeAccountNumber:
          type: string
        accountName:
          type: string
        sourceSystem:
          type: string
        invoiceDetails:
          type: array
          items:
            $ref: '#/components/schemas/BillingInvResp_invoiceDetailsInfo'
    BillingInvResp_invoiceDetailsInfo:
      type: object
      properties:
        invoiceDate:
          type: string
        invoiceDueDate:
          type: string
        invoiceNumber:
          type: string
        invoiceStatus:
          type: string
        invoiceDueAmount:
          type: number
          format: double
        invoiceAmount:
          type: number
          format: double
        invoiceCurrency:
          type: string
        sapInvoiceNumber:
          type: string
          example: "1234578"
        documentNumber:
          type: string
        aggregatedPaymentAmount:
          type: number
          format: double
        aggregatedCreditAmount:
          type: number
          format: double
        invoiceClearedDate:
          type: string
    CreatePaymentReq:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        paymentsInfo:
          $ref: '#/components/schemas/CreatePaymentReqInfo'
    CreatePaymentReqInfo:
      type: object
      properties:
        transactionConfirmationId:
          type: string
        customerPaymentDetails:
          $ref: '#/components/schemas/CreateCustomerList'
        paymentMethodDetails:
          $ref: '#/components/schemas/CreatePaymentReqInfo_paymentMethodDetails'
        ivrInteractionId:
          type: string
        userId:
          type: string
        paymentMethodCd:
          type: string
    CreateCustomerList:
      type: array
      items:
        $ref: '#/components/schemas/CreateCustomerDetails'
    CreateCustomerDetails:
      type: object
      properties:
        customerFirstName:
          type: string
          example: Test
        customerLastName:
          type: string
          example: Test
        businessName:
          type: string
        customerType:
          type: string
          example: CON
        customerEmail:
          type: string
          example: test@gmail.com
        billingApplicationCd:
          type: string
          example: ENS
        billingAccountNumber:
          type: string
          example: "490258712"
        addressDetails:
          $ref: '#/components/schemas/CreateCustomerDetails_addressDetails'
        currencyCd:
          type: string
        paymentScheduleCd:
          type: string
        paymentProcessedDate:
          type: string
        convenienceFeeAmount:
          type: number
          format: double
        invoiceNumber:
          type: string
        paymentTypeCd:
          type: string
        paymentAmount:
          type: number
          format: double
        consentMediumCd:
          type: string
        restoralInd:
          type: string
        productTypeCd:
          type: string
    CreatePaymentResponse:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        paymentsInfo:
          $ref: '#/components/schemas/CreatePaymentResponseInfo'
    CreatePaymentResponseInfo:
      type: object
      properties:
        transactionStatus:
          type: string
        transactionConfirmationId:
          type: string
        customerPaymentDetails:
          $ref: '#/components/schemas/CPaymenList'
        paymentMethodDetails:
          $ref: '#/components/schemas/CreatePaymentReqInfo_paymentMethodDetails'
        ivrInteractionId:
          type: string
        userId:
          type: string
        paymentMethodCd:
          type: string
        errorInfo:
          $ref: '#/components/schemas/ErrorInfo'
    CPaymenList:
      type: array
      items:
        $ref: '#/components/schemas/CPaymentResponse'
    CPaymentResponse:
      type: object
      properties:
        customerFirstName:
          type: string
          example: Test
        customerLastName:
          type: string
          example: Test
        businessName:
          type: string
        customerType:
          type: string
          example: CON
        customerEmail:
          type: string
          example: test@gmail.com
        billingApplicationCd:
          type: string
          example: ENS
        billingAccountNumber:
          type: string
          example: "490258712"
        addressDetails:
          $ref: '#/components/schemas/AddressDetails'
        currencyCd:
          type: string
        paymentScheduleCd:
          type: string
        paymentProcessedDate:
          type: string
        convenienceFeeAmount:
          type: number
          format: double
        invoiceNumber:
          type: string
        paymentTypeCd:
          type: string
        paymentAmount:
          type: number
          format: double
        consentMediumCd:
          type: string
        masterPaymentId:
          type: string
        vendorCd:
          type: string
        vendorConfirmationId:
          type: string
        paymentStatus:
          type: string
        cardType:
          type: string
        bankAccountType:
          type: string
        maskedAccountNumber:
          type: string
        errorInfo:
          $ref: '#/components/schemas/ErrorInfo'
        restoralInd:
          type: string
    ErrorInfo:
      type: object
      properties:
        errorMessage:
          type: string
        errorCd:
          type: string
    CPIReq:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/CPIReqInfo'
    HeaderInfo:
      type: object
      properties:
        sendTimeStamp:
          type: string
        srcApplicationCd:
          type: string
        requestId:
          type: string
        inputChannelCd:
          type: string
        userId:
          type: string
        srcSysTransactionId: {}
      example:
        sendTimeStamp: 2022-01-19T15:47:01.151Z
        srcApplicationCd: KENAN
        requestId: 1234567890A
        inputChannelCd: CC_BMG
        userId: AD20987
        srcSysTransactionId: 2346245768
    ReqInfo:
      type: object
      properties:
        requestParams:
          type: array
          example:
          - requestParamType: BillingAccountNumber
            requestParamValue: "16181-WIL,1-4321119,1-DI3B5U-A"
          - requestParamType: Status
            requestParamValue: CLOSED
          items:
            $ref: '#/components/schemas/RequestParamsDetails'
    RequestParamsDetails:
      type: object
      properties:
        requestParamType:
          type: string
          enum:
          - BillingAccountNumber
          - FinanceAccountNumber
          - BusOrgId
          - Status
        requestParamValue:
          type: string
    CPIReqInfo:
      type: object
      properties:
        billingApplicationCd:
          type: string
        requestParamType:
          type: string
          enum:
          - BillingAccountNumber
          - FinanceAccountNumber
          - BusOrgId
          - Status
        requestParamValue:
          type: string
      example:
        billingApplicationCd: KENAN
        requestParamType: BillingAccountNumber
        requestParamValue: "16181-WIL,1-4321119,1-DI3B5U-A"
    CPIResp:
      type: object
      properties:
        headerInfo:
          $ref: '#/components/schemas/HeaderInfo'
        requestInfo:
          $ref: '#/components/schemas/CPIReqInfo'
        responseInfo:
          $ref: '#/components/schemas/CPIResp_responseInfo'
    CPIResp_responseInfo:
      type: object
      properties:
        accountDetailsResponseList:
          type: array
          items:
            $ref: '#/components/schemas/CPIResponseDetails'
    CPIResponseDetails:
      type: object
      properties:
        transactionStatus:
          type: string
        errorInfo:
          $ref: '#/components/schemas/ErrorInfo'
        accountInfo:
          $ref: '#/components/schemas/CPIResp_accountDetails'
        amountDueInfo:
          $ref: '#/components/schemas/CPIResp_amountDueInfo'
        paymentPlanInfo:
