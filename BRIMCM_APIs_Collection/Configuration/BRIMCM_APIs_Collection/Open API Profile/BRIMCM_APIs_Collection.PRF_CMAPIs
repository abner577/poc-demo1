        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreditAdjustmentResp'
  /brimcm/adjustment/writeoff/reverse:
    post:
      tags:
      - adjustments
      summary: Reverse Writeoff from Fusion and Salesforce
      description: API to give the end user ability to reverse a writeoff in document number
      operationId: Writeoff Reverse
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WriteoffReverseReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WriteoffReverseResp'
        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCode in the Response Payload"
          content:
            application/json:
