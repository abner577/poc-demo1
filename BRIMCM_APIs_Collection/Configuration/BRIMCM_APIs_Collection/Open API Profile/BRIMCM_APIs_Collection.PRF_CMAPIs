              schema:
                $ref: '#/components/schemas/AgencyReturnResp'
        "405":
          description: Method Not Allowed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        "400":
          description: "CM will check for Mandatory fields, if the fields are not present then CM send error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorInfo'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AgencyReturnResp'
  /brimcm/collection/strategyworkitem/collectionSteps/retrieve:
    post:
      tags:
      - collections
      summary: Collection steps details API
      description: API to display collection steps details to portals for BAN passed in input request.
      operationId: Collection steps details
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CollectionStepsReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CollectionStepsResp'
        "405":
          description: Method Not Allowed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        "400":
          description: "CM will check for Mandatory fields, if the fields are not present then CM send error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorInfo'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CollectionStepsResp'
  /brimcm/account/customerAccountInfo:
    post:
      tags:
      - account
      summary: "API to capture details of billing account, customer and ultimate customer data"
      description: "API service that provides details of billing account, customer and ultimate customer data"
      operationId: Master Data API
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/MasterDataReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/MasterDataResp'
        "405":
          description: Method Not Allowed
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
        "400":
          description: "CM will check for Mandatory fields, if the fields are not present then CM send error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/MasterDataResp'
              example:
                transactionStatus: F
                errorCd: 401
                errorMessage: billingAccountName IS NULL
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/MasterDataResp'
  /brimcm/collection/dunning/:
    post:
      tags:
      - collections
      summary: API to display the dunning lock details based on BAN and BusOrg Id
      description: API to capture BAN and BusOrg details to get dunning locks details from BRIM and display on Portal
      operationId: Dunning Locks Details
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DunningDetailsReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningDetailsResp'
        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningDetailsResp'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningDetailsResp'
  /brimcm/collection/dunning/update/:
    post:
      tags:
      - collections
      summary: Apply Dunning Locks based on authorization groups
      description: "API to capture BAN, BusOrg and Dunning details to apply dunning locks based on authorization groups and send response back from BRIM to Portal"
      operationId: Apply Dunning Locks
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/DunningLockReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningLockResp'
        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningLockResp'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/DunningLockResp'
  /brimcm/collection/writeoff/:
    post:
      tags:
      - collections
      summary: Write Offs Enterprise API
      description: API to capture write off request initiated by fusion towards BRIM and send response back from BRIM to Portal
      operationId: Write Offs API
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WriteOffReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WriteOffResp'
        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WriteOffResp'
        "500":
          description: Failure Response from S4
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WriteOffResp'
  /brimcm/adjustment/credit/:
    post:
      tags:
      - adjustments
      summary: Credit Adjustment from Fusion and Salesforce
      description: API to give the end user ability to  create an adjustment for credits in BRIM using BAN Number
      operationId: Credit Adjustment
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/CreditAdjustmentReq'
      responses:
        "200":
          description: Success Response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/CreditAdjustmentResp'
        "400":
          description: "CM will check for Mandatory fields in input request, if the mandatory fields are not present, then CM will send the error Message along with errorCd in the Response Payload"
          content:
            application/json:
              schema:
